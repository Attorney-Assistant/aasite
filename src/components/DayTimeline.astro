---
const scenarios = [
  {
    time: "7:30 AM",
    label: "Morning Arrival",
    without: "Staff arrives to 6 overnight voicemails. Starts returning calls manually. 2 leads already called competitors.",
    with: "All 6 leads already qualified. Intake complete. Appointments booked.",
    isEvening: false,
  },
  {
    time: "9:00 AM",
    label: "Peak Call Volume",
    without: "Receptionist juggling 4 simultaneous calls. 2 go to voicemail.",
    with: "All calls answered live. Leads qualified in real-time.",
    isEvening: false,
  },
  {
    time: "10:00 AM",
    label: "Intake Bottleneck",
    without: "Paralegal spends 45 min on intake paperwork for one client.",
    with: "Intake data already captured and organized. Paralegal works on case.",
    isEvening: false,
  },
  {
    time: "12:30 PM",
    label: "Follow-Up Gap",
    without: "Lead from Tuesday still hasn't received follow-up call.",
    with: "All follow-ups completed within 5 minutes of initial contact.",
    isEvening: false,
  },
  {
    time: "2:00 PM",
    label: "Lead Prioritization",
    without: "Attorney manually reviews which leads to prioritize.",
    with: "Qualified leads scored and prioritized. Attorney focuses on best cases.",
    isEvening: false,
  },
  {
    time: "5:30 PM",
    label: "Office Closing",
    without: "Office closes. Phones go to generic voicemail.",
    with: "Seamless handoff. Live coverage continues.",
    isEvening: true,
  },
  {
    time: "9:30 PM",
    label: "After-Hours Lead",
    without: "Potential client calls after seeing a TV ad. Gets voicemail. Calls competitor.",
    with: "Live answer. Lead qualified. Consultation booked for morning.",
    isEvening: true,
  },
  {
    time: "11:45 PM",
    label: "Late Night Form",
    without: "Website form submitted. Auto-reply sent. No follow-up until morning.",
    with: "Form triggers immediate call-back. Lead converted same night.",
    isEvening: true,
  },
];
---

<div class="dt" id="day-timeline">
  <div class="dt-list" role="list">
    {scenarios.map((s, i) => (
      <div class:list={["dt-item", s.isEvening && "dt-item--evening"]} data-index={i} role="listitem">
        <button class="dt-trigger" aria-expanded={i === 0 ? "true" : "false"} aria-controls={`dt-detail-${i}`}>
          <span class="dt-time">{s.time}</span>
          <span class="dt-bar-pip" aria-hidden="true"></span>
          <span class="dt-label">{s.label}</span>
          <span class="dt-chevron" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 5.5L7 9.5L11 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
        <div class:list={["dt-detail", i === 0 && "dt-detail--open"]} id={`dt-detail-${i}`} {...(i !== 0 ? { hidden: true } : {})} style={i === 0 ? "max-height: none;" : ""}>
          <div class="dt-compare">
            <div class="dt-side dt-side--without">
              <div class="dt-side-head">
                <span class="dt-side-icon dt-side-icon--red" aria-hidden="true">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 2L8 8M8 2L2 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </span>
                Without Attorney Assistant
              </div>
              <p>{s.without}</p>
            </div>
            <div class="dt-side dt-side--with">
              <div class="dt-side-head">
                <span class="dt-side-icon dt-side-icon--green" aria-hidden="true">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1.5 5L4 7.5L8.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                With Attorney Assistant
              </div>
              <p>{s.with}</p>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Running progress line -->
  <div class="dt-progress" aria-hidden="true">
    <div class="dt-progress-track"></div>
    <div class="dt-progress-fill"></div>
  </div>
</div>

<noscript>
  <style>
    .dt-detail { display: block !important; max-height: none !important; }
    .dt-detail[hidden] { display: block !important; }
  </style>
</noscript>

<style>
  .dt {
    position: relative;
    max-width: 48rem;
    margin: 0 auto;
  }

  /* ── List ── */
  .dt-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    z-index: 1;
  }

  .dt-item {
    border-bottom: 1px solid #eaecf0;
  }

  .dt-item:last-child { border-bottom: none; }

  /* ── Trigger row ── */
  .dt-trigger {
    display: flex;
    align-items: center;
    width: 100%;
    gap: 0.75rem;
    padding: 0.75rem 0;
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .dt-trigger:hover {
    background: rgba(26,58,92,0.02);
  }

  .dt-trigger:focus-visible {
    outline: 2px solid rgba(26,58,92,0.2);
    outline-offset: -2px;
    border-radius: 6px;
  }

  .dt-time {
    flex: 0 0 72px;
    font-size: 0.75rem;
    font-weight: 700;
    color: #1a3a5c;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .dt-item--evening .dt-time {
    color: #475467;
  }

  .dt-bar-pip {
    flex: 0 0 10px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #f87171;
    border: 2px solid #fff;
    box-shadow: 0 0 0 1px #e5e7eb;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .dt-item--evening .dt-bar-pip {
    background: #1a3a5c;
  }

  .dt-trigger[aria-expanded="true"] .dt-bar-pip {
    background: #1a3a5c;
    box-shadow: 0 0 0 1px #1a3a5c, 0 0 0 4px rgba(26,58,92,0.12);
  }

  .dt-label {
    flex: 1;
    font-size: 0.875rem;
    font-weight: 600;
    color: #344054;
    text-align: left;
  }

  .dt-chevron {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    color: #98a2b3;
    transition: transform 0.25s ease, color 0.25s ease;
  }

  .dt-trigger[aria-expanded="true"] .dt-chevron {
    transform: rotate(180deg);
    color: #1a3a5c;
  }

  /* ── Detail panel ── */
  .dt-detail {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1);
  }

  .dt-detail[hidden] {
    display: block;
    max-height: 0 !important;
  }

  .dt-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin: 0 0 0.75rem 82px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #e5e7eb;
  }

  .dt-side {
    padding: 0.75rem 1rem;
  }

  .dt-side--without {
    background: #fef3f2;
    border-right: 1px solid #e5e7eb;
  }

  .dt-side--with {
    background: #f0fdf4;
  }

  .dt-side-head {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.375rem;
  }

  .dt-side--without .dt-side-head { color: #b42318; }
  .dt-side--with .dt-side-head { color: #15803d; }

  .dt-side-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dt-side-icon--red { background: #fee4e2; color: #d92d20; }
  .dt-side-icon--green { background: #dcfce7; color: #15803d; }

  .dt-side p {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: #475467;
    margin: 0;
  }

  .dt-side--with p {
    color: #344054;
    font-weight: 500;
  }

  /* ── Progress line (vertical, behind pips) ── */
  .dt-progress {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 77px;
    width: 2px;
    z-index: 0;
  }

  .dt-progress-track {
    position: absolute;
    inset: 0;
    background: #eaecf0;
    border-radius: 1px;
  }

  .dt-progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 62.5%;
    background: linear-gradient(180deg, #f87171 0%, #1a3a5c 100%);
    border-radius: 1px;
    transition: background 0.3s ease;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .dt-time { flex: 0 0 60px; font-size: 0.6875rem; }

    .dt-compare {
      grid-template-columns: 1fr;
      margin-left: 70px;
    }

    .dt-side--without {
      border-right: none;
      border-bottom: 1px solid #e5e7eb;
    }

    .dt-progress { left: 65px; }
  }
</style>

<script>
(function () {
  const root = document.getElementById("day-timeline") as HTMLElement | null;
  if (!root) return;

  root.addEventListener("click", (e: Event) => {
    const target = e.target as HTMLElement;
    const trigger = target.closest(".dt-trigger") as HTMLButtonElement | null;
    if (!trigger) return;

    const controlsId = trigger.getAttribute("aria-controls");
    const detail = controlsId ? root.querySelector(`#${controlsId}`) as HTMLElement | null : null;
    if (!detail) return;

    const isExpanded = trigger.getAttribute("aria-expanded") === "true";

    // Collapse all others
    root.querySelectorAll<HTMLButtonElement>('.dt-trigger[aria-expanded="true"]').forEach((t) => {
      if (t === trigger) return;
      t.setAttribute("aria-expanded", "false");
      const otherId = t.getAttribute("aria-controls");
      const other = otherId ? root.querySelector(`#${otherId}`) as HTMLElement | null : null;
      if (other) {
        other.style.maxHeight = other.scrollHeight + "px";
        other.getBoundingClientRect();
        other.style.maxHeight = "0";
        other.addEventListener("transitionend", () => {
          if (other.style.maxHeight === "0px" || other.style.maxHeight === "0") {
            other.setAttribute("hidden", "");
            other.style.maxHeight = "";
          }
        }, { once: true });
      }
    });

    if (isExpanded) {
      trigger.setAttribute("aria-expanded", "false");
      detail.style.maxHeight = detail.scrollHeight + "px";
      detail.getBoundingClientRect();
      detail.style.maxHeight = "0";
      detail.addEventListener("transitionend", () => {
        if (detail.style.maxHeight === "0px" || detail.style.maxHeight === "0") {
          detail.setAttribute("hidden", "");
          detail.style.maxHeight = "";
        }
      }, { once: true });
    } else {
      trigger.setAttribute("aria-expanded", "true");
      detail.removeAttribute("hidden");
      const h = detail.scrollHeight;
      detail.style.maxHeight = "0";
      detail.getBoundingClientRect();
      detail.style.maxHeight = h + "px";
      detail.addEventListener("transitionend", () => {
        if (detail.style.maxHeight !== "0px" && detail.style.maxHeight !== "0") {
          detail.style.maxHeight = "none";
        }
      }, { once: true });
    }
  });
})();
</script>
