---
export interface Props {
  videoId: string;
  title?: string;
}

const { videoId, title = "Video testimonial" } = Astro.props;
const thumbnailUrl = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
---

<div class="youtube-facade group relative aspect-video rounded-2xl overflow-hidden bg-brand-950 shadow-xl ring-1 ring-white/10" data-video-id={videoId}>
  <img
    src={thumbnailUrl}
    alt={`Video: ${title}`}
    class="absolute inset-0 w-full h-full object-cover transition-all duration-500 group-hover:opacity-80 group-hover:scale-105"
    loading="lazy"
  />
  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
  <button
    type="button"
    class="youtube-play-btn absolute inset-0 w-full h-full flex items-center justify-center cursor-pointer bg-transparent border-none focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-brand-gold/50 rounded-2xl"
    aria-label={`Play video: ${title}`}
  >
    <div class="w-16 h-16 md:w-18 md:h-18 bg-brand-gold rounded-full flex items-center justify-center shadow-2xl transition-all duration-300 group-hover:scale-110 group-hover:shadow-glow">
      <svg class="w-6 h-6 md:w-7 md:h-7 text-brand-900 ml-0.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M8 5v14l11-7z" />
      </svg>
    </div>
  </button>
</div>

<script is:inline>
  document.querySelectorAll(".youtube-facade").forEach(function (el) {
    function loadVideo() {
      var videoId = el.getAttribute("data-video-id");
      var iframe = document.createElement("iframe");
      iframe.setAttribute("src", "https://www.youtube.com/embed/" + videoId + "?autoplay=1&rel=0");
      iframe.setAttribute("frameborder", "0");
      iframe.setAttribute("allow", "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture");
      iframe.setAttribute("allowfullscreen", "");
      iframe.setAttribute("title", el.querySelector(".youtube-play-btn")?.getAttribute("aria-label") || "Video");
      iframe.className = "absolute inset-0 w-full h-full rounded-2xl";
      el.innerHTML = "";
      el.appendChild(iframe);
    }
    var playBtn = el.querySelector(".youtube-play-btn");
    if (playBtn) {
      playBtn.addEventListener("click", loadVideo, { once: true });
    }
  });
</script>
