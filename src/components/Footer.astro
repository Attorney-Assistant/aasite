---
const currentYear = new Date().getFullYear();

const footerSections = [
  {
    title: "Services",
    links: [
      { href: "/services/intake-360", label: "24/7 Intake" },
      { href: "/services/impact-assistants", label: "Dedicated Legal Support" },
      { href: "/services/virtual-legal-assistants", label: "Virtual Legal Assistants" },
      { href: "/services/admin-support", label: "Admin Support" },
      { href: "/services/legal-receptionist", label: "Legal Receptionist" },
      { href: "/services", label: "All Services" },
    ],
  },
  {
    title: "Resources",
    links: [
      { href: "/blog", label: "Blog" },
      { href: "/guides", label: "Guides" },
      { href: "/webinars", label: "Webinars" },
      { href: "/podcast", label: "Podcast" },
      { href: "/all-scripts-2025", label: "Scripts" },
    ],
  },
  {
    title: "Company",
    links: [
      { href: "/about", label: "About Us" },
      { href: "/our-story", label: "Our Story" },
      { href: "/our-team", label: "Our Team" },
      { href: "/careers", label: "Careers" },
      { href: "/reviews", label: "Reviews" },
      { href: "/contact", label: "Contact" },
    ],
  },
  {
    title: "Legal",
    links: [
      { href: "/privacy-policy", label: "Privacy Policy" },
      { href: "/faq", label: "FAQ" },
    ],
  },
];
---

<footer class="bg-brand-950 grain-overlay relative overflow-hidden">
  <!-- Subtle gradient accent at top -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-gold/40 to-transparent"></div>

  <!-- Main footer -->
  <div class="container-wide pt-20 pb-16 relative z-10">
    <div class="grid grid-cols-2 md:grid-cols-6 gap-10 md:gap-8">
      <!-- Brand column -->
      <div class="col-span-2">
        <a href="/" class="inline-block mb-6">
          <img src="/brand/logos/Attorney%20Assistant_H_White.svg" alt="Attorney Assistant" class="h-9 w-auto" />
        </a>
        <p class="text-gray-400 text-sm leading-relaxed max-w-xs mb-8">
          Expert legal support services helping law firms streamline operations, serve more clients, and achieve better outcomes.
        </p>
        <div class="divider-gold mb-8"></div>
        <a href="/contact" class="btn-primary text-sm group">
          Book a Call
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>

      <!-- Link columns -->
      {footerSections.map((section) => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-brand-gold mb-5">
            {section.title}
          </h3>
          <ul class="space-y-3">
            {section.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10 relative z-10">
    <div class="container-wide py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} Attorney Assistant. All rights reserved.
      </p>
      <div class="flex items-center gap-5">
        <a href="https://www.youtube.com/@attorneyassistant1173" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-brand-gold transition-colors duration-200" aria-label="YouTube">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/attorney-assistant" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-brand-gold transition-colors duration-200" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
