---
const currentYear = new Date().getFullYear();

const footerSections = [
  {
    title: "Services",
    links: [
      { href: "/services/lead-recovery", label: "Stop Losing Leads" },
      { href: "/services/intake-360", label: "Fix Your Intake" },
      { href: "/services/lead-follow-up", label: "Never Miss a Follow-Up" },
      { href: "/services/after-hours", label: "24/7 Coverage" },
      { href: "/services/admin-support", label: "Streamline Operations" },
      { href: "/services/marketing-support", label: "Marketing ROI" },
      { href: "/services", label: "All Services" },
      { href: "/pricing", label: "Pricing" },
    ],
  },
  {
    title: "Resources",
    links: [
      { href: "/blog", label: "Blog" },
      { href: "/guides", label: "Guides" },
      { href: "/webinars", label: "Webinars" },
      { href: "/podcast", label: "Podcast" },
      { href: "/all-scripts-2025", label: "Scripts" },
    ],
  },
  {
    title: "Company",
    links: [
      { href: "/about", label: "About Us" },
      { href: "/our-story", label: "Our Story" },
      { href: "/our-team", label: "Our Team" },
      { href: "/careers", label: "Careers" },
      { href: "/reviews", label: "Reviews" },
      { href: "/contact", label: "Contact" },
    ],
  },
  {
    title: "Legal",
    links: [
      { href: "/privacy-policy", label: "Privacy Policy" },
      { href: "/attorney-assistant-contract-terms", label: "Contract Terms" },
      { href: "/intake-360-terms", label: "Intake 360 Terms" },
      { href: "/faq", label: "FAQ" },
    ],
  },
];
---

<footer class="bg-brand-950 grain-overlay relative overflow-hidden">
  <!-- Subtle gradient accent at top -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-gold/40 to-transparent"></div>

  <!-- Main footer -->
  <div class="container-wide pt-20 pb-16 relative z-10">
    <div class="grid grid-cols-2 md:grid-cols-6 gap-10 md:gap-8">
      <!-- Brand column -->
      <div class="col-span-2">
        <a href="/" class="inline-block mb-6">
          <img src="/brand/logos/long_white_logo.svg" alt="Attorney Assistant" class="h-9 w-auto" />
        </a>
        <p class="text-gray-400 text-sm leading-relaxed max-w-xs mb-6">
          We handle the work law firms need to grow but hate to manage — intake, follow-up, admin, and operations.
        </p>
        <div class="space-y-2 mb-6">
          <a href="tel:+12153372677" class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
            <svg class="w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            +1 (215) 337-2677
          </a>
          <p class="flex items-start gap-2 text-sm text-gray-500">
            <svg class="w-3.5 h-3.5 mt-0.5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
            21 East 5th Ave Suite 102, Conshohocken, PA 19428
          </p>
        </div>
        <div class="divider-gold mb-8"></div>
        <div class="flex flex-wrap gap-3">
          <a href="/book-call" class="btn-primary text-sm group">
            Book a Call
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </a>
          <a href="https://turnkeyops.my.site.com/aaclientportal/s/" target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm group">
            Client Portal
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {footerSections.map((section) => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-brand-gold mb-5">
            {section.title}
          </h3>
          <ul class="space-y-3">
            {section.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10 relative z-10">
    <div class="container-wide py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} Attorney Assistant. All rights reserved.
      </p>
      <div class="flex items-center gap-5">
        <a href="https://www.youtube.com/@attorneyassistant" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-brand-gold transition-colors duration-200" aria-label="YouTube">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/attorneyassistant/" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-brand-gold transition-colors duration-200" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://www.instagram.com/attorneyassistant" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-brand-gold transition-colors duration-200" aria-label="Instagram">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://web.facebook.com/attyassistant/" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-brand-gold transition-colors duration-200" aria-label="Facebook">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.google.com/maps/place/?q=place_id:ChIJKSqaqoG_xokRw6mNcCWmxcI" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-brand-gold transition-colors duration-200" aria-label="Google Reviews">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
