---
// No props — content is self-contained
---

<section class="scrollytelling-section" aria-label="Revenue impact story">

  <!-- ===== ACT 1: Right now, your firm is leaking revenue ===== -->
  <div class="act act-1" id="act-1">
    <div class="act-sentinel" aria-hidden="true"></div>
    <div class="act-inner">
      <div class="container-wide">

        <div class="act-header">
          <div class="act-eyebrow">
            <span class="eyebrow-dot eyebrow-dot--red"></span>
            The Reality
          </div>
          <h2 class="act-title">
            Right now, your firm<br />
            <span class="text-red-400">is leaking revenue.</span>
          </h2>
          <p class="act-subtitle">Every hour you're not available, leads choose someone who is.</p>
        </div>

        <!-- Counter cards -->
        <div class="counter-grid">

          <!-- Card 1: Missed calls -->
          <div class="counter-card counter-card--danger">
            <div class="counter-card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                <!-- X mark overlay -->
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 9l4 4m0-4l-4 4" class="x-mark" />
              </svg>
            </div>
            <div class="counter-card-body">
              <div class="counter-number text-red-400">
                <span class="counter" data-target="3">0</span>
              </div>
              <div class="counter-label">missed calls <span class="counter-sub">today</span></div>
              <div class="counter-pulse">
                <span class="pulse-ring pulse-ring--red"></span>
                <span class="pulse-dot pulse-dot--red"></span>
              </div>
            </div>
          </div>

          <!-- Card 2: Intake time -->
          <div class="counter-card counter-card--warn">
            <div class="counter-card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="counter-card-body">
              <div class="counter-number text-orange-400">
                <span class="counter" data-target="47">0</span>
                <span class="counter-unit">min</span>
              </div>
              <div class="counter-label">average <span class="counter-sub">intake time</span></div>
              <div class="counter-bar-wrap">
                <div class="counter-bar counter-bar--warn"></div>
              </div>
            </div>
          </div>

          <!-- Card 3: Marketing conversion -->
          <div class="counter-card counter-card--neutral">
            <div class="counter-card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
              </svg>
            </div>
            <div class="counter-card-body">
              <div class="spend-row">
                <span class="spend-amount">$4,200</span>
                <span class="spend-arrow">→</span>
                <span class="counter-number text-red-400">
                  <span class="counter" data-target="12">0</span>
                  <span class="counter-unit">%</span>
                </span>
              </div>
              <div class="counter-label">marketing spend <span class="counter-sub">converted</span></div>
              <div class="counter-bar-wrap">
                <div class="counter-bar counter-bar--danger" style="--bar-width: 12%"></div>
              </div>
            </div>
          </div>

        </div><!-- /counter-grid -->

      </div>
    </div>
  </div>

  <!-- ===== ACT 2: The overnight gap ===== -->
  <div class="act act-2" id="act-2">
    <div class="act-sentinel" aria-hidden="true"></div>
    <div class="act-inner">
      <div class="container-wide">

        <div class="act-header">
          <div class="act-eyebrow">
            <span class="eyebrow-dot eyebrow-dot--gray"></span>
            The Overnight Gap
          </div>
          <h2 class="act-title">
            Every night, your firm<br />
            <span class="text-gray-400">goes dark.</span>
          </h2>
          <p class="act-subtitle">While you sleep, leads are choosing your competitors.</p>
        </div>

        <!-- Timeline visualization -->
        <div class="timeline-wrap">
          <div class="timeline-header">
            <span class="timeline-time">6:00 PM</span>
            <span class="timeline-label">Firm closes</span>
            <span class="timeline-spacer"></span>
            <span class="timeline-label">Firm opens</span>
            <span class="timeline-time">8:00 AM</span>
          </div>

          <div class="timeline-bar-wrap">
            <!-- Active hours (tiny slices on each end) -->
            <div class="timeline-active timeline-active--left">
              <span class="timeline-active-label">Open</span>
            </div>
            <!-- Gap (the dark overnight block) -->
            <div class="timeline-gap">
              <div class="timeline-gap-label">
                <svg class="gap-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
                </svg>
                <span>Your firm goes offline</span>
              </div>
              <div class="timeline-gap-hours">14 hours of silence</div>
            </div>
            <div class="timeline-active timeline-active--right">
              <span class="timeline-active-label">Open</span>
            </div>
          </div>

          <!-- Lead scenario -->
          <div class="lead-scenario">
            <div class="lead-event">
              <div class="lead-event-time">10:47 PM</div>
              <div class="lead-event-connector">
                <span class="lead-event-dot lead-event-dot--active"></span>
                <span class="lead-event-line"></span>
              </div>
              <div class="lead-event-card">
                <div class="lead-event-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                  </svg>
                </div>
                <div class="lead-event-content">
                  <p class="lead-event-title">Lead fills out your contact form</p>
                  <p class="lead-event-detail">"I need help with my case — it's urgent."</p>
                </div>
              </div>
            </div>

            <div class="lead-event lead-event--silence">
              <div class="lead-event-time">…</div>
              <div class="lead-event-connector">
                <span class="lead-event-dot lead-event-dot--dim"></span>
                <span class="lead-event-line lead-event-line--dashed"></span>
              </div>
              <div class="lead-event-card lead-event-card--dim">
                <div class="lead-event-icon lead-event-icon--dim">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                  </svg>
                </div>
                <div class="lead-event-content">
                  <p class="lead-event-title">No response. Radio silence.</p>
                  <p class="lead-event-detail">Your firm is closed. No one picks up.</p>
                </div>
              </div>
            </div>

            <div class="lead-event lead-event--lost">
              <div class="lead-event-time">8:02 AM</div>
              <div class="lead-event-connector">
                <span class="lead-event-dot lead-event-dot--red"></span>
              </div>
              <div class="lead-event-card lead-event-card--lost">
                <div class="lead-event-icon lead-event-icon--red">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                  </svg>
                </div>
                <div class="lead-event-content">
                  <p class="lead-event-title lead-event-title--red">They've already called another firm.</p>
                  <p class="lead-event-detail">9+ hours later — the moment is gone.</p>
                </div>
              </div>
            </div>

          </div><!-- /lead-scenario -->

          <!-- Overnight counter -->
          <div class="overnight-counter">
            <div class="overnight-counter-label">Leads lost overnight this week</div>
            <div class="overnight-counter-number">
              <span class="counter" data-target="5">0</span>
            </div>
            <div class="overnight-counter-sub">and counting — every week</div>
          </div>

        </div><!-- /timeline-wrap -->

      </div>
    </div>
  </div>

  <!-- ===== ACT 3: Now imagine every lead handled ===== -->
  <div class="act act-3" id="act-3">
    <div class="act-sentinel" aria-hidden="true"></div>

    <!-- Gold divider that sweeps in -->
    <div class="gold-divider" aria-hidden="true">
      <div class="gold-divider-line"></div>
    </div>

    <div class="act-inner">
      <div class="container-wide">

        <div class="act-header">
          <div class="act-eyebrow act-eyebrow--gold">
            <span class="eyebrow-dot eyebrow-dot--gold"></span>
            The Transformation
          </div>
          <h2 class="act-title">
            Now imagine<br />
            <span class="text-gold">every lead handled.</span>
          </h2>
          <p class="act-subtitle act-subtitle--light">Attorney Assistant's 24/7 intake team means no lead ever goes unanswered.</p>
        </div>

        <!-- Transformed counter cards -->
        <div class="counter-grid">

          <!-- Card 1: Zero missed calls -->
          <div class="counter-card counter-card--gold">
            <div class="counter-card-icon counter-card-icon--gold">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="counter-card-body">
              <div class="counter-number text-green-400">
                <span class="counter" data-target="0">99</span>
              </div>
              <div class="counter-label">missed calls <span class="counter-sub counter-sub--green">this month</span></div>
              <div class="result-badge result-badge--green">
                <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                24/7 always answered
              </div>
            </div>
          </div>

          <!-- Card 2: 5 min intake -->
          <div class="counter-card counter-card--gold">
            <div class="counter-card-icon counter-card-icon--gold">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="counter-card-body">
              <div class="counter-number text-green-400">
                <span class="counter" data-target="5">47</span>
                <span class="counter-unit">min</span>
              </div>
              <div class="counter-label">avg intake <span class="counter-sub counter-sub--green">down from 47</span></div>
              <div class="result-badge result-badge--green">
                <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                89% faster intake
              </div>
            </div>
          </div>

          <!-- Card 3: 38% conversion -->
          <div class="counter-card counter-card--gold">
            <div class="counter-card-icon counter-card-icon--gold">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
              </svg>
            </div>
            <div class="counter-card-body">
              <div class="counter-number text-green-400">
                <span class="counter" data-target="38">12</span>
                <span class="counter-unit">%</span>
              </div>
              <div class="counter-label">conversion rate <span class="counter-sub counter-sub--green">up from 12%</span></div>
              <div class="counter-bar-wrap">
                <div class="counter-bar counter-bar--gold" style="--bar-width: 38%"></div>
              </div>
            </div>
          </div>

        </div><!-- /counter-grid -->

        <!-- Act 3 scenario replay -->
        <div class="act3-scenario">

          <div class="act3-scenario-timeline">

            <div class="act3-event">
              <div class="act3-time">10:47 PM</div>
              <div class="act3-connector">
                <span class="act3-dot act3-dot--gold"></span>
                <span class="act3-line"></span>
              </div>
              <div class="act3-card">
                <p class="act3-card-title">Lead fills out your contact form</p>
                <p class="act3-card-detail">"I need help with my case — it's urgent."</p>
              </div>
            </div>

            <div class="act3-event">
              <div class="act3-time act3-time--gold">10:49 PM</div>
              <div class="act3-connector">
                <span class="act3-dot act3-dot--green"></span>
                <span class="act3-line act3-line--green"></span>
              </div>
              <div class="act3-card act3-card--highlight">
                <div class="act3-card-badge">
                  <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                  Answered in 90 seconds
                </div>
                <p class="act3-card-title act3-card-title--gold">Attorney Assistant responds</p>
                <p class="act3-card-detail">"Hi! I'm calling from the law firm about your inquiry…"</p>
              </div>
            </div>

            <div class="act3-event">
              <div class="act3-time act3-time--gold">9:00 AM</div>
              <div class="act3-connector">
                <span class="act3-dot act3-dot--green"></span>
              </div>
              <div class="act3-card act3-card--win">
                <div class="act3-card-badge act3-card-badge--gold">
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25" /><path stroke-linecap="round" stroke-linejoin="round" d="M3 18.75A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75" /></svg>
                  Consultation booked for 9am
                </div>
                <p class="act3-card-title act3-card-title--gold">New client secured.</p>
                <p class="act3-card-detail">While your competitors slept, you won the case.</p>
              </div>
            </div>

          </div>

          <!-- Overnight glowing block -->
          <div class="act3-overnight">
            <div class="act3-overnight-glow" aria-hidden="true"></div>
            <div class="act3-overnight-content">
              <div class="act3-overnight-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
                </svg>
              </div>
              <div>
                <p class="act3-overnight-title">24/7 coverage active</p>
                <p class="act3-overnight-sub">No lead goes unanswered — ever</p>
              </div>
            </div>
          </div>

        </div><!-- /act3-scenario -->

        <!-- CTA -->
        <div class="act3-cta">
          <a href="/contact" class="btn-primary btn-lg group">
            Start Capturing Every Lead
            <svg class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>

      </div>
    </div>
  </div>

</section>

<noscript>
  <style>
    .act { opacity: 1 !important; transform: none !important; }
    .gold-divider-line { transform: scaleX(1) !important; }
    .counter-bar { width: var(--bar-width, 50%) !important; transition: none !important; }
  </style>
</noscript>

<style>
  /* =============================================
     BASE SECTION
  ============================================= */
  .scrollytelling-section {
    overflow: hidden;
  }

  /* =============================================
     ACT REVEAL SYSTEM
  ============================================= */
  .act {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }

  .act.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger children inside active acts */
  .act.is-active .act-header { transition-delay: 0ms; }
  .act.is-active .counter-grid { transition-delay: 150ms; }
  .act.is-active .timeline-wrap { transition-delay: 150ms; }
  .act.is-active .act3-scenario { transition-delay: 250ms; }
  .act.is-active .act3-cta { transition-delay: 400ms; }

  /* Sentinel — zero-height trigger element */
  .act-sentinel {
    position: absolute;
    top: 15%;
    left: 0;
    width: 100%;
    height: 1px;
    pointer-events: none;
  }

  /* =============================================
     ACT 1 — DARK NAVY
  ============================================= */
  .act-1 {
    background-color: #091623; /* brand-950 */
    position: relative;
  }

  .act-1::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 80% 20%, rgba(239, 68, 68, 0.06) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 10% 80%, rgba(26, 58, 92, 0.4) 0%, transparent 70%);
    pointer-events: none;
  }

  .act-inner {
    position: relative;
    z-index: 1;
    padding: 5rem 0;
  }

  @media (min-width: 768px) {
    .act-inner { padding: 7rem 0; }
  }

  /* =============================================
     ACT 2 — GRAY/DARK
  ============================================= */
  .act-2 {
    background-color: #0e1a24;
    position: relative;
  }

  .act-2::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 40% at 50% 0%, rgba(26, 58, 92, 0.3) 0%, transparent 70%);
    pointer-events: none;
  }

  /* =============================================
     ACT 3 — NAVY + GOLD
  ============================================= */
  .act-3 {
    background-color: #091623;
    position: relative;
  }

  .act-3::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 20% 30%, rgba(255, 170, 43, 0.07) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 80% 70%, rgba(26, 58, 92, 0.5) 0%, transparent 70%);
    pointer-events: none;
  }

  /* =============================================
     ACT HEADER
  ============================================= */
  .act-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .act-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #588aa5;
    margin-bottom: 1.25rem;
  }

  .act-eyebrow--gold {
    color: #ffaa2b;
  }

  .eyebrow-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .eyebrow-dot--red { background-color: #ef4444; box-shadow: 0 0 8px rgba(239, 68, 68, 0.6); }
  .eyebrow-dot--gray { background-color: #475467; }
  .eyebrow-dot--gold { background-color: #ffaa2b; box-shadow: 0 0 8px rgba(255, 170, 43, 0.6); animation: pulse-gold 2s ease-in-out infinite; }

  @keyframes pulse-gold {
    0%, 100% { box-shadow: 0 0 8px rgba(255, 170, 43, 0.6); }
    50% { box-shadow: 0 0 16px rgba(255, 170, 43, 0.9); }
  }

  .act-title {
