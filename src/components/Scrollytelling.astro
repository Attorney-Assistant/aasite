  .stat-bar--danger { background: linear-gradient(90deg, #ef4444, #dc2626); }
  .stat-bar--warn { background: linear-gradient(90deg, #fb923c, #ea580c); }
  .stat-bar--gold { background: linear-gradient(90deg, #F9A630, #e69500); }

  /* =============================================
     DIVIDER
  ============================================= */
  .st-divider {
