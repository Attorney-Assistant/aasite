</style>

<script>
(function () {
  // ── Utility: ease-out cubic ──────────────────────────────────────────────
  function easeOutCubic(t: number): number {
    return 1 - Math.pow(1 - t, 3);
  }

  // ── Counter animation ────────────────────────────────────────────────────
  function animateCounter(el: HTMLElement, start: number, target: number, duration: number = 2000): void {
    const startTime = performance.now();

    function step(now: number): void {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const value = Math.round(start + (target - start) * easeOutCubic(progress));
      el.textContent = String(value);
      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        el.textContent = String(target);
      }
    }

    requestAnimationFrame(step);
  }

  // ── Typewriter ────────────────────────────────────────────────────────────
  const twInner = document.getElementById('tw-inner') as HTMLElement | null;
  const twParent = twInner?.parentElement as HTMLElement | null;
  let typewriterDone = false;

  function runTypewriter(): void {
    if (typewriterDone || !twInner || !twParent) return;
    typewriterDone = true;
    const text = "I need help with my case — it's urgent.";
    let idx = 0;
    twInner.textContent = '';
    const interval = setInterval(() => {
      twInner.textContent = text.slice(0, ++idx);
      if (idx >= text.length) {
        clearInterval(interval);
        twParent?.classList.add('done');
      }
    }, 42);
  }

  // ── Track which acts have animated ──────────────────────────────────────
  const animated = new WeakSet<Element>();

  // ── Stagger counter cards ────────────────────────────────────────────────
  function staggerCards(act: Element, selector: string): void {
    const cards = act.querySelectorAll<HTMLElement>(selector);
    cards.forEach((card) => {
      const delay = parseInt(card.dataset.stagger || '0', 10);
      setTimeout(() => {
        card.classList.add('card-visible');
      }, delay);
    });
  }

  // ── Activate an act ─────────────────────────────────────────────────────
  function activateAct(act: Element): void {
    if (animated.has(act)) return;
    animated.add(act);

    act.classList.add('is-active');

    const actId = act.id;

    // Animate counters with stagger
    act.querySelectorAll<HTMLElement>('.counter[data-target]').forEach((el) => {
      const target = parseInt(el.dataset.target || '0', 10);
      const start = parseInt(el.dataset.start || el.textContent || '0', 10);
      const cardEl = el.closest<HTMLElement>('.stagger-card, .stagger-card-3');
      const cardDelay = cardEl ? parseInt(cardEl.dataset.stagger || '0', 10) : 0;

      setTimeout(() => {
        animateCounter(el, start, target, 1800);
      }, 200 + cardDelay);
    });

    // Stagger cards for Act 1
    if (actId === 'act-1') {
      staggerCards(act, '.stagger-card');
    }

    // Stagger + shimmer cards for Act 3
    if (actId === 'act-3') {
      staggerCards(act, '.stagger-card-3');
    }

    // Typewriter fires when Act 2 activates
    if (actId === 'act-2') {
      setTimeout(runTypewriter, 600);
    }
  }

  // ── Progress bar ─────────────────────────────────────────────────────────
  const progressBar = document.getElementById('st-progress') as HTMLElement | null;
  const progressFill = document.getElementById('st-progress-fill') as HTMLElement | null;
  const section = document.querySelector('.scrollytelling-section') as HTMLElement | null;

  function updateProgress(): void {
    if (!section || !progressBar || !progressFill) return;
    const rect = section.getBoundingClientRect();
    const sectionHeight = section.offsetHeight;
    const viewH = window.innerHeight;

    // Section is in view?
    if (rect.top < viewH && rect.bottom > 0) {
      progressBar.classList.add('visible');
      const scrolled = Math.max(0, -rect.top);
      const total = Math.max(1, sectionHeight - viewH);
      const pct = Math.min(100, (scrolled / total) * 100);
      progressFill.style.width = pct + '%';
    } else {
      progressBar.classList.remove('visible');
    }
  }

  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();

  // ── "See the difference" button ──────────────────────────────────────────
  const seeDiffBtn = document.getElementById('see-diff-btn');
  seeDiffBtn?.addEventListener('click', () => {
    const act3 = document.getElementById('act-3');
    act3?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // ── IntersectionObserver (own instance) ─────────────────────────────────
  const sentinels = document.querySelectorAll<HTMLElement>('.act-sentinel');
  if (!sentinels.length) return;

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.intersectionRatio >= 0.25) {
          const act = entry.target.closest<HTMLElement>('.act');
          if (act) {
            activateAct(act);
            observer.unobserve(entry.target);
          }
        }
      });
    },
    {
      threshold: [0, 0.25, 0.5, 0.75],
      rootMargin: '0px 0px -10% 0px',
    }
  );

  sentinels.forEach((sentinel) => {
    observer.observe(sentinel);
  });
})();
</script>
