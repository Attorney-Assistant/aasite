<script>
(function () {
  // ── Utility: ease-out cubic ──────────────────────────────────────────────
  function easeOutCubic(t: number): number {
    return 1 - Math.pow(1 - t, 3);
  }

  // ── Counter animation ────────────────────────────────────────────────────
  function animateCounter(el: Element, target: number, duration: number = 2000): void {
    const start = parseInt((el as HTMLElement).textContent || '0', 10);
    const startTime = performance.now();

    function step(now: number): void {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const value = Math.round(start + (target - start) * easeOutCubic(progress));
      el.textContent = String(value);
      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        el.textContent = String(target);
      }
    }

    requestAnimationFrame(step);
  }

  // ── Track which acts have animated ──────────────────────────────────────
  const animated = new WeakSet<Element>();

  // ── Activate an act ─────────────────────────────────────────────────────
  function activateAct(act: Element): void {
    if (animated.has(act)) return;
    animated.add(act);

    act.classList.add('is-active');

    // Animate all counters inside this act
    act.querySelectorAll<HTMLElement>('.counter[data-target]').forEach(function (el) {
      const target = parseInt(el.dataset.target || '0', 10);
      // Small delay so the reveal animation has started
      setTimeout(function () {
        animateCounter(el, target, 2000);
      }, 200);
    });
  }

  // ── IntersectionObserver (own instance, separate from global .reveal) ───
  const sentinels = document.querySelectorAll<HTMLElement>('.act-sentinel');
  if (!sentinels.length) return;

  const observer = new IntersectionObserver(
    function (entries) {
      entries.forEach(function (entry) {
        if (entry.intersectionRatio >= 0.25) {
          const act = entry.target.closest<HTMLElement>('.act');
          if (act) {
            activateAct(act);
            observer.unobserve(entry.target);
          }
        }
      });
    },
    {
      threshold: [0, 0.25, 0.5, 0.75],
      rootMargin: '0px 0px -10% 0px',
    }
  );

  sentinels.forEach(function (sentinel) {
    observer.observe(sentinel);
  });
})();
</script>
