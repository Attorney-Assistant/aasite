  }

  .st-story-body {
    font-size: 1rem;
    color: #98a2b3;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .st-story-result {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
