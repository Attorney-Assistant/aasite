    border-radius: 9999px;
  }
  .st-story-result--red {
    color: #f04438;
    background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.2);
  }
  .st-story-result--gold {
    color: #F9A630;
    background: rgba(249,166,48,0.1);
    border: 1px solid rgba(249,166,48,0.2);
  }

  /* hide story blocks via toggle */
  .st-story-block--with { display: none; }
  .st-strip.is-transformed .st-story-block--without { display: none; }
  .st-strip.is-transformed .st-story-block--with { display: block; }

  /* =============================================
     LEGACY — keep tl-wrap reference for JS compat
  ============================================= */
  .tl-wrap { display: none; }


  /* =============================================
     OVERNIGHT COUNTER
  ============================================= */
  .overnight {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    text-align: center;
    max-width: 52rem;
    margin: 0 auto;
    transition: background 0.4s ease, border-color 0.4s ease;
  }

  .st-strip.is-transformed .overnight {
    background: rgba(249,166,48,0.06);
    border-color: rgba(249,166,48,0.2);
  }

  .overnight-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: #98a2b3;
    text-transform: uppercase;
