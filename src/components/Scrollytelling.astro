      opacity: 1;
      transform: none;
      transition: none;
    }

    .stat-bar { transition: none; }

    .st-eyebrow-dot { animation: none; }
    .pulse-ring { animation: none; }
    .particle { animation: none; }
    .st-intro-chevron { animation: none; }
    .st-icon-alarm { animation: none; }
    .st-icon-sun { animation: none; }
    .lead-envelope { animation: none; }
    .st-gold-overlay { transition: none; }
    .content-without, .content-with { transition: none; }
    .stat-card { transition: none; }
    .stat-number { transition: none; }
    .overnight { transition: none; }
    .overnight-num { transition: none; }
  }
</style>

<script>
(function () {
  function easeOutCubic(t: number): number {
    return 1 - Math.pow(1 - t, 3);
  }

  function animateCounter(el: HTMLElement, start: number, target: number, duration = 2000): void {
    const startTime = performance.now();
    function step(now: number): void {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const value = Math.round(start + (target - start) * easeOutCubic(progress));
      el.textContent = String(value);
      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        el.textContent = String(target);
      }
    }
    requestAnimationFrame(step);
  }

  // State management
  const strip = document.getElementById('st-strip') as HTMLElement | null;
  const toggleWithout = document.getElementById('toggle-without') as HTMLButtonElement | null;
  const toggleWith = document.getElementById('toggle-with') as HTMLButtonElement | null;
  const eyebrowText = document.getElementById('st-eyebrow-text') as HTMLElement | null;
  const titleAccent = document.getElementById('st-title-accent') as HTMLElement | null;
  const subtitle = document.getElementById('st-subtitle') as HTMLElement | null;
  let isTransformed = false;
  let hasActivated = false;

  function setState(transformed: boolean): void {
    if (!strip) return;
    isTransformed = transformed;

    if (transformed) {
      strip.classList.add('is-transformed');
      toggleWithout?.classList.remove('is-active-tab');
      toggleWith?.classList.add('is-active-tab');
      toggleWithout?.setAttribute('aria-pressed', 'false');
      toggleWith?.setAttribute('aria-pressed', 'true');
      if (eyebrowText) eyebrowText.textContent = 'The Outcome';
      if (titleAccent) titleAccent.textContent = 'capturing every lead.';
      if (subtitle) subtitle.textContent = 'Attorney Assistant works while you sleep, while you\u2019re busy, while you\u2019re in court \u2014 so no lead goes unanswered.';
    } else {
      strip.classList.remove('is-transformed');
      toggleWithout?.classList.add('is-active-tab');
      toggleWith?.classList.remove('is-active-tab');
      toggleWithout?.setAttribute('aria-pressed', 'true');
      toggleWith?.setAttribute('aria-pressed', 'false');
      if (eyebrowText) eyebrowText.textContent = 'The Reality';
      if (titleAccent) titleAccent.textContent = 'leaking revenue.';
      if (subtitle) subtitle.textContent = "Every hour you're not available, leads choose someone who is.";
    }

    // Morph counters
    strip.querySelectorAll<HTMLElement>('.morph-counter').forEach((el) => {
      const currentVal = parseInt(el.textContent || '0', 10);
      const targetVal = parseInt(
        transformed ? (el.dataset.with || '0') : (el.dataset.without || '0'),
        10
      );
      animateCounter(el, currentVal, targetVal, 1200);
    });
  }

  toggleWithout?.addEventListener('click', () => setState(false));
  toggleWith?.addEventListener('click', () => setState(true));

  // Activate section
  function activate(): void {
    if (hasActivated || !strip) return;
    hasActivated = true;

    strip.classList.add('is-active');

    // Stagger cards
    strip.querySelectorAll<HTMLElement>('.stagger-card').forEach((card) => {
      const delay = parseInt(card.dataset.stagger || '0', 10);
      setTimeout(() => card.classList.add('card-visible'), delay);
    });

    // Animate counters to "without" values
    strip.querySelectorAll<HTMLElement>('.morph-counter').forEach((el) => {
      const targetVal = parseInt(el.dataset.without || '0', 10);
      const cardEl = el.closest<HTMLElement>('.stagger-card');
      const cardDelay = cardEl ? parseInt(cardEl.dataset.stagger || '0', 10) : 0;
      setTimeout(() => animateCounter(el, 0, targetVal, 1800), 200 + cardDelay);
    });

  }

  // Observer
  const sentinel = strip?.querySelector('.st-sentinel');
  if (sentinel) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.intersectionRatio >= 0.25) {
            activate();
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: [0, 0.25, 0.5, 0.75], rootMargin: '0px 0px -10% 0px' }
    );
    observer.observe(sentinel);
  }
})();
</script>
