---
// No props — content is self-contained
---

<!-- Progress bar -->
<div class="st-progress-bar" id="st-progress" aria-hidden="true">
  <div class="st-progress-fill" id="st-progress-fill"></div>
</div>

<section class="scrollytelling-section" aria-label="Revenue impact story">

  <!-- Intro label -->
  <div class="st-intro">
    <div class="container-wide">
      <div class="st-intro-inner">
        <span class="st-intro-label">The Cost of Doing Nothing</span>
        <div class="st-intro-chevron" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== ACT 1: Right now, your firm is leaking revenue ===== -->
  <div class="act act-1" id="act-1">
    <div class="act-sentinel" aria-hidden="true"></div>

    <!-- Floating particles (CSS-only) -->
    <div class="particles" aria-hidden="true">
      <span class="particle particle-1"></span>
      <span class="particle particle-2"></span>
      <span class="particle particle-3"></span>
      <span class="particle particle-4"></span>
      <span class="particle particle-5"></span>
      <span class="particle particle-6"></span>
      <span class="particle particle-7"></span>
      <span class="particle particle-8"></span>
    </div>

    <!-- Background act number -->
    <div class="act-bg-num" aria-hidden="true">01</div>

    <div class="act-inner">
      <div class="container-wide">

        <div class="act-header">
          <div class="act-eyebrow">
            <span class="eyebrow-dot eyebrow-dot--red"></span>
            The Reality
          </div>
          <!-- Alarm bell icon -->
          <div class="act-header-icon act-header-icon--red" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
            </svg>
          </div>
          <h2 class="act-title">
            Right now, your firm<br />
            <span class="text-red-glow">is leaking revenue.</span>
          </h2>
          <p class="act-subtitle">Every hour you're not available, leads choose someone who is.</p>
        </div>

        <!-- Counter cards with stagger -->
        <div class="counter-grid">

          <!-- Card 1: Missed calls -->
          <div class="counter-card counter-card--danger stagger-card" data-stagger="0" tabindex="0">
            <div class="card-tooltip" role="tooltip">
              Based on average law firm data from ABA 2024 research — most firms miss 3–5 inbound calls per day during business hours due to capacity limits.
            </div>
            <div class="counter-card-icon counter-card-icon--red">
              <!-- Phone + gradient fill -->
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="grad-phone-red" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#ef4444"/>
                    <stop offset="100%" stop-color="#dc2626"/>
                  </linearGradient>
                </defs>
                <path fill="url(#grad-phone-red)" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                <line x1="15" y1="9" x2="19" y2="13" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/>
                <line x1="19" y1="9" x2="15" y2="13" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="counter-card-body">
              <div class="counter-label-row">
                <svg class="inline-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path fill="#ef4444" d="M2.25 5.25C2.25 11.462 7.287 16.5 13.5 16.5H15a1.5 1.5 0 001.5-1.5v-.914a.75.75 0 00-.568-.727l-2.949-.737a.75.75 0 00-.782.278l-.647.863a.75.75 0 01-.807.253 8.024 8.024 0 01-4.762-4.762.75.75 0 01.253-.807l.863-.647a.75.75 0 00.278-.782L5.632 4.07a.75.75 0 00-.727-.569H4a1.5 1.5 0 00-1.5 1.5v.75-.75z"/>
                </svg>
                Missed calls <span class="counter-sub">today</span>
              </div>
              <div class="counter-number text-red-400">
                <span class="counter" data-target="3" data-act="1">0</span>
              </div>
              <div class="counter-pulse">
                <span class="pulse-ring pulse-ring--red"></span>
                <span class="pulse-dot pulse-dot--red"></span>
              </div>
            </div>
          </div>

          <!-- Card 2: Intake time -->
          <div class="counter-card counter-card--warn stagger-card" data-stagger="150" tabindex="0">
            <div class="card-tooltip" role="tooltip">
              Industry research shows the average law firm intake process takes 40–55 minutes. Slow intake frustrates potential clients and reduces conversion rates significantly.
            </div>
            <div class="counter-card-icon counter-card-icon--orange">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="grad-clock-orange" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#fb923c"/>
                    <stop offset="100%" stop-color="#ea580c"/>
                  </linearGradient>
                </defs>
                <circle cx="12" cy="12" r="9" fill="url(#grad-clock-orange)" opacity="0.9"/>
                <path d="M12 7v5h3.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="counter-card-body">
              <div class="counter-label-row">
                <svg class="inline-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="6" fill="#fb923c"/>
                  <path d="M8 5v3.5H10.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                Avg intake time <span class="counter-sub">per lead</span>
              </div>
              <div class="counter-number text-orange-400">
                <span class="counter" data-target="47" data-act="1">0</span>
                <span class="counter-unit">min</span>
              </div>
              <div class="counter-bar-wrap">
                <div class="counter-bar counter-bar--warn" style="--bar-width: 78%"></div>
              </div>
            </div>
          </div>

          <!-- Card 3: Marketing conversion -->
          <div class="counter-card counter-card--neutral stagger-card" data-stagger="300" tabindex="0">
            <div class="card-tooltip" role="tooltip">
              The average law firm converts only 10–15% of marketing-driven leads into paying clients. Attorney Assistant clients average 35–40% after implementing 24/7 intake.
            </div>
            <div class="counter-card-icon counter-card-icon--blue">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="grad-chart-blue" x1="0" y1="1" x2="1" y2="0">
                    <stop offset="0%" stop-color="#50a7dd"/>
                    <stop offset="100%" stop-color="#1a3a5c"/>
                  </linearGradient>
                </defs>
                <rect x="2" y="2" width="20" height="20" rx="4" fill="url(#grad-chart-blue)" opacity="0.9"/>
                <path d="M6 14l3-4 3 3 4-6" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="counter-card-body">
              <div class="spend-row">
                <svg class="inline-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="6" fill="#50a7dd"/>
                  <path d="M8 4v8M6 6h3a1 1 0 010 2H6m0 0h3.5a1 1 0 010 2H6" stroke="#fff" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                <span class="spend-amount">$4,200</span>
                <span class="spend-arrow">→</span>
                <span class="counter-number text-red-400">
                  <span class="counter" data-target="12" data-act="1">0</span>
                  <span class="counter-unit">%</span>
                </span>
              </div>
              <div class="counter-label-row">Marketing spend <span class="counter-sub">converted</span></div>
              <div class="counter-bar-wrap">
                <div class="counter-bar counter-bar--danger" style="--bar-width: 12%"></div>
              </div>
            </div>
          </div>

        </div><!-- /counter-grid -->

        <!-- "See the difference" CTA -->
        <div class="act1-cta">
          <button class="see-diff-btn" id="see-diff-btn" type="button">
            See the difference
            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>

      </div>
    </div>
  </div>

  <!-- ===== ACT 2: The overnight gap ===== -->
  <div class="act act-2" id="act-2">
    <div class="act-sentinel" aria-hidden="true"></div>

    <!-- Background act number -->
    <div class="act-bg-num" aria-hidden="true">02</div>

    <div class="act-inner">
      <div class="container-wide">

        <div class="act-header">
          <div class="act-eyebrow">
            <span class="eyebrow-dot eyebrow-dot--gray"></span>
            The Overnight Gap
          </div>
          <!-- Moon icon -->
          <div class="act-header-icon act-header-icon--gray" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
            </svg>
          </div>
          <h2 class="act-title">
            Every night, your firm<br />
            <span class="text-gray-dim">goes dark.</span>
          </h2>
          <p class="act-subtitle">While you sleep, leads are choosing your competitors.</p>
        </div>

        <!-- Timeline visualization -->
        <div class="timeline-wrap">
          <div class="timeline-header">
            <span class="timeline-time">6:00 PM</span>
            <span class="timeline-label">Firm closes</span>
            <span class="timeline-spacer"></span>
            <span class="timeline-label">Firm opens</span>
            <span class="timeline-time">8:00 AM</span>
          </div>

          <div class="timeline-bar-wrap">
            <!-- Active hours -->
            <div class="timeline-active timeline-active--left">
              <span class="timeline-active-label">Open</span>
            </div>
            <!-- Gap bar — animates from 0 to full -->
            <div class="timeline-gap" id="timeline-gap">
              <div class="timeline-gap-fill" aria-hidden="true"></div>
              <!-- Hover zones -->
              <div class="tl-hover-zone" style="left:15%" data-tip="8 PM — Most leads submit forms after dinner">
                <span class="tl-hz-pip"></span>
                <span class="tl-hz-tooltip">8 PM — Most leads submit forms after dinner</span>
              </div>
              <div class="tl-hover-zone" style="left:40%" data-tip="10:47 PM — Peak legal-distress search time">
                <span class="tl-hz-pip"></span>
                <span class="tl-hz-tooltip">10:47 PM — Peak legal-distress search time</span>
              </div>
              <div class="tl-hover-zone" style="left:68%" data-tip="2 AM — Emergency situations don't wait">
                <span class="tl-hz-pip"></span>
                <span class="tl-hz-tooltip">2 AM — Emergency situations don't wait</span>
              </div>
              <div class="timeline-gap-label">
                <svg class="gap-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
                </svg>
                <span>Your firm goes offline</span>
              </div>
              <div class="timeline-gap-hours">14 hours of silence</div>
            </div>
            <div class="timeline-active timeline-active--right">
              <span class="timeline-active-label">Open</span>
            </div>
          </div>

          <!-- Lead scenario with typewriter -->
          <div class="lead-scenario">

            <div class="lead-event">
              <div class="lead-event-time">10:47 PM</div>
              <div class="lead-event-connector">
                <span class="lead-event-dot lead-event-dot--active"></span>
                <span class="lead-event-line"></span>
              </div>
              <div class="lead-event-card">
                <!-- Animated envelope icon -->
                <div class="lead-event-icon lead-envelope-icon">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <defs>
                      <linearGradient id="grad-env" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#50a7dd"/>
                        <stop offset="100%" stop-color="#1a3a5c"/>
                      </linearGradient>
                    </defs>
                    <rect x="2" y="5" width="20" height="14" rx="2" fill="url(#grad-env)"/>
                    <path d="M2 7l10 7 10-7" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </div>
                <div class="lead-event-content">
                  <p class="lead-event-title">Lead fills out your contact form</p>
                  <p class="lead-event-detail typewriter" id="typewriter-text" aria-label="Quote: I need help with my case — it's urgent.">"<span id="tw-inner"></span>"</p>
                </div>
              </div>
            </div>

            <div class="lead-event lead-event--silence">
              <div class="lead-event-time">…</div>
              <div class="lead-event-connector">
                <span class="lead-event-dot lead-event-dot--dim"></span>
                <span class="lead-event-line lead-event-line--dashed"></span>
              </div>
              <div class="lead-event-card lead-event-card--dim">
                <div class="lead-event-icon lead-event-icon--dim">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                  </svg>
                </div>
                <div class="lead-event-content">
                  <p class="lead-event-title">No response. Radio silence.</p>
                  <p class="lead-event-detail">Your firm is closed. No one picks up.</p>
                </div>
              </div>
            </div>

            <div class="lead-event lead-event--lost">
              <div class="lead-event-time">8:02 AM</div>
              <div class="lead-event-connector">
                <span class="lead-event-dot lead-event-dot--red"></span>
              </div>
              <div class="lead-event-card lead-event-card--lost">
                <div class="lead-event-icon lead-event-icon--red">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.75 3.75 0 11-6.75 0 3.75 3.75 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                  </svg>
                </div>
                <div class="lead-event-content">
                  <p class="lead-event-title lead-event-title--red">They've already called another firm.</p>
                  <p class="lead-event-detail">9+ hours later — the moment is gone.</p>
                </div>
              </div>
            </div>

          </div><!-- /lead-scenario -->

          <!-- Overnight counter -->
          <div class="overnight-counter">
            <div class="overnight-counter-label">Leads lost overnight this week</div>
            <div class="overnight-counter-number">
              <span class="counter" data-target="5" data-act="2">0</span>
            </div>
            <div class="overnight-counter-sub">and counting — every week</div>
          </div>

        </div><!-- /timeline-wrap -->

      </div>
    </div>
  </div>

  <!-- ===== ACT 3: Now imagine every lead handled ===== -->
  <div class="act act-3" id="act-3">
    <div class="act-sentinel" aria-hidden="true"></div>

    <!-- Background act number -->
    <div class="act-bg-num act-bg-num--gold" aria-hidden="true">03</div>

    <!-- Gold divider — thicker with glow -->
    <div class="gold-divider" aria-hidden="true">
      <div class="gold-divider-line"></div>
    </div>

    <div class="act-inner">
      <div class="container-wide">

        <div class="act-header">
          <div class="act-eyebrow act-eyebrow--gold">
            <span class="eyebrow-dot eyebrow-dot--gold"></span>
            The Transformation
          </div>
          <!-- Rocket/sun icon -->
          <div class="act-header-icon act-header-icon--gold" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.82m5.84-2.56a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.818m2.546-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7a18.897 18.897 0 01-4.244 0M9.632 8.41l-.118-.012M13.5 12c-.09.34-.189.67-.298.993" />
            </svg>
          </div>
          <h2 class="act-title">
            Now imagine<br />
            <span class="text-gold-glow">every lead handled.</span>
          </h2>
          <p class="act-subtitle act-subtitle--light">Attorney Assistant's 24/7 intake team means no lead ever goes unanswered.</p>
        </div>

        <!-- Transformed counter cards with shimmer -->
        <div class="counter-grid">

          <!-- Card 1: Zero missed calls -->
          <div class="counter-card counter-card--gold shimmer-card stagger-card-3" data-stagger="0">
            <div class="shimmer-overlay" aria-hidden="true"></div>
            <div class="counter-card-icon counter-card-icon--gold-fill">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="grad-check-gold" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#ffaa2b"/>
                    <stop offset="100%" stop-color="#e69500"/>
                  </linearGradient>
                </defs>
                <circle cx="12" cy="12" r="10" fill="url(#grad-check-gold)"/>
                <path d="M7 12.5l3.5 3.5 6.5-7" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="counter-card-body">
              <div class="counter-label-row">
                <svg class="inline-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="6" fill="#ffaa2b"/>
                  <path d="M5 8l2.5 2.5 4-4.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Missed calls <span class="counter-sub counter-sub--green">this month</span>
              </div>
              <div class="counter-number text-green-400">
                <span class="counter" data-target="0" data-start="99" data-act="3">99</span>
              </div>
              <div class="result-badge result-badge--green">
                <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                24/7 always answered
              </div>
            </div>
          </div>

          <!-- Card 2: 5 min intake -->
          <div class="counter-card counter-card--gold shimmer-card stagger-card-3" data-stagger="150">
            <div class="shimmer-overlay" aria-hidden="true"></div>
            <div class="counter-card-icon counter-card-icon--gold-fill">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="grad-clock-gold" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#ffaa2b"/>
                    <stop offset="100%" stop-color="#e69500"/>
                  </linearGradient>
                </defs>
                <circle cx="12" cy="12" r="10" fill="url(#grad-clock-gold)"/>
                <path d="M12 7.5v4.5H15" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="counter-card-body">
              <div class="counter-label-row">
                <svg class="inline-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="6" fill="#ffaa2b"/>
                  <path d="M8 5v3.5H10.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                Avg intake <span class="counter-sub counter-sub--green">down from 47min</span>
              </div>
              <div class="counter-number text-green-400">
                <span class="counter" data-target="5" data-start="47" data-act="3">47</span>
                <span class="counter-unit">min</span>
              </div>
              <div class="result-badge result-badge--green">
                <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                89% faster intake
              </div>
            </div>
          </div>

          <!-- Card 3: 38% conversion -->
          <div class="counter-card counter-card--gold shimmer-card stagger-card-3" data-stagger="300">
            <div class="shimmer-overlay" aria-hidden="true"></div>
            <div class="counter-card-icon counter-card-icon--gold-fill">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="grad-trend-gold" x1="0" y1="1" x2="1" y2="0">
