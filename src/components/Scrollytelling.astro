---
// No props — content is self-contained
---

<section class="st-section" aria-label="Revenue impact comparison">

  <!-- Intro label -->
  <div class="st-intro">
    <div class="container-wide">
      <div class="st-intro-inner">
        <span class="st-intro-label">The Cost of Doing Nothing</span>
        <div class="st-intro-chevron" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Single unified strip -->
  <div class="st-strip" id="st-strip">
    <div class="st-sentinel" aria-hidden="true"></div>

    <!-- Floating particles -->
    <div class="particles" aria-hidden="true">
      <span class="particle p1"></span>
      <span class="particle p2"></span>
      <span class="particle p3"></span>
      <span class="particle p4"></span>
      <span class="particle p5"></span>
      <span class="particle p6"></span>
    </div>

    <!-- Gold overlay for transformed state -->
    <div class="st-gold-overlay" aria-hidden="true"></div>

    <div class="st-inner">
      <div class="container-wide">

        <!-- Header -->
        <div class="st-header">
          <div class="st-eyebrow" id="st-eyebrow">
            <span class="st-eyebrow-dot" id="st-eyebrow-dot"></span>
            <span id="st-eyebrow-text">The Reality</span>
          </div>
          <!-- Icon: alarm (without) / sun (with) -->
          <div class="st-header-icon st-icon-alarm" id="st-icon-alarm" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
            </svg>
          </div>
          <div class="st-header-icon st-icon-sun" id="st-icon-sun" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
            </svg>
          </div>
          <h2 class="st-title">
            Your firm is
            <span class="st-title-accent" id="st-title-accent">leaking revenue.</span>
          </h2>
          <p class="st-subtitle" id="st-subtitle">Every hour you're not available, leads choose someone who is.</p>
        </div>

        <!-- Toggle -->
        <div class="st-toggle" role="group" aria-label="Compare without and with Attorney Assistant">
          <button class="st-toggle-btn st-toggle-btn--without is-active-tab" id="toggle-without" type="button" aria-pressed="true">
            <span class="st-toggle-dot st-toggle-dot--red"></span>
            Without Attorney Assistant
          </button>
          <button class="st-toggle-btn st-toggle-btn--with" id="toggle-with" type="button" aria-pressed="false">
            <span class="st-toggle-dot st-toggle-dot--gold"></span>
            With Attorney Assistant
          </button>
        </div>

        <!-- Stat cards — morph between states -->
        <div class="stat-grid">

          <!-- Card 1: Missed calls -->
          <div class="stat-card stagger-card" data-stagger="0" tabindex="0">
            <div class="stat-tooltip" role="tooltip">
              Based on ABA 2024 research — most firms miss 3–5 inbound calls per day during business hours.
            </div>
            <div class="stat-icon stat-icon--red" id="stat-icon-1">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="g-phone-red" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#ef4444"/><stop offset="100%" stop-color="#dc2626"/>
                  </linearGradient>
                  <linearGradient id="g-check-gold" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#F9A630"/><stop offset="100%" stop-color="#e69500"/>
                  </linearGradient>
                </defs>
                <path class="icon-without" fill="url(#g-phone-red)" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                <line class="icon-without" x1="15" y1="9" x2="19" y2="13" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/>
                <line class="icon-without" x1="19" y1="9" x2="15" y2="13" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/>
                <circle class="icon-with" cx="12" cy="12" r="10" fill="url(#g-check-gold)" opacity="0"/>
                <path class="icon-with" d="M7 12.5l3.5 3.5 6.5-7" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" opacity="0"/>
              </svg>
            </div>
            <div class="stat-body">
              <div class="stat-label">
                <span class="label-without">Missed calls <span class="stat-sub">today</span></span>
                <span class="label-with">Missed calls <span class="stat-sub stat-sub--green">this month</span></span>
              </div>
              <div class="stat-number" id="stat-num-1">
                <span class="counter morph-counter" data-without="3" data-with="0">0</span>
              </div>
              <div class="stat-badge badge-without">
                <span class="pulse-ring"></span>
                <span class="pulse-dot"></span>
              </div>
              <div class="stat-badge badge-with">
                <div class="result-badge">
                  <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                  24/7 always answered
                </div>
              </div>
            </div>
          </div>

          <!-- Card 2: Intake time -->
          <div class="stat-card stagger-card" data-stagger="150" tabindex="0">
            <div class="stat-tooltip" role="tooltip">
              Average law firm intake: 40–55 minutes. Attorney Assistant completes intake in under 5 minutes — 89% faster.
            </div>
            <div class="stat-icon stat-icon--orange">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="g-clock" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#fb923c"/><stop offset="100%" stop-color="#ea580c"/>
                  </linearGradient>
                </defs>
                <circle cx="12" cy="12" r="9" fill="url(#g-clock)" opacity="0.9"/>
                <path d="M12 7v5h3.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="stat-body">
              <div class="stat-label">
                <span class="label-without">Avg intake time <span class="stat-sub">per lead</span></span>
                <span class="label-with">Avg intake <span class="stat-sub stat-sub--green">down from 47min</span></span>
              </div>
              <div class="stat-number" id="stat-num-2">
                <span class="counter morph-counter" data-without="47" data-with="5">0</span>
                <span class="stat-unit">min</span>
              </div>
              <div class="stat-badge badge-without">
                <div class="stat-bar-wrap"><div class="stat-bar stat-bar--warn" style="--bar-w:78%"></div></div>
              </div>
              <div class="stat-badge badge-with">
                <div class="result-badge">
                  <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                  89% faster intake
                </div>
              </div>
            </div>
          </div>

          <!-- Card 3: Conversion rate -->
          <div class="stat-card stagger-card" data-stagger="300" tabindex="0">
            <div class="stat-tooltip" role="tooltip">
              Average firm converts 10–15% of leads. Attorney Assistant clients average 35–40% after implementing 24/7 intake.
            </div>
            <div class="stat-icon stat-icon--blue">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="g-chart" x1="0" y1="1" x2="1" y2="0">
                    <stop offset="0%" stop-color="#50a7dd"/><stop offset="100%" stop-color="#1a3a5c"/>
                  </linearGradient>
                </defs>
                <rect x="2" y="2" width="20" height="20" rx="4" fill="url(#g-chart)" opacity="0.9"/>
                <path d="M6 14l3-4 3 3 4-6" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="stat-body">
              <div class="stat-label">
                <span class="label-without">Conversion rate <span class="stat-sub">of marketing spend</span></span>
                <span class="label-with">Conversion rate <span class="stat-sub stat-sub--green">up from 12%</span></span>
              </div>
              <div class="stat-number" id="stat-num-3">
                <span class="counter morph-counter" data-without="12" data-with="38">0</span>
                <span class="stat-unit">%</span>
              </div>
              <div class="stat-badge badge-without">
                <div class="stat-bar-wrap"><div class="stat-bar stat-bar--danger" style="--bar-w:12%"></div></div>
              </div>
              <div class="stat-badge badge-with">
                <div class="stat-bar-wrap"><div class="stat-bar stat-bar--gold" style="--bar-w:38%"></div></div>
              </div>
            </div>
          </div>

        </div><!-- /stat-grid -->

        <!-- Divider -->
        <div class="st-divider" aria-hidden="true">
          <div class="st-divider-line"></div>
          <span class="st-divider-label" id="st-divider-label">What happens after 5 PM?</span>
          <div class="st-divider-line"></div>
        </div>

        <!-- Simple before/after story -->
        <div class="st-story">
          <!-- Without -->
          <div class="st-story-block st-story-block--without content-without">
            <div class="st-story-time">10:47 PM</div>
            <h3 class="st-story-headline">A lead fills out your contact form.</h3>
            <p class="st-story-body">Your firm is closed. Nobody responds. By 8 AM, they've already called another firm.</p>
            <div class="st-story-result st-story-result--red">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
              <span>Client lost. Revenue gone.</span>
            </div>
          </div>
          <!-- With -->
          <div class="st-story-block st-story-block--with content-with">
            <div class="st-story-time st-story-time--gold">10:47 PM</div>
            <h3 class="st-story-headline">A lead fills out your contact form.</h3>
            <p class="st-story-body">Attorney Assistant responds in 90 seconds. By morning, you have a consultation booked.</p>
            <div class="st-story-result st-story-result--gold">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span>New client secured.</span>
            </div>
          </div>
        </div>

        <!-- Overnight counter -->
        <div class="overnight" id="overnight">
          <div class="overnight-label content-without">Leads lost overnight this week</div>
          <div class="overnight-label overnight-label--gold content-with">Leads captured overnight this week</div>
          <div class="overnight-num">
            <span class="counter morph-counter" data-without="5" data-with="5" id="overnight-counter">0</span>
          </div>
          <div class="overnight-sub content-without">and counting — every week</div>
          <div class="overnight-sub overnight-sub--gold content-with">every one a potential client</div>
        </div>

        <!-- CTA -->
        <div class="st-cta">
          <a href="/book-call" class="btn-primary btn-lg group">
            Start Capturing Every Lead
            <svg class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>

      </div>
    </div>
  </div>

</section>

<noscript>
  <style>
    .st-strip { opacity: 1 !important; transform: none !important; }
    .stagger-card { opacity: 1 !important; transform: none !important; }
    .stat-bar { width: var(--bar-w, 50%) !important; transition: none !important; }
    .content-with { display: none !important; }
    .content-without { display: block !important; }
  </style>
</noscript>

<style>
  /* =============================================
     INTRO
  ============================================= */
  .st-section { overflow: hidden; background: #132d46; }

  .st-intro {
    background: #132d46;
    padding: 1.5rem 0 1rem;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .st-intro-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .st-intro-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #98a2b3;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 9999px;
    padding: 0.4rem 1.25rem;
  }

  .st-intro-chevron {
    color: #667085;
    animation: bounce-down 1.6s ease-in-out infinite;
  }

  .st-intro-chevron svg { width: 22px; height: 22px; }

  @keyframes bounce-down {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(6px); opacity: 1; }
  }

  /* =============================================
     STRIP (single unified section)
  ============================================= */
  .st-strip {
    background: #132d46;
    position: relative;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1),
                transform 0.8s cubic-bezier(0.16,1,0.3,1);
  }

  .st-strip::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 80% 20%, rgba(80,167,221,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 10% 80%, rgba(80,167,221,0.12) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
    transition: opacity 0.6s ease;
  }

  .st-strip.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  .st-strip.is-transformed::before { opacity: 0; }

  .st-gold-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 20% 30%, rgba(249,166,48,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 80% 70%, rgba(26,58,92,0.5) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .st-strip.is-transformed .st-gold-overlay { opacity: 1; }

  .st-sentinel {
    position: absolute;
    top: 12%;
    left: 0;
    width: 100%;
    height: 1px;
    pointer-events: none;
  }

  .st-inner {
    position: relative;
    z-index: 1;
    padding: 3rem 0;
  }

  @media (min-width: 768px) {
    .st-inner { padding: 4rem 0; }
  }

  /* =============================================
     FLOATING PARTICLES
  ============================================= */
  .particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .particle {
    position: absolute;
    border-radius: 50%;
    background: rgba(80,167,221,0.15);
    will-change: transform, opacity;
  }

  .st-strip.is-transformed .particle {
    background: rgba(249,166,48,0.12);
    transition: background 0.6s ease;
  }

  .p1 { width: 4px; height: 4px; left: 10%; top: 20%; animation: float-p 11s ease-in-out infinite 0s; }
  .p2 { width: 3px; height: 3px; left: 25%; top: 65%; animation: float-p 14s ease-in-out infinite 2s; background: rgba(80,167,221,0.1); }
  .p3 { width: 5px; height: 5px; left: 50%; top: 35%; animation: float-p 9s ease-in-out infinite 1s; }
  .p4 { width: 3px; height: 3px; left: 72%; top: 75%; animation: float-p 13s ease-in-out infinite 3s; background: rgba(249,166,48,0.15); }
  .p5 { width: 4px; height: 4px; left: 85%; top: 25%; animation: float-p 10s ease-in-out infinite 0.5s; }
  .p6 { width: 3px; height: 3px; left: 38%; top: 82%; animation: float-p 12s ease-in-out infinite 4s; background: rgba(80,167,221,0.08); }

  @keyframes float-p {
    0% { transform: translateY(0) translateX(0) scale(1); opacity: 0.4; }
    33% { transform: translateY(-30px) translateX(15px) scale(1.2); opacity: 0.8; }
    66% { transform: translateY(15px) translateX(-10px) scale(0.9); opacity: 0.3; }
    100% { transform: translateY(0) translateX(0) scale(1); opacity: 0.4; }
  }

  /* =============================================
     HEADER
  ============================================= */
  .st-header {
    text-align: center;
    margin-bottom: 1.25rem;
  }

  .st-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #7fb8d4;
    margin-bottom: 0.5rem;
    transition: color 0.4s ease;
  }

  .st-strip.is-transformed .st-eyebrow { color: #F9A630; }

  .st-eyebrow-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ef4444;
    box-shadow: 0 0 8px rgba(239,68,68,0.6);
    animation: ping-red 1.5s ease-in-out infinite;
    transition: background 0.4s ease, box-shadow 0.4s ease;
  }

  .st-strip.is-transformed .st-eyebrow-dot {
    background: #F9A630;
    box-shadow: 0 0 8px rgba(249,166,48,0.6);
    animation: pulse-gold 2s ease-in-out infinite;
  }

  @keyframes ping-red {
    0%, 100% { box-shadow: 0 0 8px rgba(239,68,68,0.6); }
    50% { box-shadow: 0 0 16px rgba(239,68,68,0.9), 0 0 24px rgba(239,68,68,0.4); }
  }

  @keyframes pulse-gold {
    0%, 100% { box-shadow: 0 0 8px rgba(249,166,48,0.6); }
    50% { box-shadow: 0 0 16px rgba(249,166,48,0.9); }
  }

  .st-header-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    margin-bottom: 0.5rem;
    transition: all 0.3s ease;
  }

  .st-header-icon svg { width: 22px; height: 22px; }

  .st-icon-alarm {
    background: rgba(239,68,68,0.12);
    border: 1px solid rgba(239,68,68,0.2);
    color: #ef4444;
    animation: alarm-shake 3s ease-in-out infinite;
  }

  .st-icon-sun {
    display: none;
    background: rgba(249,166,48,0.12);
    border: 1px solid rgba(249,166,48,0.25);
    color: #F9A630;
    animation: pulse-gold-icon 2.5s ease-in-out infinite;
  }

  .st-strip.is-transformed .st-icon-alarm { display: none; }
  .st-strip.is-transformed .st-icon-sun { display: inline-flex; }

  @keyframes alarm-shake {
    0%, 90%, 100% { transform: rotate(0deg); }
    92% { transform: rotate(-8deg); }
    96% { transform: rotate(8deg); }
    98% { transform: rotate(-4deg); }
  }

  @keyframes pulse-gold-icon {
    0%, 100% { box-shadow: 0 0 0 0 rgba(249,166,48,0.2); }
    50% { box-shadow: 0 0 0 8px rgba(249,166,48,0); }
  }

  .st-title {
    font-family: 'Sora', -apple-system, 'Segoe UI', sans-serif; font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin-bottom: 0.5rem;
  }

  .st-title-accent {
    color: #ef4444;
    text-shadow: 0 0 30px rgba(239,68,68,0.3);
    transition: color 0.4s ease, text-shadow 0.4s ease;
  }

  .st-strip.is-transformed .st-title-accent {
    color: #F9A630;
    text-shadow: 0 0 40px rgba(249,166,48,0.25);
  }

  .st-subtitle {
    font-size: 0.9375rem;
    color: #98a2b3;
    max-width: 32rem;
    margin: 0 auto;
    line-height: 1.6;
    transition: color 0.4s ease;
  }

  .st-strip.is-transformed .st-subtitle { color: #98a2b3; }

  /* =============================================
     TOGGLE
  ============================================= */
  .st-toggle {
    display: flex;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .st-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.05);
    color: #98a2b3;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
  }

  .st-toggle-btn--without {
    border-radius: 9999px 0 0 9999px;
    border-right: none;
  }

  .st-toggle-btn--with {
