  .st-strip.is-transformed .st-divider-label { color: #F9A630; }
  .st-strip.is-transformed .st-divider-line { background: rgba(249,166,48,0.15); }

  /* =============================================
     STORY BLOCK (simple before/after)
  ============================================= */
  .st-story {
    max-width: 36rem;
    margin: 0 auto 2rem;
  }

  .st-story-block {
    background: rgba(255,255,255,0.05);
