      transition: none;
    }

    .stagger-card,
    .stagger-card-3 {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .gold-divider-line {
      transform: scaleX(1);
      transition: none;
    }

    .counter-bar { transition: none; }

    .eyebrow-dot--gold,
    .eyebrow-dot--red { animation: none; }

    .act3-overnight-glow { animation: none; opacity: 0.8; }

    .pulse-ring { animation: none; }

    .particle { animation: none; }

    .st-intro-chevron { animation: none; }

    .act-header-icon--red { animation: none; }
    .act-header-icon--gold { animation: none; }

    .lead-envelope-icon { animation: none; }

    .shimmer-overlay { display: none; }

    .timeline-gap-fill { width: 100%; transition: none; }
