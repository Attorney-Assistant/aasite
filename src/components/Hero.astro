---
export interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  buttonText?: string;
  buttonLink?: string;
  secondaryButtonText?: string;
  secondaryButtonLink?: string;
  align?: "left" | "center";
  size?: "sm" | "md" | "lg";
}

const {
  title,
  subtitle,
  badge,
  buttonText,
  buttonLink,
  secondaryButtonText,
  secondaryButtonLink,
  align = "center",
  size = "md",
} = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: "py-12 md:py-16",
  md: "py-16 md:py-24",
  lg: "py-20 md:py-32",
};

const titleSizes: Record<string, string> = {
  sm: "text-display-sm md:text-display-md",
  md: "text-display-md md:text-display-lg",
  lg: "text-display-lg md:text-display-xl",
};
---

<section class={`relative bg-white overflow-hidden ${sizeClasses[size]}`}>
  <!-- Subtle mesh gradient background -->
  <div class="absolute inset-0 bg-gradient-mesh opacity-60"></div>
  <!-- Floating ambient orbs -->
  <div class="hero-orb hero-orb--1" aria-hidden="true"></div>
  <div class="hero-orb hero-orb--2" aria-hidden="true"></div>

  <div class:list={["container-wide relative", align === "center" ? "text-center" : ""]}>
    <div class:list={[align === "center" ? "max-w-3xl mx-auto" : "max-w-2xl"]}>
      {badge && (
        <div class="mb-5 reveal">
          <span class="badge badge-brand">{badge}</span>
        </div>
      )}
      <h1 class={`${titleSizes[size]} text-gray-900 reveal`}>
        {title}
      </h1>
      {subtitle && (
        <p class="mt-5 text-lg md:text-xl text-gray-500 leading-relaxed reveal" style="transition-delay: 100ms;">
          {subtitle}
        </p>
      )}
      {(buttonText || secondaryButtonText) && (
        <div class:list={["mt-8 flex flex-wrap gap-3 reveal", align === "center" ? "justify-center" : ""]} style="transition-delay: 200ms;">
          {buttonText && buttonLink && (
            <a href={buttonLink} class="btn-primary btn-lg group">
              {buttonText}
              <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
              </svg>
            </a>
          )}
          {secondaryButtonText && secondaryButtonLink && (
            <a href={secondaryButtonLink} class="btn-secondary btn-lg">{secondaryButtonText}</a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Bottom border accent -->
  <div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>
</section>

<style>
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
  }
  .hero-orb--1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(80,167,221,0.22) 0%, rgba(80,167,221,0) 70%);
    top: -20%;
    right: -8%;
    z-index: 1;
    animation: heroFloat1 10s ease-in-out infinite;
  }
  .hero-orb--2 {
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(249,166,48,0.22) 0%, rgba(249,166,48,0) 70%);
    bottom: -20%;
    left: -8%;
    z-index: 1;
    animation: heroFloat2 12s ease-in-out infinite;
  }
  @keyframes heroFloat1 {
    0% { transform: translate(0, 0) scale(1); }
    20% { transform: translate(-100px, 50px) scale(1.25); }
    40% { transform: translate(-30px, -60px) scale(0.85); }
    60% { transform: translate(80px, 25px) scale(1.15); }
    80% { transform: translate(30px, -40px) scale(0.9); }
    100% { transform: translate(0, 0) scale(1); }
  }
  @keyframes heroFloat2 {
    0% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(90px, -45px) scale(1.3); }
    50% { transform: translate(30px, 60px) scale(0.8); }
    75% { transform: translate(-60px, -20px) scale(1.15); }
    100% { transform: translate(0, 0) scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-orb { animation: none; }
  }
</style>
