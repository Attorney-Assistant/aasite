---
export interface Props {
  title: string;
  description: string;
  href?: string;
  iconColor?: string;
}

const { title, description, href, iconColor = "brand" } = Astro.props;

const iconColorClasses: Record<string, string> = {
  brand: "featured-icon-brand",
  gold: "featured-icon-gold",
  gray: "featured-icon-gray",
  navy: "featured-icon-navy",
  success: "featured-icon-success",
};
---

<div class="card card-hover p-6 flex flex-col gap-4 group">
  <div class:list={["featured-icon featured-icon-md", iconColorClasses[iconColor] || iconColorClasses.brand]}>
    <slot name="icon" />
  </div>
  <div>
    <h3 class="text-lg font-heading text-gray-900 mb-1.5">
      {href ? (
        <a href={href} class="hover:text-brand-600 transition-colors duration-200">{title}</a>
      ) : (
        title
      )}
    </h3>
    <p class="text-sm text-gray-500 leading-relaxed">{description}</p>
  </div>
  {href && (
    <a href={href} class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-700 transition-all duration-200 mt-auto group/link">
      Learn more
      <svg class="w-4 h-4 transition-transform duration-200 group-hover/link:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
      </svg>
    </a>
  )}
</div>
