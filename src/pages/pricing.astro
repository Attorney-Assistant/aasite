  { label: "Surprise invoices", detail: "Transparent pricing with no hidden fees" },
  { label: "Staffing delays", detail: "Quick matching with qualified candidates" },
  { label: "Time zone confusion", detail: "All assistants work during your business hours" },
  { label: "Untrained VAs", detail: "Every assistant is managed by legal operations experts who know your world" },
