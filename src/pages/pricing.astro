---

<BaseLayout title="Pricing" description="Affordable, scalable virtual assistant pricing built for law firms. Transparent monthly rates with volume discounts.">

  <Hero
    badge="Pricing"
    title="Affordable, Scalable Support Built for Law Firms"
    subtitle="Full-time virtual assistants managed by legal operations experts — so you don't have to."
    buttonText="Get Started"
    buttonLink="/book-call"
    size="sm"
    align="center"
  />

  <!-- Interactive Pricing Calculator -->
  <section class="py-10 md:py-14">
    <div class="container-wide">
      <div class="pricing-calc card overflow-hidden reveal" id="pricing-calculator">
        <div class="grid lg:grid-cols-5">
          <!-- Left: Controls -->
          <div class="lg:col-span-3 p-8 md:p-10">
            <span class="badge badge-brand mb-4">Build Your Team</span>
            <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mb-2">
              Pricing Calculator
            </h2>
            <p class="text-sm text-gray-500 mb-8">Select roles and quantities to estimate your monthly investment.</p>

            <div class="space-y-4" id="calc-roles">
              {roles.map((role, i) => (
                <div class="calc-role flex items-center gap-4 p-4 rounded-xl border border-gray-200 bg-white hover:border-brand-200 transition-colors" data-standard={role.standard.replace(/[$,]/g, '')} data-bilingual={role.bilingual.replace(/[$,]/g, '')} data-name={role.name}>
                  <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-brand-50 flex items-center justify-center text-brand-700">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d={role.icon} />
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <a href={role.href} class="text-sm font-semibold text-gray-900 hover:text-brand-700 transition-colors">{role.name}</a>
                    <p class="text-xs text-gray-400">from {role.standard}/mo</p>
                  </div>
                  <div class="flex items-center gap-1">
                    <select class="calc-type text-xs border border-gray-200 rounded-lg px-2 py-1.5 bg-white text-gray-600 focus:ring-2 focus:ring-brand-gold/30 focus:border-brand-gold outline-none">
                      <option value="standard">Standard</option>
                      <option value="bilingual">Bilingual</option>
                    </select>
                  </div>
                  <div class="flex items-center gap-0">
                    <button type="button" class="calc-minus w-8 h-8 rounded-l-lg border border-gray-200 bg-gray-50 text-gray-500 hover:bg-gray-100 transition-colors flex items-center justify-center text-lg font-medium" aria-label="Decrease">−</button>
                    <span class="calc-qty w-10 h-8 border-t border-b border-gray-200 bg-white flex items-center justify-center text-sm font-semibold text-gray-900">0</span>
                    <button type="button" class="calc-plus w-8 h-8 rounded-r-lg border border-gray-200 bg-gray-50 text-gray-500 hover:bg-gray-100 transition-colors flex items-center justify-center text-lg font-medium" aria-label="Increase">+</button>
                  </div>
                </div>
              ))}
            </div>

            <p class="text-xs text-gray-400 mt-6">
              We have a physical location in Belize. <a href="/book-call" class="text-brand-700 hover:text-brand-800 font-medium underline">Ask about in-office pricing.</a>
            </p>
          </div>

          <!-- Right: Summary -->
          <div class="lg:col-span-2 bg-brand-navy p-8 md:p-10 flex flex-col justify-between relative overflow-hidden">
            <div class="absolute inset-0 grain-overlay opacity-50"></div>
            <div class="absolute -top-20 -right-20 w-60 h-60 bg-brand-gold/[0.05] rounded-full blur-3xl"></div>

            <div class="relative z-10">
              <p class="text-[0.625rem] font-bold tracking-[0.15em] uppercase text-brand-gold/80 mb-6">Your Estimate</p>

              <div id="calc-summary" class="space-y-3 mb-6 min-h-[80px]">
                <p class="text-sm text-white/40 italic">Add roles to see your estimate</p>
              </div>

              <div class="border-t border-white/10 pt-4 mb-2">
                <div class="flex justify-between items-baseline" id="calc-discount-row" style="display:none">
                  <span class="text-xs text-white/50">Volume discount</span>
                  <span class="text-sm font-semibold text-green-400" id="calc-discount">-$0</span>
                </div>
              </div>
              <div class="flex justify-between items-baseline">
                <span class="text-sm text-white/60">Estimated monthly</span>
                <span class="text-display-sm font-heading text-white" id="calc-total">$0</span>
              </div>
              <p class="text-[0.625rem] text-white/30 mt-1" id="calc-annual-savings"></p>
            </div>

            <div class="relative z-10 mt-8">
              <a href="/book-call" class="btn-primary btn-lg w-full justify-center group">
                Talk to a Consultant
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
                </svg>
              </a>
              <p class="text-[0.625rem] text-white/30 text-center mt-3">No commitment required</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
  (function() {
    var discounts = [
      { min: 1, max: 1, perUnit: 0 },
      { min: 2, max: 4, perUnit: 100 },
      { min: 5, max: 9, perUnit: 125 },
      { min: 10, max: Infinity, perUnit: 150 },
    ];

    function getDiscount(totalQty) {
      if (totalQty < 1) return 0;
      for (var i = discounts.length - 1; i >= 0; i--) {
        if (totalQty >= discounts[i].min) return discounts[i].perUnit;
      }
      return 0;
    }

    function recalc() {
      var roles = document.querySelectorAll('.calc-role');
      var summaryEl = document.getElementById('calc-summary');
      var totalEl = document.getElementById('calc-total');
      var discountEl = document.getElementById('calc-discount');
      var discountRow = document.getElementById('calc-discount-row');
      var annualEl = document.getElementById('calc-annual-savings');
      var lines = [];
      var totalQty = 0;
      var subtotal = 0;

      roles.forEach(function(row) {
        var qty = parseInt(row.querySelector('.calc-qty').textContent, 10);
        if (qty < 1) return;
        var type = row.querySelector('.calc-type').value;
        var rate = parseInt(row.dataset[type], 10);
        var name = row.dataset.name;
        totalQty += qty;
        subtotal += rate * qty;
        lines.push('<div class="flex justify-between text-sm"><span class="text-white/60">' + qty + 'x ' + name + ' <span class="text-white/30">(' + type + ')</span></span><span class="text-white font-semibold">$' + (rate * qty).toLocaleString() + '</span></div>');
      });

      var discountPerUnit = getDiscount(totalQty);
      var totalDiscount = discountPerUnit * totalQty;
      var finalTotal = subtotal - totalDiscount;

      if (lines.length === 0) {
        summaryEl.innerHTML = '<p class="text-sm text-white/40 italic">Add roles to see your estimate</p>';
        totalEl.textContent = '$0';
        discountRow.style.display = 'none';
        annualEl.textContent = '';
      } else {
        summaryEl.innerHTML = lines.join('');
        totalEl.textContent = '$' + finalTotal.toLocaleString();
        if (totalDiscount > 0) {
          discountRow.style.display = 'flex';
          discountEl.textContent = '-$' + totalDiscount.toLocaleString() + '/mo';
          annualEl.textContent = 'You save $' + (totalDiscount * 12).toLocaleString() + '/year with volume pricing';
        } else {
          discountRow.style.display = 'none';
          annualEl.textContent = '';
        }
      }
    }

    document.querySelectorAll('.calc-plus').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var qtyEl = this.parentElement.querySelector('.calc-qty');
        qtyEl.textContent = parseInt(qtyEl.textContent, 10) + 1;
        recalc();
      });
    });

    document.querySelectorAll('.calc-minus').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var qtyEl = this.parentElement.querySelector('.calc-qty');
        var val = parseInt(qtyEl.textContent, 10);
        if (val > 0) qtyEl.textContent = val - 1;
        recalc();
      });
    });

    document.querySelectorAll('.calc-type').forEach(function(sel) {
      sel.addEventListener('change', recalc);
    });
  })();
  </script>

  <!-- Intake360 -->
  <section class="relative overflow-hidden grain-overlay">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-navy via-brand-900 to-brand-950"></div>
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-gold/30 to-transparent"></div>

    <div class="container-wide relative z-10 py-16 md:py-24">
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <div class="reveal">
            <div class="inline-flex items-baseline gap-1 mb-4">
              <span class="text-xl font-heading tracking-tight">
                <span class="text-brand-gold">INTAKE</span><span class="text-brand-blue">360</span>
              </span>
            </div>
            <h2 class="text-display-xs md:text-display-sm font-heading text-white mb-4">
              On-Demand Intake & Reception
            </h2>
            <div class="w-12 h-[3px] bg-gradient-to-r from-brand-gold to-brand-gold-light rounded-full mt-4 mb-6"></div>
            <p class="text-white/60 leading-relaxed mb-6">
              Don't need a full-time assistant? Intake360 is our credit-based intake and reception service.
              Pay only for what you use — no monthly minimums, no subscriptions.
            </p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-start gap-2.5 text-sm text-white/70">
                <svg class="w-4 h-4 text-brand-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                Live call answering & lead qualification
              </li>
              <li class="flex items-start gap-2.5 text-sm text-white/70">
                <svg class="w-4 h-4 text-brand-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                Outbound follow-up (up to 5 attempts per lead)
              </li>
              <li class="flex items-start gap-2.5 text-sm text-white/70">
                <svg class="w-4 h-4 text-brand-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                Warm transfers, appointment setting & contract signing
              </li>
              <li class="flex items-start gap-2.5 text-sm text-white/70">
                <svg class="w-4 h-4 text-brand-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                Credits never expire — no subscription fees
              </li>
            </ul>
            <a href="/lp/intake360" class="btn-primary btn-lg group">
              Learn About Intake360
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>

          <div class="reveal" style="transition-delay: 150ms">
            <div class="bg-white/5 border border-white/10 rounded-2xl p-8 backdrop-blur-sm">
              <div class="text-center mb-6">
                <p class="text-[0.625rem] font-bold tracking-[0.15em] uppercase text-brand-gold/80 mb-2">Starter Package</p>
                <div class="text-display-sm font-heading text-white">$3,600</div>
                <div class="flex items-center justify-center gap-3 text-sm text-white/50 mt-1">
                  <span><strong class="text-white">360</strong> Credits</span>
                  <span class="w-1 h-1 rounded-full bg-white/30"></span>
                  <span><strong class="text-white">$10</strong> / Credit</span>
                </div>
              </div>
              <div class="border-t border-white/10 pt-5">
                <p class="text-xs text-white/40 uppercase tracking-wider font-semibold mb-3">Credit Usage</p>
                <div class="space-y-2.5 text-sm">
                  <div class="flex justify-between text-white/60">
                    <span>Reception (non-intake)</span>
                    <span class="font-semibold text-white">1.0 – 1.5</span>
                  </div>
                  <div class="flex justify-between text-white/60">
                    <span>Unsuccessful Outbound</span>
                    <span class="font-semibold text-white">1.0</span>
                  </div>
                  <div class="flex justify-between text-white/60">
                    <span>Evaluation (not signed)</span>
                    <span class="font-semibold text-white">3 – 4</span>
                  </div>
                  <div class="flex justify-between text-white/60">
                    <span>Conversion (signed CFA)</span>
                    <span class="font-semibold text-white">7 – 8</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Volume Discounts (compact) -->
  <section class="py-10 md:py-14 bg-gray-25">
    <div class="container-wide">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-8 reveal">
          <span class="badge badge-brand">Scale & Save</span>
          <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
            Pay Less as You Hire More
          </h2>
          <div class="divider-gold-center mt-5"></div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 reveal" style="transition-delay: 100ms">
          {volumeDiscounts.map((d) => (
            <div class="card p-5 text-center">
              <p class="text-display-xs font-heading text-brand-navy mb-1">{d.count}</p>
              <p class="text-[0.625rem] font-bold tracking-[0.12em] uppercase text-gray-400 mb-3">Assistants</p>
              <div class="border-t border-gray-100 pt-3">
                <p class="text-lg font-heading text-brand-700">{d.monthly}</p>
                <p class="text-xs text-gray-400">off/mo each</p>
              </div>
            </div>
          ))}
        </div>

        <p class="text-xs text-gray-400 text-center mt-4 reveal">
          Discounts apply automatically. Try the calculator above to see your volume savings.
        </p>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="section-padding">
    <div class="container-wide">
      <div class="text-center mb-12 reveal">
        <span class="badge badge-brand">Every Plan</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4 mb-5">
          What's Included With Every Plan
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {included.map((item, i) => (
          <div class="card card-hover p-6 reveal" style={`transition-delay: ${i * 80}ms`}>
            <div class="featured-icon featured-icon-lg featured-icon-brand mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-heading text-gray-900 mb-2">{item.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What You Won't Get -->
  <section class="relative overflow-hidden grain-overlay">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-navy via-brand-900 to-brand-950"></div>
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-gold/30 to-transparent"></div>

    <div class="container-wide relative z-10 py-16 md:py-24">
      <div class="text-center mb-12 reveal">
        <h2 class="text-display-xs md:text-display-sm font-heading text-white mb-5">
          What You <span class="wont-strikethrough">Won't</span> Get
        </h2>
        <div class="divider-gold-center"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 max-w-6xl mx-auto">
        {wontGet.map((item, i) => (
          <div class="wont-card reveal" style={`transition-delay: ${i * 80}ms`}>
            <div class="wont-x" aria-hidden="true">
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
              </svg>
            </div>
            <p class="text-white font-semibold text-sm mb-1.5">{item.label}</p>
            <p class="text-white/40 text-xs leading-relaxed">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .wont-strikethrough {
      position: relative;
      color: #ef4444;
    }
    .wont-strikethrough::after {
      content: '';
      position: absolute;
      left: -4px;
      right: -4px;
      top: 50%;
      height: 3px;
      background: #ef4444;
      border-radius: 2px;
      transform: rotate(-3deg);
    }

    .wont-card {
      position: relative;
      padding: 1.75rem 1.25rem 1.5rem;
      border-radius: 1rem;
      border: 1px solid rgba(255,255,255,0.06);
      background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
      backdrop-filter: blur(4px);
      text-align: center;
      transition: border-color 0.3s ease, transform 0.3s ease;
    }

    .wont-card:hover {
      border-color: rgba(239,68,68,0.3);
      transform: translateY(-3px);
    }

    .wont-x {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: rgba(239,68,68,0.1);
      color: #ef4444;
      margin: 0 auto 1rem;
    }

    @media (prefers-reduced-motion: reduce) {
      .wont-card { transition: none; }
    }
  </style>

  <CTABanner
    heading="Let's Build a Package That Works for You"
    body="Every firm is different. Our Client Success Consultants will learn your needs, recommend the right roles and services, and build a custom pricing package tailored to your firm."
    buttonText="Talk to a Consultant"
    buttonLink="/book-call"
    variant="brand"
  />

</BaseLayout>
