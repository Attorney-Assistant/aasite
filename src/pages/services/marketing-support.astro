---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import FeatureCard from "@components/FeatureCard.astro";
import CTABanner from "@components/CTABanner.astro";
---

<BaseLayout title="Marketing Support" description="Dedicated marketing support specialists to help law firms execute their marketing strategies efficiently and professionally.">

  <Hero
    badge="Marketing Support"
    title="Marketing Execution, Handled"
    subtitle="Dedicated marketing support specialists to help law firms execute their marketing strategies efficiently and professionally."
    buttonText="Get Started"
    buttonLink="/contact"
    secondaryButtonText="View Capabilities"
    secondaryButtonLink="#capabilities"
    size="lg"
  />

  <!-- Core Features Grid -->
  <section class="section-padding" id="capabilities">
    <div class="container-wide">
      <div class="text-center mb-12 md:mb-16 reveal">
        <span class="badge badge-brand">Core Capabilities</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4 mb-5">Marketing Execution, Handled</h2>
        <div class="divider-gold-center mt-5"></div>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto">From content scheduling to reputation management, your marketing specialist keeps campaigns running smoothly.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        <div class="reveal" style="transition-delay: 0ms"><FeatureCard title="Content Posting & Scheduling" description="Upload and schedule social media posts, newsletters, and blogs. Keep your marketing calendar on track with consistent, timely distribution." icon="calendar" /></div>
        <div class="reveal" style="transition-delay: 100ms"><FeatureCard title="Email Campaign Coordination" description="Schedule and manage email campaigns, monitor open and click-through rates, and report results." icon="mail" /></div>
        <div class="reveal" style="transition-delay: 200ms"><FeatureCard title="CRM Management & Lead Tracking" description="Log campaign performance data, tag leads, and track engagement to keep your pipeline organized." icon="users" /></div>
        <div class="reveal" style="transition-delay: 300ms"><FeatureCard title="Event & Webinar Coordination" description="Handle logistics, scheduling, and promotion for webinars or in-person events." icon="clock" /></div>
        <div class="reveal" style="transition-delay: 400ms"><FeatureCard title="Website & Graphic Updates" description="Minor updates to pre-approved website content and templated graphics, maintaining professional brand presence." icon="globe" /></div>
        <div class="reveal" style="transition-delay: 500ms"><FeatureCard title="Reputation & Review Management" description="Request client reviews, monitor brand mentions, and flag feedback to protect your firm's reputation." icon="star" /></div>
      </div>
    </div>
  </section>

  <!-- Additional Capabilities -->
  <section class="section-padding bg-gray-25 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-mesh opacity-40"></div>
    <div class="container-wide relative">
      <div class="text-center mb-12 md:mb-16 reveal">
        <span class="badge badge-brand">Additional</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">Additional Capabilities</h2>
        <div class="divider-gold-center mt-5"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {[
          { title: "Performance Monitoring & Reporting", desc: "Track KPIs and compile summary reports to refine strategy and increase ROI." },
          { title: "Competitor & Trend Monitoring", desc: "Gather and log competitor examples or industry trends." },
        ].map((item, i) => (
          <div class="card card-hover p-6 flex items-start gap-4 reveal" style={`transition-delay: ${i * 100}ms`}>
            <div class="featured-icon featured-icon-sm featured-icon-brand flex-shrink-0">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
              </svg>
            </div>
            <div>
              <h3 class="text-base font-heading text-gray-900 mb-1">{item.title}</h3>
              <p class="text-sm text-gray-500 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Package CTA -->
  <section class="section-padding">
    <div class="container-narrow text-center">
      <div class="reveal">
        <span class="badge badge-brand">Custom Packages</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4 mb-5">
          Scale Your Firm's Marketing
        </h2>
        <div class="divider-gold-center mt-5"></div>
        <p class="text-lg text-gray-500 leading-relaxed max-w-2xl mx-auto mb-8">
          Marketing support fits right into a broader service package. We'll combine it with legal assistants, admin, or receptionist coverage to build the right team for your firm.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/book-call" class="btn-primary btn-lg group">Schedule Consultation</a>
          <a href="/services" class="btn-secondary btn-lg group">View All Services</a>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    heading="Scale Your Firm's Marketing"
    body="Marketing support fits right into a broader service package. We'll combine it with legal assistants, admin, or receptionist coverage to build the right team for your firm."
    buttonText="Schedule Consultation"
    buttonLink="/contact"
    variant="brand"
  />

</BaseLayout>
