---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import CTABanner from "@components/CTABanner.astro";
import DayTimeline from "@components/DayTimeline.astro";
---

<BaseLayout title="Services" description="Custom solutions built around the problems that cost law firms money — from lead recovery to 24/7 coverage and beyond.">

  <Hero
    badge="Our Services"
    title="We Solve the Problems That Cost Your Firm Money"
    subtitle="We build custom combinations of services tailored to your firm's unique needs — so you can focus on practicing law while we handle the rest."
    buttonText="Schedule Consultation"
    buttonLink="/contact"
    secondaryButtonText="Explore Solutions"
    secondaryButtonLink="#services"
    size="lg"
  />

  <!-- Problem Cards Grid -->
  <section class="section-padding" id="services">
    <div class="container-wide">
      <div class="text-center mb-12 md:mb-16 reveal">
        <span class="badge badge-brand">Solutions</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4 mb-5">
          What Problem Are You Trying to Solve?
        </h2>
        <div class="divider-gold-center mt-5"></div>
        <p class="text-lg text-gray-500 leading-relaxed max-w-2xl mx-auto">
          Every firm is different. Choose the problem that's costing you the most and we'll build the right solution around it.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">

        <!-- Stop Losing Leads -->
        <div class="card card-hover p-8 flex flex-col group reveal" style="transition-delay: 0ms">
          <div class="featured-icon featured-icon-md featured-icon-brand mb-5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-3">Stop Losing Leads</h3>
          <p class="text-gray-500 leading-relaxed mb-6 flex-1">
            Every missed call is revenue walking out the door. We capture and qualify every lead so nothing slips through.
          </p>
          <a href="/services/lead-recovery" class="text-brand-600 font-semibold text-sm hover:text-brand-700 transition-colors inline-flex items-center gap-1">
            Learn more <span aria-hidden="true">→</span>
          </a>
        </div>

        <!-- Fix Your Intake -->
        <div class="card card-hover p-8 flex flex-col group reveal" style="transition-delay: 100ms">
          <div class="featured-icon featured-icon-md featured-icon-brand mb-5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-3">Fix Your Intake</h3>
          <p class="text-gray-500 leading-relaxed mb-6 flex-1">
            Streamline your intake process with 24/7 coverage, bilingual support, and seamless CRM integration.
          </p>
          <a href="/services/intake-360" class="text-brand-600 font-semibold text-sm hover:text-brand-700 transition-colors inline-flex items-center gap-1">
            Learn more <span aria-hidden="true">→</span>
          </a>
        </div>

        <!-- Never Miss a Follow-Up -->
        <div class="card card-hover p-8 flex flex-col group reveal" style="transition-delay: 200ms">
          <div class="featured-icon featured-icon-md featured-icon-brand mb-5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-3">Never Miss a Follow-Up</h3>
          <p class="text-gray-500 leading-relaxed mb-6 flex-1">
            Speed wins cases. We ensure every lead gets contacted within 5 minutes, every time.
          </p>
          <a href="/services/lead-follow-up" class="text-brand-600 font-semibold text-sm hover:text-brand-700 transition-colors inline-flex items-center gap-1">
            Learn more <span aria-hidden="true">→</span>
          </a>
        </div>

        <!-- 24/7 Coverage -->
        <div class="card card-hover p-8 flex flex-col group reveal" style="transition-delay: 300ms">
          <div class="featured-icon featured-icon-md featured-icon-brand mb-5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-3">24/7 Coverage</h3>
          <p class="text-gray-500 leading-relaxed mb-6 flex-1">
            Your competitors close at 5pm. With Attorney Assistant, your firm never stops converting.
          </p>
          <a href="/services/after-hours" class="text-brand-600 font-semibold text-sm hover:text-brand-700 transition-colors inline-flex items-center gap-1">
            Learn more <span aria-hidden="true">→</span>
          </a>
        </div>

        <!-- Streamline Operations -->
        <div class="card card-hover p-8 flex flex-col group reveal" style="transition-delay: 400ms">
          <div class="featured-icon featured-icon-md featured-icon-brand mb-5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 00-1.883 2.542l.857 6a2.25 2.25 0 002.227 1.932H19.05a2.25 2.25 0 002.227-1.932l.857-6a2.25 2.25 0 00-1.883-2.542m-16.5 0V6A2.25 2.25 0 016 3.75h3.879a1.5 1.5 0 011.06.44l2.122 2.12a1.5 1.5 0 001.06.44H18A2.25 2.25 0 0120.25 9v.776" />
            </svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-3">Streamline Operations</h3>
          <p class="text-gray-500 leading-relaxed mb-6 flex-1">
            Free your team from administrative burden so they can focus on practicing law.
          </p>
          <a href="/services/admin-support" class="text-brand-600 font-semibold text-sm hover:text-brand-700 transition-colors inline-flex items-center gap-1">
            Learn more <span aria-hidden="true">→</span>
          </a>
        </div>

        <!-- Maximize Your Marketing ROI -->
        <div class="card card-hover p-8 flex flex-col group reveal" style="transition-delay: 500ms">
          <div class="featured-icon featured-icon-md featured-icon-brand mb-5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
            </svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-3">Maximize Your Marketing ROI</h3>
          <p class="text-gray-500 leading-relaxed mb-6 flex-1">
            Align your marketing spend with actual results. Stop wasting money on leads that never convert.
          </p>
          <a href="/services/marketing-support" class="text-brand-600 font-semibold text-sm hover:text-brand-700 transition-colors inline-flex items-center gap-1">
            Learn more <span aria-hidden="true">→</span>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Day Timeline -->
  <section class="section-padding bg-gray-25 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-mesh opacity-40"></div>
    <div class="container-wide relative">
      <div class="text-center mb-12 md:mb-16 reveal">
        <span class="badge badge-brand">A Day in the Life</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4 mb-5">
          See What Changes When We're In Your Corner
        </h2>
        <div class="divider-gold-center mt-5"></div>
        <p class="text-lg text-gray-500 leading-relaxed max-w-2xl mx-auto">
          Walk through a real day at a law firm — with and without our support — and see the difference it makes.
        </p>
      </div>
      <DayTimeline />
    </div>
  </section>

  <CTABanner
    heading="Let Us Build Your Custom Solution"
    body="Every firm is different. We'll learn how your practice operates and recommend the ideal combination of services to help you capture more leads, convert more clients, and scale with confidence."
    buttonText="Schedule Consultation"
    buttonLink="/contact"
    variant="brand"
  />

</BaseLayout>
