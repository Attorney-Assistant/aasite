---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import CTABanner from "@components/CTABanner.astro";
import YouTubeEmbed from "@components/YouTubeEmbed.astro";

const applyUrl = "https://docs.google.com/forms/d/e/1FAIpQLSfgVKM3FZQ3grla9pCjr-v2T5dfI6ztsu2v4z4oVGmjUN3LGg/viewform";

const perks = [
  {
    title: "Remote Environment",
    desc: "Be part of an innovative virtual team, constantly updating to the latest technologies.",
    icon: "/icons/law and legal_online law.svg",
  },
  {
    title: "Professional Growth",
    desc: "Continuous learning and professional development opportunities to advance your career.",
    icon: "/icons/buiness & finance_bullish.svg",
  },
  {
    title: "Collaborative Culture",
    desc: "Collaborate and thrive in a supportive work culture with experienced professionals.",
    icon: "/icons/buiness & finance_group.svg",
  },
  {
    title: "Competitive Pay",
    desc: "We believe in paying our employees fairly and treating people right.",
    icon: "/icons/buiness & finance_wallet.svg",
  },
];

const fitItems = [
  "Enjoy working in a fast-paced environment",
  "Have a passion for helping people achieve their goals",
  "Collaborate well with others",
  "Are goal-oriented and driven",
];

const videoIds = ["LWL_3pD5oWk", "Ood5iNtf7VY", "en3ZncZTeZQ"];
---

<BaseLayout title="Careers at Attorney Assistant" description="Join our mission to help law firms operate more efficiently. We're looking for passionate, driven people.">

  <Hero
    badge="We're Hiring"
    title="Careers at Attorney Assistant"
    subtitle="Join our mission to help law firms operate more efficiently. We're looking for passionate, driven people."
    buttonText="Apply Now"
    buttonLink={applyUrl}
  />

  <!-- Company Video + Perks — side by side -->
  <section class="py-12 md:py-16 reveal" style="transition-delay: 0.1s;">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
        <!-- Video -->
        <div>
          <span class="badge badge-brand mb-3">Who We Are</span>
          <h2 class="text-display-xs font-heading text-gray-900 mb-5">Discover What's Possible</h2>
          <YouTubeEmbed videoId="oISoqSqsHYU" title="Discover what's possible with Attorney Assistant" />
        </div>
        <!-- Perks -->
        <div>
          <span class="badge badge-brand mb-3">Benefits</span>
          <h2 class="text-display-xs font-heading text-gray-900 mb-5">Why Work With Us</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {perks.map((perk) => (
              <div class="card p-5 flex gap-4 items-start">
                <div class="featured-icon featured-icon-sm featured-icon-brand flex-shrink-0">
                  <img src={perk.icon} alt="" aria-hidden="true" class="w-5 h-5" />
                </div>
                <div>
                  <h3 class="text-sm font-heading text-gray-900 mb-1">{perk.title}</h3>
                  <p class="text-xs text-gray-500 leading-relaxed">{perk.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Great Fit + Team Testimonials -->
  <section class="py-12 md:py-16 bg-gray-50 relative overflow-hidden reveal" style="transition-delay: 0.2s;">
    <div class="absolute inset-0 bg-gradient-mesh opacity-40"></div>
    <div class="container-wide relative">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">
        <!-- Great Fit — narrower -->
        <div class="lg:col-span-2">
          <h2 class="text-display-xs font-heading text-gray-900 mb-5">
            You're A Great Fit If You...
          </h2>
          <div class="space-y-3">
            {fitItems.map((item) => (
              <div class="card flex items-center gap-3 p-4">
                <div class="featured-icon featured-icon-sm featured-icon-brand flex-shrink-0">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                    <path d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <p class="text-sm text-gray-700 font-medium">{item}</p>
              </div>
            ))}
          </div>
        </div>
        <!-- Team Testimonials — wider -->
        <div class="lg:col-span-3">
          <span class="badge badge-brand mb-3">Our Team</span>
          <h2 class="text-display-xs font-heading text-gray-900 mb-5">Hear From Our Team</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {videoIds.map((id) => (
              <YouTubeEmbed videoId={id} title="Team testimonial" />
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Apply Now -->
  <section id="apply" class="py-12 md:py-16 reveal" style="transition-delay: 0.3s;">
    <div class="container-narrow text-center">
      <div class="featured-icon featured-icon-lg featured-icon-brand mx-auto mb-4">
        <img src="/icons/buiness & finance_business bag.svg" alt="" aria-hidden="true" class="w-7 h-7" />
      </div>
      <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mb-3">
        Apply Now
      </h2>
      <div class="divider-gold-center mt-3"></div>
      <p class="text-base text-gray-500 leading-relaxed mb-6 max-w-2xl mx-auto">
        At Attorney Assistant, we are committed to providing high-quality talent to law firms.
        Join our team and make an impact in the legal industry.
      </p>
      <a href={applyUrl} target="_blank" rel="noopener noreferrer" class="btn-primary btn-lg">Apply Now</a>
    </div>
  </section>

  <CTABanner
    heading="Ready to Make an Impact?"
    body="Join the Attorney Assistant team and help transform how law firms operate."
    buttonText="Apply Now"
    buttonLink={applyUrl}
    variant="dark"
  />

</BaseLayout>
