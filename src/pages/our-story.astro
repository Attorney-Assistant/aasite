---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import CTABanner from "@components/CTABanner.astro";
import YouTubeEmbed from "@components/YouTubeEmbed.astro";

const values = [
  {
    title: "We treat people right.",
    desc: "We earn trust by delivering exceptional, reliable service.",
    icon: "M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z",
  },
  {
    title: "We solve for our clients.",
    desc: "We go the extra mile to find solutions to problems.",
    icon: "M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18",
  },
  {
    title: "We are deliberate yet innovative.",
    desc: "Delegation, documentation, duplication, and automation are keys to success.",
    icon: "M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z",
  },
  {
    title: "We thrive in diversity.",
    desc: "Our foundation is built on a diverse background.",
    icon: "M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418",
  },
  {
    title: "We deliver.",
    desc: "We are committed to delivering high-quality people and services.",
    icon: "M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941",
  },
];

const founders = [
  {
    name: "Ethen Ostroff",
    role: "CEO & Founder",
    bio: "CEO of Ethen Ostroff Law. Licensed in Pennsylvania, Ethen fights for the hurt and vulnerable. His mission: co-counsel and represent over 1 million plaintiffs and staff over 1 million people.",
    initials: "EO",
  },
  {
    name: "James DiBitetto",
    role: "COO & Co-Founder",
    bio: "Data expert with 7+ years in the pharmaceutical industry. James brings expertise in leading international teams and a passion for operational excellence.",
    initials: "JD",
  },
];
---

<BaseLayout title="Our Story" description="Built on a simple yet powerful idea: to revolutionize how law firms operate.">

  <Hero
    badge="Our Story"
    title="Our Story"
    subtitle="Built on a simple yet powerful idea: to revolutionize how law firms operate."
    size="md"
    align="center"
  />

  <!-- Founding Narrative -->
  <section class="section-padding reveal" style="transition-delay: 0.1s;">
    <div class="container-narrow">
      <div class="prose-brand max-w-none">
        <div class="text-center mb-12">
          <span class="badge badge-brand">The Founding</span>
          <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
            Where it all began
          </h2>
          <div class="divider-gold-center mt-5"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-4">
            <p class="text-base text-gray-500 leading-relaxed">
              Attorney Assistant was co-founded by Ethen Ostroff (CEO) and James DiBitetto (COO) in
              partnership with the legal digital marketing agency SMBTeam. The goal was to create a
              service that prioritizes clients' needs, ensures fair compensation, and provides
              opportunities for law firms and virtual assistants.
            </p>
            <p class="text-base text-gray-500 leading-relaxed">
              Our journey began with a deep understanding of the unique challenges law firms face.
              From managing administrative tasks to maintaining client communications, we saw that
              law firms needed specialized, reliable support.
            </p>
          </div>
          <div>
            <img
              src="/wp-content/uploads/2025/03/Untitled-design-4.png"
              alt="Attorney Assistant founders"
              class="rounded-2xl w-full h-64 object-cover shadow-xs"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Stats -->
  <section class="section-padding bg-gray-25 reveal" style="transition-delay: 0.2s;">
    <div class="container-narrow text-center">
      <span class="badge badge-brand">Our Mission</span>
      <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4 mb-6">
        Positively impact as many people as possible
      </h2>
      <div class="divider-gold-center mt-5"></div>
      <p class="text-lg text-gray-500 leading-relaxed mb-12 max-w-2xl mx-auto">
        Our mission is simple: to positively impact as many people as possible. We build custom
        combinations of services around each firm — from dedicated assistants and intake
        support to admin, marketing, and receptionist coverage — so every law firm gets exactly the
        support it needs to thrive.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-lg mx-auto">
        <div class="card card-hover p-8 text-center">
          <p class="text-display-md font-heading text-brand-700 mb-1">154+</p>
          <p class="text-sm font-medium text-gray-500">Law Firms Served</p>
        </div>
        <div class="card card-hover p-8 text-center">
          <p class="text-display-md font-heading text-brand-700 mb-1">521+</p>
          <p class="text-sm font-medium text-gray-500">Employees Globally</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section-padding reveal" style="transition-delay: 0.3s;">
    <div class="container-wide">
      <div class="text-center mb-12">
        <span class="badge badge-brand">Our Values</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
          The principles that guide us
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {values.map((value) => (
          <div class="card card-hover p-8">
            <div class="featured-icon featured-icon-md featured-icon-brand mb-5">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={value.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-heading text-gray-900 mb-2">
              {value.title}
            </h3>
            <p class="text-sm text-gray-500 leading-relaxed">
              {value.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Founders -->
  <section class="section-padding bg-gray-25 reveal" style="transition-delay: 0.4s;">
    <div class="container-wide">
      <div class="text-center mb-12">
        <span class="badge badge-brand">Leadership</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
          Meet the founders
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {founders.map((founder) => (
          <div class="card card-hover p-8 flex flex-col sm:flex-row gap-6 items-start">
            <div class="w-16 h-16 rounded-2xl bg-brand-100 flex items-center justify-center flex-shrink-0">
              <span class="text-xl font-semibold text-brand-700">{founder.initials}</span>
            </div>
            <div>
              <h3 class="text-lg font-heading text-gray-900">{founder.name}</h3>
              <p class="text-sm font-medium text-brand-600 mb-3">{founder.role}</p>
              <p class="text-sm text-gray-500 leading-relaxed">{founder.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Video -->
  <section class="section-padding reveal" style="transition-delay: 0.5s;">
    <div class="container-wide">
      <YouTubeEmbed videoId="oISoqSqsHYU" title="Attorney Assistant Story" />
    </div>
  </section>

  <CTABanner
    heading="Join Our Mission"
    body="Discover how Attorney Assistant can help your firm reach its full potential."
    buttonText="Get in Touch"
    buttonLink="/contact"
    variant="brand"
  />

</BaseLayout>
