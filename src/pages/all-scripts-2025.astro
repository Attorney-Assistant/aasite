---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import CTABanner from "@components/CTABanner.astro";

const scripts = [
  {
    title: "Premises Liability Intake Script",
    description: "Injuries on another person's property — slips, trips, or unsafe conditions.",
    pdf: "/uploads/scripts/Premises-Intake-Script-PDF.pdf",
    image: "/uploads/scripts/PremisesOnboardingScript1-.webp",
  },
  {
    title: "Bankruptcy Intake Script",
    description: "Gathering vital information from clients considering Chapter 7 or 13 bankruptcy.",
    pdf: "/uploads/scripts/Bankruptcy_Intake_Script.pdf",
    image: "/uploads/scripts/Law-Firm-Intake-Strategy-12.png",
  },
  {
    title: "Workers' Compensation Intake Script",
    description: "Workplace injury and illness claims — employment and medical info collected up front.",
    pdf: "/uploads/scripts/Worker_s_Compensation_Intake_Script.pdf",
    image: "/uploads/scripts/Law-Firm-Intake-Strategy-3.png",
  },
  {
    title: "Short-Term/Long-Term Disability Intake Script",
    description: "Clients seeking disability benefits — eligibility, documentation, and claim details.",
    pdf: "/uploads/scripts/Short_Long_Term_Disability_Intake_Script.pdf",
    image: "/uploads/scripts/Law-Firm-Intake-Strategy-4.png",
  },
  {
    title: "Personal Injury Intake Script",
    description: "Accidents, medical treatment, insurance, and liability for injury claims.",
    pdf: "/uploads/scripts/Personal_Injury_Law_scripts.pdf",
    image: "/uploads/scripts/Law-Firm-Intake-Strategy-6.png",
  },
  {
    title: "Immigration Intake Script",
    description: "Various immigration cases — visas, green cards, asylum, and more.",
    pdf: "/uploads/scripts/Immigration_Practice_Area_Scripts.pdf",
    image: "/uploads/scripts/Law-Firm-Intake-Strategy-7.png",
  },
  {
    title: "Family Law Intake Script",
    description: "Sensitive conversations around divorce, custody, child and spousal support.",
    pdf: "/uploads/scripts/1_FAMILY_LAW_-_Intake.pdf",
    image: "/uploads/scripts/Law-Firm-Intake-Strategy-8.png",
  },
  {
    title: "Estate Planning Intake Script",
    description: "Wills, trusts, powers of attorney, and healthcare directives.",
    pdf: "/uploads/scripts/Scripts-_Estate_Planning.pdf",
    image: "/uploads/scripts/Law-Firm-Intake-Strategy-5.png",
  },
  {
    title: "Employment Litigation Intake Script",
    description: "Wrongful termination, discrimination, harassment, and wage disputes.",
    pdf: "/uploads/scripts/Employee_Litigation_Intake_Scripts.pdf",
    image: "/uploads/scripts/Law-Firm-Intake-Strategy-9.png",
  },
  {
    title: "Criminal Law Intake Script",
    description: "DUI, assault, or other criminal defense consultations.",
    pdf: "/uploads/scripts/Criminal_Law_Intake_Scripts.pdf",
    image: "/uploads/scripts/Law-Firm-Intake-Strategy-10.png",
  },
  {
    title: "Consumer Law Intake Script",
    description: "Consumer protection issues such as fraud and unfair business practices.",
    pdf: "/uploads/scripts/Consumer_Law_Practice_Area_Script.pdf",
    image: "/uploads/scripts/Law-Firm-Intake-Strategy-11.png",
  },
];
---

<BaseLayout title="Free Intake Scripts for Every Practice Area" description="Download free, ready-to-use intake scripts for personal injury, family law, bankruptcy, criminal, immigration, and more. Customize for your law firm.">

  <Hero
    title="Intake Scripts"
    subtitle="Free, ready-to-use intake scripts for every practice area. Download and customize for your firm."
    badge="Free Resources"
  />

  <section class="section-padding">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {scripts.map((script) => (
          <div class="card card-hover overflow-hidden flex flex-col">
            <img
              src={script.image}
              alt={script.title}
              class="w-full h-48 object-cover"
              loading="lazy"
            />
            <div class="p-6 flex flex-col flex-1">
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                {script.title}
              </h3>
              <p class="text-sm text-gray-600 leading-relaxed mb-5 flex-1">
                {script.description}
              </p>
              <a
                href={script.pdf}
                target="_blank"
                rel="noopener"
                class="btn-primary text-sm w-full justify-center"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
                Download Script
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Elevate Your Client Intake"
    body="Download free, ready-to-use legal scripts and transform your intake process."
    buttonText="Get Started"
    buttonLink="/contact"
    variant="brand"
  />

</BaseLayout>
