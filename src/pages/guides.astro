---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import CTABanner from "@components/CTABanner.astro";

const guides = [
  {
    title: "A Cybersecurity Guide For Law Firms",
    description: "Tips for keeping your client's data safe while working with virtual assistants.",
    pdf: "/uploads/guides/AA_Safeguarding_Client_Data_A_Cybersecurity_Guide_for_Businesses_Using_Virtual_Assistants_.pdf",
    image: "/uploads/site/Container-1.png",
  },
  {
    title: "The Modern, Highly Efficient Intake Strategy",
    description: "Streamline your client intake process with this modern approach.",
    pdf: "/uploads/guides/Intake-Systems.pdf",
    image: "/uploads/site/Container-Absolute-Wrapper.png",
  },
  {
    title: "Attorney Assistant Brochure",
    description: "We place virtual, full-time legal staff exclusively for law firms.",
    pdf: "/uploads/guides/AA-Information-Brochure.pdf",
    image: "/uploads/site/Container-Absolute-Wrapper-1.png",
  },
  {
    title: "Attorney Assistant vs. Competitors",
    description: "VAs trained specifically for law firms. We handle hiring, training, and oversight.",
    pdf: "/uploads/guides/Attorney-Assistant-vs.-Competitors.pdf",
    image: "/uploads/site/Container.png",
  },
  {
    title: "Case Maximizer Method: PI Firms",
    description: "Enhancing client communication for personal injury firms.",
    pdf: "/uploads/guides/The-CASE-MAXIMIZER-METHOD.pdf",
    image: "/uploads/site/Container-Absolute-Wrapper-2.png",
  },
  {
    title: "A Lawyer's Guide To Virtual Assistants",
    description: "Why legal virtual assistants are a must for modern law firms.",
    pdf: "/uploads/guides/LawyerE28099s_Guide_to_Virtual_Assistants_Why_Legal_VAs_Are_a_Must_for_Modern_Law_Firms.pdf",
    image: "/uploads/site/Container-Absolute-Wrapper-3.png",
  },
  {
    title: "Client Intake SOP",
    description: "An efficient intake process that captures, qualifies, and converts legal leads.",
    pdf: "/uploads/guides/Client-Intake-SOP-Attorney-Assistant.pdf",
    image: "/uploads/blog/AA-LeadMagnetThumbnails-Client-Intake-SOP.webp",
  },
];
---

<BaseLayout title="Free Guides for Law Firms" description="Download free guides on cybersecurity, intake optimization, VA management, and more. Help your law firm operate smarter and grow faster.">

  <Hero
    badge="Free Downloads"
    title="Guides"
    subtitle="Access our exclusive collection of legal guides and resources to help your firm operate smarter."
  />

  <section class="section-padding reveal" style="transition-delay: 0.1s;">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {guides.map((guide) => (
          <div class="card card-hover flex flex-col overflow-hidden">
            <img
              src={guide.image}
              alt={guide.title}
              class="w-full h-48 object-cover"
              loading="lazy"
            />
            <div class="p-6 flex flex-col flex-1">
              <div class="featured-icon featured-icon-sm featured-icon-brand mb-4">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m.75 12l3 3m0 0l3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </div>
              <h3 class="text-lg font-heading text-gray-900 mb-2">
                {guide.title}
              </h3>
              <p class="text-sm text-gray-500 leading-relaxed mb-6 flex-1">
                {guide.description}
              </p>
              <a
                href={guide.pdf}
                target="_blank"
                rel="noopener"
                class="btn-primary text-sm w-full justify-center"
              >
                Download Guide
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Need Personalized Legal Assistance?"
    body="Our team is ready to help with your specific needs. Contact us today for a consultation."
    buttonText="Book a Call"
    buttonLink="/contact"
    variant="brand"
  />

</BaseLayout>
