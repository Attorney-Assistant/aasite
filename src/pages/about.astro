---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import CTABanner from "@components/CTABanner.astro";
import FeatureCard from "@components/FeatureCard.astro";
---

<BaseLayout title="About Us" description="Learn about Attorney Assistant and our mission to help law firms streamline their operations.">

  <Hero
    badge="About Us"
    title="About Attorney Assistant"
    subtitle="We solve the operational problems that prevent law firms from growing — so your team can focus on practicing law."
    size="md"
    align="center"
  />

  <!-- Mission Section -->
  <section class="section-padding reveal" style="transition-delay: 0.1s;">
    <div class="container-narrow">
      <div class="text-center mb-12">
        <span class="badge badge-brand">Our Mission</span>
      </div>
      <div class="flex flex-col items-center">
        <div class="featured-icon featured-icon-lg featured-icon-brand mb-8">
          <img src="/icons/law and legal_trust.svg" alt="" aria-hidden="true" class="w-6 h-6" />
        </div>
        <p class="text-lg text-gray-500 leading-relaxed text-center max-w-2xl">
          Attorney Assistant was founded on a simple observation: law firms don't have a lead problem — they have an operations problem.
          Missed calls, broken intake, inconsistent follow-up, and admin chaos cost firms more revenue than they realize.
          We fix those operational failures so firms can actually convert the leads they're already paying for.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="py-12 bg-brand-950 grain-overlay relative overflow-hidden">
    <div class="container-wide relative z-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-display-sm md:text-display-md font-heading text-white counter" data-target="200" data-suffix="+">0</p>
          <p class="text-xs text-brand-200 mt-1 uppercase tracking-widest">Law Firms</p>
        </div>
        <div>
          <p class="text-display-sm md:text-display-md font-heading text-white counter" data-target="60" data-suffix="%+">0</p>
          <p class="text-xs text-brand-200 mt-1 uppercase tracking-widest">Cost Savings</p>
        </div>
        <div>
          <p class="text-display-sm md:text-display-md font-heading text-white counter" data-target="24" data-suffix="/7">0</p>
          <p class="text-xs text-brand-200 mt-1 uppercase tracking-widest">Coverage</p>
        </div>
        <div>
          <p class="text-display-sm md:text-display-md font-heading text-white counter" data-target="5" data-suffix=" min">0</p>
          <p class="text-xs text-brand-200 mt-1 uppercase tracking-widest">Response Time</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="section-padding bg-gray-25 reveal" style="transition-delay: 0.2s;">
    <div class="container-wide">
      <div class="text-center mb-12">
        <span class="badge badge-brand">Our Values</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
          What drives everything we do
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="card card-hover p-8">
          <div class="featured-icon featured-icon-lg featured-icon-brand mb-5">
            <img src="/icons/law and legal_law scale.svg" alt="" aria-hidden="true" class="w-7 h-7" />
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Excellence</h3>
          <p class="text-sm text-gray-500 leading-relaxed">We hold ourselves to the highest standards in every interaction.</p>
        </div>

        <div class="card card-hover p-8">
          <div class="featured-icon featured-icon-lg featured-icon-brand mb-5">
            <img src="/icons/law and legal_shield.svg" alt="" aria-hidden="true" class="w-7 h-7" />
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Reliability</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Your clients and your deadlines depend on us. We deliver.</p>
        </div>

        <div class="card card-hover p-8">
          <div class="featured-icon featured-icon-lg featured-icon-brand mb-5">
            <img src="/icons/buiness & finance_business document.svg" alt="" aria-hidden="true" class="w-7 h-7" />
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Transparency</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Clear reporting and open communication at every step.</p>
        </div>

        <div class="card card-hover p-8">
          <div class="featured-icon featured-icon-lg featured-icon-brand mb-5">
            <img src="/icons/buiness & finance_hand shake.svg" alt="" aria-hidden="true" class="w-7 h-7" />
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Partnership</h3>
          <p class="text-sm text-gray-500 leading-relaxed">We succeed when your firm succeeds.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="section-padding reveal" style="transition-delay: 0.3s;">
    <div class="container-narrow">
      <div class="text-center mb-6">
        <span class="badge badge-brand">What We Do</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
          Custom legal support, built around your firm
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>
      <p class="text-lg text-gray-500 leading-relaxed text-center max-w-2xl mx-auto">
        We identify and fix the operational failures that cost law firms revenue — missed intake calls,
        inconsistent follow-up, admin bottlenecks, and the scaling problems that keep firms stuck.
        We don't just add headcount. We redesign how the work gets done so your firm can grow without the chaos.
      </p>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="section-padding bg-gray-25 reveal" style="transition-delay: 0.4s;">
    <div class="container-narrow">
      <div class="text-center mb-6">
        <span class="badge badge-brand">Our Approach</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
          Tailored to your firm's unique needs
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>
      <p class="text-lg text-gray-500 leading-relaxed text-center max-w-2xl mx-auto">
        Every engagement starts with diagnosing where your firm is losing revenue. We map your intake process,
        follow-up gaps, and admin workflows — then build a co-managed solution around the specific problems
        holding you back. As your firm grows, we continuously refine the approach so operations scale with you,
        not against you.
      </p>
    </div>
  </section>

  <CTABanner
    heading="Let's Work Together"
    body="Discover how Attorney Assistant can help your firm reach its full potential."
    buttonText="Get in Touch"
    buttonLink="/book-call"
    variant="brand"
  />

<script>
document.querySelectorAll('.counter').forEach(function(el) {
  var target = Number(el.dataset.target);
  var suffix = el.dataset.suffix || '';
  var observed = false;

  var observer = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting && !observed) {
      observed = true;
      var start = performance.now();
      var duration = 2000;

      function step(now) {
        var t = Math.min((now - start) / duration, 1);
        var ease = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(target * ease) + suffix;
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
      observer.disconnect();
    }
  }, { threshold: 0.3 });
  observer.observe(el);
});
</script>

</BaseLayout>
