---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import CTABanner from "@components/CTABanner.astro";
import FeatureCard from "@components/FeatureCard.astro";
---

<BaseLayout title="About Us" description="Learn about Attorney Assistant and our mission to help law firms streamline their operations.">

  <Hero
    badge="About Us"
    title="About Attorney Assistant"
    subtitle="We're on a mission to help law firms operate more efficiently, serve more clients, and achieve better outcomes."
    size="md"
    align="center"
  />

  <!-- Mission Section -->
  <section class="section-padding reveal" style="transition-delay: 0.1s;">
    <div class="container-narrow">
      <div class="text-center mb-12">
        <span class="badge badge-brand">Our Mission</span>
      </div>
      <div class="flex flex-col items-center">
        <div class="featured-icon featured-icon-lg featured-icon-brand mb-8">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
        </div>
        <p class="text-lg text-gray-500 leading-relaxed text-center max-w-2xl">
          Attorney Assistant was founded with a simple belief: law firms deserve better operational support.
          Too many firms struggle with inefficient intake processes, overwhelmed staff, and missed opportunities.
          We provide the specialized support that lets attorneys focus on what they do best — practicing law.
        </p>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="section-padding bg-gray-25 reveal" style="transition-delay: 0.2s;">
    <div class="container-wide">
      <div class="text-center mb-12">
        <span class="badge badge-brand">Our Values</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
          What drives everything we do
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="card card-hover p-8">
          <div class="featured-icon featured-icon-md featured-icon-brand mb-5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
            </svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Excellence</h3>
          <p class="text-sm text-gray-500 leading-relaxed">We hold ourselves to the highest standards in every interaction.</p>
        </div>

        <div class="card card-hover p-8">
          <div class="featured-icon featured-icon-md featured-icon-brand mb-5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Reliability</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Your clients and your deadlines depend on us. We deliver.</p>
        </div>

        <div class="card card-hover p-8">
          <div class="featured-icon featured-icon-md featured-icon-brand mb-5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Transparency</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Clear reporting and open communication at every step.</p>
        </div>

        <div class="card card-hover p-8">
          <div class="featured-icon featured-icon-md featured-icon-brand mb-5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Partnership</h3>
          <p class="text-sm text-gray-500 leading-relaxed">We succeed when your firm succeeds.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="section-padding reveal" style="transition-delay: 0.3s;">
    <div class="container-narrow">
      <div class="text-center mb-6">
        <span class="badge badge-brand">What We Do</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
          Custom legal support, built around your firm
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>
      <p class="text-lg text-gray-500 leading-relaxed text-center max-w-2xl mx-auto">
        We build custom combinations of legal support services tailored to your firm.
        From dedicated assistants who integrate with your team to per-task services like
        24/7 intake, we design the ideal mix so your firm can scale without the overhead of in-house hiring.
      </p>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="section-padding bg-gray-25 reveal" style="transition-delay: 0.4s;">
    <div class="container-narrow">
      <div class="text-center mb-6">
        <span class="badge badge-brand">Our Approach</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
          Tailored to your firm's unique needs
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>
      <p class="text-lg text-gray-500 leading-relaxed text-center max-w-2xl mx-auto">
        Every engagement starts with understanding your firm's unique needs. Our team gets to know
        your practice areas, client base, and growth goals — then recommends the ideal combination
        of services for scalability. Most of our clients benefit from a strategic mix of dedicated assistants
        and per-task services, and we continuously refine that mix as your firm evolves.
      </p>
    </div>
  </section>

  <CTABanner
    heading="Let's Work Together"
    body="Discover how Attorney Assistant can help your firm reach its full potential."
    buttonText="Get in Touch"
    buttonLink="/contact"
    variant="brand"
  />

</BaseLayout>
