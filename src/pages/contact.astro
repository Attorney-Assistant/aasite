---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
---

<BaseLayout title="Contact Us" description="Get in touch with Attorney Assistant. Schedule a consultation to learn how we can help your firm.">

  <Hero
    badge="Contact"
    title="Contact Us"
    subtitle="Ready to streamline your firm's operations? Let's talk about how Attorney Assistant can help."
    size="sm"
    align="center"
  />

  <section class="section-padding reveal" style="transition-delay: 0.1s;">
    <div class="container-wide">
      <div class="grid md:grid-cols-5 gap-12">
        <!-- Contact Form -->
        <div class="md:col-span-3">
          <h2 class="text-display-xs font-heading text-gray-900 mb-2">Send Us a Message</h2>
          <div class="divider-gold mt-5"></div>
          <p class="text-gray-500 mb-8">Fill out the form below and we'll get back to you within one business day.</p>

          <form class="space-y-6" action="#" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="firstName" class="label-base">First Name</label>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  placeholder="First name"
                  required
                  class="input-base"
                />
              </div>
              <div>
                <label for="lastName" class="label-base">Last Name</label>
                <input
                  type="text"
                  id="lastName"
                  name="lastName"
                  placeholder="Last name"
                  required
                  class="input-base"
                />
              </div>
            </div>
            <div>
              <label for="email" class="label-base">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="you@company.com"
                required
                class="input-base"
              />
            </div>
            <div>
              <label for="phone" class="label-base">Phone</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="(123) 456-7890"
                class="input-base"
              />
            </div>
            <div>
              <label for="firmName" class="label-base">Firm Name</label>
              <input
                type="text"
                id="firmName"
                name="firmName"
                placeholder="Your law firm"
                class="input-base"
              />
            </div>
            <div>
              <label for="service" class="label-base">Service Interest</label>
              <select
                id="service"
                name="service"
                class="input-base"
              >
                <option value="">Select a service...</option>
                <option value="intake-360">24/7 Intake Services</option>
                <option value="impact-assistants">Dedicated Legal Support</option>
                <option value="both">Both Services</option>
                <option value="other">Other / Not Sure</option>
              </select>
            </div>
            <div>
              <label for="message" class="label-base">Message</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                placeholder="Tell us about your firm's needs..."
                class="input-base resize-y"
              ></textarea>
            </div>
            <button type="submit" class="btn-primary btn-lg w-full sm:w-auto">
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="md:col-span-2">
          <h2 class="text-display-xs font-heading text-gray-900 mb-8">Get in Touch</h2>

          <div class="space-y-8">
            <!-- Email -->
            <div class="flex gap-4">
              <div class="featured-icon featured-icon-md featured-icon-brand flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-heading text-gray-900 mb-1">Email</h3>
                <a href="mailto:info@attorneyassistant.com" class="text-sm text-brand-600 hover:text-brand-700 transition-colors">
                  info@attorneyassistant.com
                </a>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex gap-4">
              <div class="featured-icon featured-icon-md featured-icon-brand flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-heading text-gray-900 mb-1">Phone</h3>
                <a href="tel:+1234567890" class="text-sm text-brand-600 hover:text-brand-700 transition-colors">
                  (123) 456-7890
                </a>
              </div>
            </div>

            <!-- Hours -->
            <div class="flex gap-4">
              <div class="featured-icon featured-icon-md featured-icon-brand flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-heading text-gray-900 mb-1">Hours</h3>
                <p class="text-sm text-gray-500">Our intake services operate 24/7.</p>
                <p class="text-sm text-gray-500">Business office hours: Mon-Fri, 9 AM - 6 PM EST</p>
              </div>
            </div>
          </div>

          <!-- Consultation Card -->
          <div class="card card-hover p-6 mt-8 border-brand-gold/30 bg-brand-25">
            <div class="featured-icon featured-icon-md featured-icon-brand mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
            </div>
            <h3 class="text-lg font-heading text-gray-900 mb-2">Schedule a Consultation</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-4">
              Prefer to talk directly? Schedule a free 30-minute consultation with our team.
            </p>
            <a href="#" class="btn-secondary text-sm">Book a Call</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
