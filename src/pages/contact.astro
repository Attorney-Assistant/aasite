---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import HubSpotForm from "@components/HubSpotForm.astro";
import ROICalculator from "@components/ROICalculator.astro";
---

<BaseLayout title="Contact Us" description="Get in touch with Attorney Assistant. Schedule a consultation to learn how we can help your firm.">

  <Hero
    badge="Contact"
    title="Contact Us"
    subtitle="Tell us what's not working and we'll show you how to fix it — no pitch, just a straightforward conversation about your firm's operations."
    size="sm"
    align="center"
  />

  <section class="section-padding reveal" style="transition-delay: 0.1s;">
    <div class="container-wide">
      <div class="grid md:grid-cols-5 gap-12">
        <!-- Contact Form -->
        <div class="md:col-span-3">
          <h2 class="text-display-xs font-heading text-gray-900 mb-2">Send Us a Message</h2>
          <div class="divider-gold mt-5"></div>
          <p class="text-gray-500 mb-8">Fill out the form below and we'll get back to you within one business day.</p>

          <HubSpotForm portalId="49161090" formId="78db3eac-c628-433a-840f-c0a73aab1ddf" region="na1" />
        </div>

        <!-- Contact Info -->
        <div class="md:col-span-2">
          <h2 class="text-display-xs font-heading text-gray-900 mb-8">Get in Touch</h2>

          <div class="space-y-8">
            <!-- Email -->
            <div class="flex gap-4">
              <div class="featured-icon featured-icon-md featured-icon-brand flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-heading text-gray-900 mb-1">Email</h3>
                <a href="mailto:info@attorneyassistant.com" class="text-sm text-brand-600 hover:text-brand-700 transition-colors">
                  info@attorneyassistant.com
                </a>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex gap-4">
              <div class="featured-icon featured-icon-md featured-icon-brand flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-heading text-gray-900 mb-1">Phone</h3>
                <a href="tel:+12153372677" class="text-sm text-brand-600 hover:text-brand-700 transition-colors">
                  +1 (215) 337-2677
                </a>
              </div>
            </div>

            <!-- Hours -->
            <div class="flex gap-4">
              <div class="featured-icon featured-icon-md featured-icon-brand flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-heading text-gray-900 mb-1">Hours</h3>
                <p class="text-sm text-gray-500">Our intake services operate 24/7.</p>
                <p class="text-sm text-gray-500">Business office hours: Mon-Fri, 9 AM - 6 PM EST</p>
              </div>
            </div>

            <!-- Address -->
            <div class="flex gap-4">
              <div class="featured-icon featured-icon-md featured-icon-brand flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-heading text-gray-900 mb-1">Visit Us</h3>
                <p class="text-sm text-gray-500">21 East 5th Avenue Suite 102</p>
                <p class="text-sm text-gray-500">Conshohocken, PA 19428</p>
              </div>
            </div>
          </div>

          <!-- Consultation Card -->
          <div class="card card-hover p-6 mt-8 border-brand-gold/30 bg-brand-25">
            <div class="featured-icon featured-icon-md featured-icon-brand mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
            </div>
            <h3 class="text-lg font-heading text-gray-900 mb-2">Schedule a Consultation</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-4">
              Prefer to talk directly? Schedule a free 30-minute consultation with our team.
            </p>
            <a href="/book-call" class="btn-secondary text-sm">Book a Call</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ROI Calculator -->
  <section class="section-padding bg-gray-50 relative overflow-hidden reveal" style="transition-delay: 0.2s;">
    <div class="absolute inset-0 bg-gradient-mesh opacity-40"></div>
    <div class="container-narrow relative">
      <ROICalculator />
    </div>
  </section>

</BaseLayout>
