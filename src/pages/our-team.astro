---

<BaseLayout title="Our Team" description="Behind every successful staffing company there is a dedicated team — meet ours at Attorney Assistant.">

  <Hero
    badge="Our Team"
    title="Our Team"
    subtitle="Behind every successful staffing company there is a dedicated team — meet ours at Attorney Assistant."
    size="md"
    align="center"
  />

  <!-- Leadership -->
  <section class="section-padding reveal" style="transition-delay: 0.1s;">
    <div class="container-wide">
      <div class="text-center mb-12">
        <span class="badge badge-brand">Leadership</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
          Meet the people leading the way
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>

      <div class="space-y-6 max-w-4xl mx-auto">
        {leaders.map((leader) => (
          <div class="card card-hover p-6 md:p-8 flex flex-col sm:flex-row gap-6 items-start">
            {leader.image ? (
              <img
                src={leader.image}
                alt={leader.name}
                class="w-20 h-20 rounded-2xl object-cover flex-shrink-0"
                loading="lazy"
              />
            ) : (
              <div class="w-20 h-20 rounded-2xl bg-brand-100 flex items-center justify-center flex-shrink-0">
                <span class="text-2xl font-semibold text-brand-700">
                  {leader.initials}
                </span>
              </div>
            )}
            <div>
              <div class="flex flex-wrap items-center gap-3 mb-2">
                <h3 class="text-lg font-heading text-gray-900">{leader.name}</h3>
                <span class="badge badge-brand">{leader.title}</span>
              </div>
              <p class="text-sm text-gray-500 leading-relaxed">
                {leader.bio}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Departments -->
  <section class="section-padding bg-gray-25 reveal" style="transition-delay: 0.2s;">
    <div class="container-wide">
      <div class="text-center mb-12">
        <span class="badge badge-brand">Departments</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
          Our departments
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 max-w-4xl mx-auto">
        {departments.map((dept) => (
          <div class="card card-hover p-6 text-center flex flex-col items-center gap-3">
            <div class="featured-icon featured-icon-md featured-icon-brand">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={dept.icon} />
              </svg>
            </div>
            <span class="text-sm font-heading text-gray-900">{dept.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Join Our Team"
    body="We're always looking for talented people who share our mission."
    buttonText="View Careers"
    buttonLink="/careers"
    variant="brand"
  />

</BaseLayout>
