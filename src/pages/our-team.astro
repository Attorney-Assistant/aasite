    ],
  },
];

function getInitials(name: string) {
  return name.split(" ").map(w => w[0]).join("").slice(0, 2).toUpperCase();
}

const teamSchema = leaders.map((l) => ({
  "@type": "Person",
  "name": l.name,
  "jobTitle": l.title,
  "description": l.bio,
  "image": l.image ? `https://attorneyassistant.com${l.image}` : undefined,
  "worksFor": { "@id": "https://attorneyassistant.com/#organization" },
}));
---

<BaseLayout title="Meet the Attorney Assistant Team" description="Meet the team behind Attorney Assistant — operations specialists helping law firms fix intake, follow-up, and admin so they can grow." schema={teamSchema}>

  <Hero
    badge="Our Team"
    title="Meet the people leading the way"
    subtitle="The team behind the operations infrastructure that helps law firms stop leaking revenue and start scaling."
    size="md"
    align="center"
  />

  <!-- Leadership -->
  <section class="section-padding reveal" style="transition-delay: 0.1s;">
    <div class="container-wide">
      <div class="text-center mb-12">
        <span class="badge badge-brand">Leadership</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4">
          Executive Team
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {leaders.map((leader) => (
          <div class="card card-hover text-center overflow-hidden">
            <div class="aspect-[3/4] overflow-hidden bg-gray-100">
              {leader.image ? (
                <img
                  src={leader.image}
                  alt={leader.name}
                  class="w-full h-full object-cover object-top"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full bg-brand-100 flex items-center justify-center">
                  <span class="text-4xl font-semibold text-brand-700">{leader.initials}</span>
                </div>
              )}
            </div>
            <div class="p-6">
              <h3 class="text-lg font-heading text-gray-900 mb-1">{leader.name}</h3>
              <span class="badge badge-gold text-xs mb-3">{leader.title}</span>
              <p class="text-sm text-gray-500 leading-relaxed mt-3">{leader.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Departments -->
  {departments.map((dept, di) => (
    <section class:list={["section-padding reveal", di % 2 === 0 ? "bg-gray-50" : "bg-white"]} style={`transition-delay: ${0.1 + di * 0.05}s;`}>
      <div class="container-wide">
        <div class="flex items-center gap-3 mb-10">
          <div class="featured-icon featured-icon-lg featured-icon-brand">
            <img src={dept.icon} alt="" aria-hidden="true" class="w-7 h-7" />
          </div>
          <h2 class="text-display-xs font-heading text-gray-900">{dept.name}</h2>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
          {dept.members.map((member: any) => (
            <div class="text-center group">
              <div class="w-24 h-24 mx-auto mb-3 rounded-2xl overflow-hidden border-2 border-gray-200 group-hover:border-brand-gold/50 transition-colors duration-300 bg-gray-100">
                {member.image ? (
                  <img
                    src={member.image}
                    alt={member.name}
                    class="w-full h-full object-cover object-top"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-brand-50">
                    <span class="text-lg font-semibold text-brand-700">{getInitials(member.name)}</span>
                  </div>
                )}
              </div>
              <p class="text-sm font-medium text-gray-900">{member.name}</p>
              {member.title && (
                <p class="text-xs text-gray-400 mt-0.5">{member.title}</p>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <CTABanner
    heading="Join Our Team"
    body="We're always looking for talented people who share our mission."
    buttonText="View Careers"
    buttonLink="/careers"
    variant="brand"
  />

</BaseLayout>
