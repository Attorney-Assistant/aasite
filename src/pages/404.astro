---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found | Attorney Assistant">

  <section class="relative overflow-hidden bg-brand-950 grain-overlay">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-navy via-brand-900 to-brand-950"></div>
    <div class="notfound-orb notfound-orb--1" aria-hidden="true"></div>
    <div class="notfound-orb notfound-orb--2" aria-hidden="true"></div>

    <div class="container-wide relative z-10 py-28 md:py-40 text-center">
      <div class="max-w-xl mx-auto">
        <p class="notfound-code reveal">404</p>
        <h1 class="text-display-sm md:text-display-md font-heading text-white mb-4 reveal" style="transition-delay: 100ms">
          This page doesn't exist.
        </h1>
        <p class="text-lg text-gray-400 mb-10 leading-relaxed reveal" style="transition-delay: 200ms">
          Looks like this lead went cold. Let's get you back on track.
        </p>
        <div class="flex flex-wrap gap-3 justify-center reveal" style="transition-delay: 300ms">
          <a href="/" class="btn-primary btn-lg group">
            Back to Home
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </a>
          <a href="/contact" class="btn-ghost-light btn-lg">
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .notfound-code {
    font-family: 'Sora', -apple-system, 'Segoe UI', sans-serif; font-weight: 700;
    font-size: clamp(6rem, 15vw, 10rem);
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(249,166,48,0.3) 50%, rgba(80,167,221,0.2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
  }

  .notfound-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
    z-index: 1;
  }
  .notfound-orb--1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(80,167,221,0.22) 0%, rgba(80,167,221,0) 70%);
    top: -20%;
    right: -8%;
    animation: nfFloat1 10s ease-in-out infinite;
  }
  .notfound-orb--2 {
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(249,166,48,0.22) 0%, rgba(249,166,48,0) 70%);
    bottom: -20%;
    left: -8%;
    animation: nfFloat2 12s ease-in-out infinite;
  }
  @keyframes nfFloat1 {
    0% { transform: translate(0, 0) scale(1); }
    20% { transform: translate(-100px, 50px) scale(1.25); }
    40% { transform: translate(-30px, -60px) scale(0.85); }
    60% { transform: translate(80px, 25px) scale(1.15); }
    80% { transform: translate(30px, -40px) scale(0.9); }
    100% { transform: translate(0, 0) scale(1); }
  }
  @keyframes nfFloat2 {
    0% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(90px, -45px) scale(1.3); }
    50% { transform: translate(30px, 60px) scale(0.8); }
    75% { transform: translate(-60px, -20px) scale(1.15); }
    100% { transform: translate(0, 0) scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .notfound-orb { animation: none; }
  }
</style>
