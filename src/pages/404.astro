---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page Not Found | Attorney Assistant">

  <section class="relative overflow-hidden bg-brand-950 grain-overlay min-h-[90vh] flex items-center">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-navy via-brand-900 to-brand-950"></div>
    <div class="notfound-orb notfound-orb--1" aria-hidden="true"></div>
    <div class="notfound-orb notfound-orb--2" aria-hidden="true"></div>

    <div class="container-wide relative z-10 py-20 md:py-28 text-center">
      <div class="max-w-2xl mx-auto">

        <!-- 404 -->
        <p class="notfound-code">404</p>
        <p class="text-sm text-white/60 mb-10 max-w-md mx-auto">The page you were looking for doesn't exist. Neither does your second chance with that lead.</p>

        <!-- Phone Animation -->
        <div class="phone-scene" aria-hidden="true">
          <div class="phone-pulse phone-pulse--1"></div>
          <div class="phone-pulse phone-pulse--2"></div>
          <div class="phone-icon">
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
          </div>
        </div>

        <!-- Call Status -->
        <div class="call-status" aria-live="polite">
          <span class="call-status-text" id="call-status">Incoming call...</span>
        </div>

        <!-- Main Message (hidden until animation completes) -->
        <div class="main-message" id="main-message">
          <h1 class="text-display-sm md:text-display-md lg:text-display-lg font-heading text-white mb-4">
            This is what your leads hear.
          </h1>
          <p class="text-lg md:text-xl text-gray-400 leading-relaxed mb-10 max-w-lg mx-auto">
            When calls go unanswered, potential clients move on fast.
          </p>
          <div class="flex flex-wrap gap-3 justify-center">
            <a href="/book-call" class="btn-primary btn-lg group">
              Fix Your Intake
              <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
              </svg>
            </a>
            <a href="/" class="btn-ghost-light btn-lg">
              Back to Home
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Big 404 ── */
  .notfound-code {
    font-family: 'Sora', -apple-system, 'Segoe UI', sans-serif;
    font-weight: 700;
    font-size: clamp(6rem, 15vw, 10rem);
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(249,166,48,0.3) 50%, rgba(80,167,221,0.2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  /* ── Ambient orbs ── */
  .notfound-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
    z-index: 1;
  }
  .notfound-orb--1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(80,167,221,0.18) 0%, transparent 70%);
    top: -20%; right: -8%;
    animation: nfFloat1 10s ease-in-out infinite;
  }
  .notfound-orb--2 {
    width: 450px; height: 450px;
    background: radial-gradient(circle, rgba(249,166,48,0.18) 0%, transparent 70%);
    bottom: -20%; left: -8%;
    animation: nfFloat2 12s ease-in-out infinite;
  }
  @keyframes nfFloat1 {
    0% { transform: translate(0,0) scale(1); }
    50% { transform: translate(-80px,40px) scale(1.2); }
    100% { transform: translate(0,0) scale(1); }
  }
  @keyframes nfFloat2 {
    0% { transform: translate(0,0) scale(1); }
    50% { transform: translate(70px,-35px) scale(1.2); }
    100% { transform: translate(0,0) scale(1); }
  }

  /* ── Phone scene ── */
  .phone-scene {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 120px;
    height: 120px;
    margin: 0 auto 1.5rem;
  }

  .phone-icon {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #F9A630 0%, #e8922a 100%);
    box-shadow: 0 0 40px rgba(249,166,48,0.3), 0 0 80px rgba(249,166,48,0.1);
    animation: phoneRing 0.4s ease-in-out 6 alternate;
    animation-delay: 0.5s;
  }

  /* Pulse rings */
  .phone-pulse {
    position: absolute;
    top: 50%; left: 50%;
    width: 72px; height: 72px;
    margin: -36px 0 0 -36px;
    border-radius: 50%;
    border: 2px solid rgba(249,166,48,0.4);
    z-index: 2;
    opacity: 0;
    animation: phonePulse 1.6s ease-out 3;
    animation-delay: 0.5s;
  }
  .phone-pulse--2 {
    animation-delay: 1.0s;
  }

  @keyframes phoneRing {
    0% { transform: rotate(-8deg); }
    100% { transform: rotate(8deg); }
  }

  @keyframes phonePulse {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(2.8);
      opacity: 0;
    }
  }

  /* ── Call status text ── */
  .call-status {
    margin-bottom: 2rem;
    min-height: 2rem;
  }

  .call-status-text {
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    color: rgba(249,166,48,0.7);
    transition: color 0.3s ease;
  }

  .call-status-text.ended {
    color: rgba(239,68,68,0.8);
  }

  /* ── Main message reveal ── */
  .main-message {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .main-message.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .notfound-orb { animation: none; }
    .phone-icon { animation: none; }
    .phone-pulse { animation: none; display: none; }
    .main-message { opacity: 1; transform: none; }
  }
</style>

<script>
  const statusEl = document.getElementById('call-status');
  const messageEl = document.getElementById('main-message');
  if (statusEl && messageEl) {
    const sequence = [
      { text: 'Incoming call...', delay: 0 },
      { text: 'Ringing...', delay: 1200 },
      { text: 'Ringing...', delay: 2400 },
      { text: 'Ringing...', delay: 3600 },
      { text: 'Call ended.', delay: 4800, ended: true },
    ];

    sequence.forEach(({ text, delay, ended }) => {
      setTimeout(() => {
        statusEl.textContent = text;
        if (ended) {
          statusEl.classList.add('ended');
          setTimeout(() => messageEl.classList.add('visible'), 600);
        }
      }, delay);
    });

    // Respect reduced motion — show message immediately
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      statusEl.textContent = 'Call ended.';
      statusEl.classList.add('ended');
      messageEl.classList.add('visible');
    }
  }
</script>
