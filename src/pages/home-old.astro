---
/**
 * Redirect old /home-old WordPress slug to the homepage.
 * This was the legacy 2024 home page.
 */
const destination = "/";
const canonicalUrl = "https://attorneyassistant.com/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <link rel="canonical" href={canonicalUrl} />
    <title>Redirecting — Attorney Assistant</title>
  </head>
  <body>
    <p>This page has moved. <a href={destination}>Click here</a> if you are not redirected.</p>
  </body>
</html>
