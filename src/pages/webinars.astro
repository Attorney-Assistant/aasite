---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import CTABanner from "@components/CTABanner.astro";
import YouTubeEmbed from "@components/YouTubeEmbed.astro";

const webinars = [
  {
    title: "Cybersecurity Isn't Optional | Safeguarding Client Data From Breaches",
    date: "January 2026",
    duration: "73 min",
    videoId: "3yObVdiTE8o",
    desc: "Ethen Ostroff and Gary from Black Talon discuss remote team management and cybersecurity in the legal field — protecting sensitive data while utilizing virtual legal assistants.",
  },
  {
    title: "Revolutionizing Law Firm Intakes | Boost Success with AI & Staffing",
    date: "November 2025",
    duration: "58 min",
    videoId: "QKewPdqQj8c",
    desc: "Ethen dives deep into legal intake processes — blending AI with human interaction, effective staffing strategies, and scheduling techniques to enhance conversion rates.",
  },
  {
    title: "How to Build a High-Performing Remote Team",
    date: "October 2025",
    duration: "48 min",
    videoId: "cahXK0ezkaU",
    desc: "Michelle and Ellie Thomas cover the essentials of building a thriving remote team — fostering trust, setting clear expectations, onboarding timelines, and accountability without micromanagement.",
  },
  {
    title: "Law Firm Intake Strategy",
    date: "August 2025",
    duration: "58 min",
    videoId: "Ue_O0XyM1dE",
    desc: "Ethen Ostroff covers how to enhance the profitability, efficiency, and work quality of your law firm through virtual assistants — maximizing success with VAs to help you scale.",
  },
  {
    title: "The Flawless Intake Deep Dive",
    date: "May 2024",
    duration: "120 min",
    videoId: "mmIDMcLHu7A",
    desc: "How to increase signed cases by up to 200% with a flawless intake strategy — staffing, scripts, follow-up cadences, and the operational systems behind it all.",
  },
];

const webinarSchema = webinars.map((w) => ({
  "@type": "Event",
  "name": w.title,
  "description": w.desc,
  "startDate": new Date(w.date).toISOString().split("T")[0],
  "eventStatus": "https://schema.org/EventMovedOnline",
  "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
  "organizer": { "@id": "https://attorneyassistant.com/#organization" },
  "location": { "@type": "VirtualLocation", "url": "https://attorneyassistant.com/webinars" },
  "duration": `PT${parseInt(w.duration)}M`,
  "isAccessibleForFree": true,
  "video": {
    "@type": "VideoObject",
    "name": w.title,
    "description": w.desc,
    "thumbnailUrl": `https://img.youtube.com/vi/${w.videoId}/maxresdefault.jpg`,
    "embedUrl": `https://www.youtube.com/embed/${w.videoId}`,
  },
}));
---

<BaseLayout title="Free Law Firm Webinars & Training" description="Watch recorded webinars on legal intake, remote team management, cybersecurity, and firm growth. Free on-demand training for law firm owners." schema={webinarSchema}>

  <Hero
    badge="On-Demand"
    title="Webinars"
    subtitle="Explore our library of recorded sessions and gain valuable insights from industry leaders."
  />

  <section class="section-padding reveal" style="transition-delay: 0.1s;">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900">
          Recorded Webinars
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>

      <!-- Featured (first webinar) -->
      <div class="max-w-4xl mx-auto mb-16 reveal" style="transition-delay: 0.15s;">
        <div class="card overflow-hidden">
          <YouTubeEmbed videoId={webinars[0].videoId} title={webinars[0].title} />
          <div class="p-6 md:p-8">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <span class="badge badge-brand">{webinars[0].duration}</span>
              <span class="text-sm text-gray-400">{webinars[0].date}</span>
            </div>
            <h3 class="text-xl md:text-2xl font-heading text-gray-900 mb-3">{webinars[0].title}</h3>
            <p class="text-gray-500 leading-relaxed">{webinars[0].desc}</p>
          </div>
        </div>
      </div>

      <!-- Rest of webinars -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {webinars.slice(1).map((webinar, i) => (
          <div class="card card-hover overflow-hidden flex flex-col reveal" style={`transition-delay: ${(i + 1) * 100}ms`}>
            <YouTubeEmbed videoId={webinar.videoId} title={webinar.title} />
            <div class="p-6 flex-1 flex flex-col">
              <div class="flex items-center gap-3 mb-3">
                <span class="badge badge-brand text-xs">{webinar.duration}</span>
                <span class="text-xs text-gray-400">{webinar.date}</span>
              </div>
              <h3 class="text-lg font-heading text-gray-900 leading-snug mb-2">{webinar.title}</h3>
              <p class="text-sm text-gray-500 leading-relaxed flex-1">{webinar.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Want to See It Live?"
    body="Join our next webinar to learn how to streamline your firm's operations."
    buttonText="Book a Call"
    buttonLink="/book-call"
    variant="dark"
  />

</BaseLayout>
