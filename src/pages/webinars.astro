---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import CTABanner from "@components/CTABanner.astro";

const webinars = [
  {
    title: "The Future of Legal Intake",
    date: "October 28, 2025",
    duration: "56 min",
    desc: "Learn how to capture more leads, never miss a client call, and convert inquiries into signed cases with 24/7 live answering.",
  },
  {
    title: "Mastering Remote Team Management",
    date: "September 10, 2025",
    duration: "48 min",
    desc: "Building and maintaining company culture remotely. With speakers Elley Thomas and Michelle Scherer.",
  },
  {
    title: "Intake Webinar: Cutting Costs & Boosting Conversions",
    date: "July 19, 2025",
    duration: "58 min",
    desc: "How Ethen's team signed over 4,700 cases in three years while cutting intake costs by 40% and increasing conversion rates by 15%.",
  },
  {
    title: "Safeguarding Client Data",
    date: "October 15, 2024",
    duration: "73 min",
    desc: "Cybersecurity for law firms — ransomware, email intrusion, social engineering, and third-party data exposure.",
  },
  {
    title: "The Flawless Intake Deep Dive",
    date: "May 08, 2024",
    duration: "120 min",
    desc: "How to increase signed cases by up to 200% with a flawless intake strategy.",
  },
];

const webinarSchema = webinars.map((w) => ({
  "@type": "Event",
  "name": w.title,
  "description": w.desc,
  "startDate": new Date(w.date).toISOString().split("T")[0],
  "eventStatus": "https://schema.org/EventMovedOnline",
  "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
  "organizer": { "@id": "https://attorneyassistant.com/#organization" },
  "location": { "@type": "VirtualLocation", "url": "https://attorneyassistant.com/webinars" },
  "duration": `PT${parseInt(w.duration)}M`,
  "isAccessibleForFree": true,
}));
---

<BaseLayout title="Free Law Firm Webinars & Training" description="Watch recorded webinars on legal intake, remote team management, cybersecurity, and firm growth. Free on-demand training for law firm owners." schema={webinarSchema}>

  <Hero
    badge="On-Demand"
    title="Webinars"
    subtitle="Explore our library of recorded sessions and gain valuable insights from industry leaders."
  />

  <section class="section-padding reveal" style="transition-delay: 0.1s;">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900">
          Recorded Webinars
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {webinars.map((webinar) => (
          <div class="card card-hover p-8 flex flex-col">
            <div class="flex items-center gap-3 mb-5">
              <div class="featured-icon featured-icon-sm featured-icon-brand">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </div>
              <span class="badge badge-brand">{webinar.duration}</span>
            </div>

            <h3 class="text-lg font-heading text-gray-900 mb-2">
              {webinar.title}
            </h3>

            <p class="text-sm text-gray-500 mb-3">{webinar.date}</p>

            <p class="text-base text-gray-500 leading-relaxed mb-6 flex-1">
              {webinar.desc}
            </p>

            <a
              href="/contact"
              class="inline-flex items-center gap-2 text-sm font-semibold text-brand-700 hover:text-brand-800 transition-colors group"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
              Watch Webinar
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Want to See It Live?"
    body="Join our next webinar to learn how to streamline your firm's operations."
    buttonText="Contact Us"
    buttonLink="/contact"
    variant="dark"
  />

</BaseLayout>
