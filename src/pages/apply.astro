                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Q18 -->
            <fieldset class="assessment-q card p-5">
              <legend class="label-base mb-2">18. A program stops working on your Windows PC. Which keystrokes open the Task Manager? <span class="text-error-500">*</span></legend>
              <div class="space-y-2">
                {["SHIFT + ALT + DEL", "SHIFT + ALT + ESC", "CTRL + ALT + DEL", "CTRL + ALT + ESC"].map((opt) => (
                  <label class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-50 transition-colors cursor-pointer">
                    <input type="radio" name="q18" value={opt} data-required class="form-radio text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{opt}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Q19 -->
            <fieldset class="assessment-q card p-5">
              <legend class="label-base mb-2">19. You right-click a Desktop shortcut and choose "delete". What happens? <span class="text-error-500">*</span></legend>
              <div class="space-y-2">
                {["The program will be deleted from its folder, but not uninstalled.", "The shortcut will be deleted, but you can still access the program from its folder.", "The program will be uninstalled from your PC."].map((opt) => (
                  <label class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-50 transition-colors cursor-pointer">
                    <input type="radio" name="q19" value={opt} data-required class="form-radio text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{opt}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Q20 -->
            <fieldset class="assessment-q card p-5">
              <legend class="label-base mb-2">20. Which web browsers can be used on a Windows PC? <span class="text-error-500">*</span></legend>
              <p class="text-xs text-gray-400 mb-2">There may be more than one correct option.</p>
              <div class="space-y-2">
                {["Internet Explorer", "Microsoft Edge", "Google Chrome", "Mozilla Firefox"].map((opt) => (
                  <label class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-50 transition-colors cursor-pointer">
                    <input type="checkbox" name="q20" value={opt} class="form-checkbox rounded text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{opt}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Q21 -->
            <fieldset class="assessment-q card p-5">
              <legend class="label-base mb-2">21. Your PC is in Full Screen mode. Which key reverts to regular mode? <span class="text-error-500">*</span></legend>
              <div class="space-y-2">
                {["F11", "F1", "F12", "F2"].map((opt) => (
                  <label class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-50 transition-colors cursor-pointer">
                    <input type="radio" name="q21" value={opt} data-required class="form-radio text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{opt}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Q22 -->
            <fieldset class="assessment-q card p-5">
              <legend class="label-base mb-2">22. To rename a folder on your PC, you point to the folder and: <span class="text-error-500">*</span></legend>
              <div class="space-y-2">
                {["Double-click the left mouse button", "Press CTRL + R on your keyboard", "Click the left mouse button", "Click the right mouse button"].map((opt) => (
                  <label class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-50 transition-colors cursor-pointer">
                    <input type="radio" name="q22" value={opt} data-required class="form-radio text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{opt}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Q23 -->
            <fieldset class="assessment-q card p-5">
              <legend class="label-base mb-2">23. Windows 10 is an example of: <span class="text-error-500">*</span></legend>
              <div class="space-y-2">
                {["A hard drive", "A web browser", "A type of PC", "An operating system"].map((opt) => (
                  <label class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-50 transition-colors cursor-pointer">
                    <input type="radio" name="q23" value={opt} data-required class="form-radio text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{opt}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Q24 -->
            <fieldset class="assessment-q card p-5">
              <legend class="label-base mb-2">24. You see video but hear nothing from a media file. What could be the problem? <span class="text-error-500">*</span></legend>
              <p class="text-xs text-gray-400 mb-2">There may be more than one correct option.</p>
              <div class="space-y-2">
                {["The computer audio might be muted.", "The media player's audio might be muted.", "Your computer doesn't have speakers, and you are not using earphones.", "You are using earphones, but your computer does not recognize them."].map((opt) => (
                  <label class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-50 transition-colors cursor-pointer">
                    <input type="checkbox" name="q24" value={opt} class="form-checkbox rounded text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{opt}</span>
                  </label>
                ))}
              </div>
            </fieldset>
          </div>
        </div>

        <!-- Upload note -->
        <div id="upload-note" class="hidden mt-6 card p-4 bg-brand-25 border-brand-100">
          <div class="flex gap-3 items-start">
            <svg class="w-5 h-5 text-brand-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" /></svg>
            <p class="text-xs text-brand-700 leading-relaxed"><strong>Please note:</strong> Submission may take a moment while your files (resume, ID, speed test screenshot) are uploaded. Please don't close the page until you see the confirmation message.</p>
          </div>
        </div>

        <!-- Navigation Buttons -->
        <div class="flex items-center justify-between mt-6 pt-6 border-t border-gray-200">
          <button type="button" id="prev-btn" class="btn-secondary hidden" onclick="prevStep()">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" /></svg>
            Previous
          </button>
          <div class="ml-auto flex gap-3">
            <button type="button" id="next-btn" class="btn-primary btn-lg" onclick="nextStep()">
              Continue
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </button>
            <button type="submit" id="submit-btn" class="btn-primary btn-lg hidden">
              Submit Application
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
            </button>
          </div>
        </div>

      </form>

      <!-- Success message (hidden by default) -->
      <div id="success-message" class="hidden text-center py-16">
        <div class="featured-icon featured-icon-lg featured-icon-success mx-auto mb-5">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
        </div>
        <h2 class="text-display-xs font-heading text-gray-900 mb-2">Application Submitted!</h2>
        <p class="text-base text-gray-500 max-w-md mx-auto mb-6">Thank you for your interest in joining Attorney Assistant. We'll review your application and be in touch via your preferred communication method.</p>
        <a href="/careers" class="btn-secondary">Back to Careers</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .form-step {
    display: none;
  }
  .form-step.active {
    display: block;
    animation: fadeIn 0.4s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .file-upload-area {
    position: relative;
    border: 2px dashed #D0D5DD;
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .file-upload-area:hover,
  .file-upload-area.dragover {
    border-color: #F9A630;
    background-color: #fef6e8;
  }
  .file-upload-area .file-input {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
  }
  .file-upload-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }

  /* Custom radio/checkbox styling */
  .form-radio,
  .form-checkbox {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    accent-color: #F9A630;
  }

  .field-error {
    border-color: #F04438 !important;
  }
  .field-error:focus {
    ring-color: rgba(240, 68, 56, 0.3) !important;
  }
  .error-message {
    color: #F04438;
    font-size: 0.75rem;
    margin-top: 0.25rem;
  }
</style>

<script is:inline>
  // ── TEST MODE: set to false to re-enable validation ──
  const TEST_MODE = true;

  const TOTAL_STEPS = 6;
  const STEP_NAMES = ["Personal Information", "Position & Availability", "Experience & Skills", "Technology Specifications", "Introduction Video", "Skills Assessment"];
  let currentStep = 0;
  let highestVisited = 0;

  const form = document.getElementById('application-form');
  const steps = document.querySelectorAll('.form-step');
  const progressBar = document.getElementById('progress-bar');
  const stepLabel = document.getElementById('step-label');
  const stepName = document.getElementById('step-name');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const submitBtn = document.getElementById('submit-btn');
  const stepDots = document.querySelectorAll('.step-dot');
  const dots = document.querySelectorAll('.step-dot div');

  // ── Conditional field visibility ──

  // WhatsApp number: show when WhatsApp is checked
  document.querySelectorAll('input[name="communication_method"]').forEach(cb => {
    cb.addEventListener('change', () => {
      const whatsappChecked = document.querySelector('input[name="communication_method"][value="WhatsApp"]').checked;
      const field = document.getElementById('whatsapp-field');
      field.classList.toggle('hidden', !whatsappChecked);
      if (!whatsappChecked) document.getElementById('whatsapp_number').value = '';
    });
  });

  // Belize office: show when country contains "belize"
  const countryInput = document.getElementById('country');
  countryInput.addEventListener('input', () => {
    const isBelize = countryInput.value.trim().toLowerCase().includes('belize');
    document.getElementById('belize-question').classList.toggle('hidden', !isBelize);
  });

  // Part-time hours: show when part-time = Yes or Maybe
  document.querySelectorAll('input[name="part_time"]').forEach(radio => {
    radio.addEventListener('change', () => {
      const val = document.querySelector('input[name="part_time"]:checked')?.value;
      const show = val === 'Yes' || val === 'Maybe';
      document.getElementById('part-time-hours-field').classList.toggle('hidden', !show);
      if (!show) document.getElementById('part_time_hours').value = '';
    });
  });

  // ── Step navigation ──

  function updateUI() {
    steps.forEach((step, i) => step.classList.toggle('active', i === currentStep));

    const pct = ((currentStep + 1) / TOTAL_STEPS) * 100;
    progressBar.style.width = pct + '%';
    stepLabel.textContent = `Step ${currentStep + 1} of ${TOTAL_STEPS}`;
    stepName.textContent = STEP_NAMES[currentStep];

    if (currentStep > highestVisited) highestVisited = currentStep;

    dots.forEach((dot, i) => {
      if (i < currentStep) {
        dot.className = 'w-3 h-3 rounded-full border-2 transition-all duration-300 bg-brand-gold border-brand-gold';
      } else if (i === currentStep) {
        dot.className = 'w-3 h-3 rounded-full border-2 transition-all duration-300 bg-brand-gold border-brand-gold ring-4 ring-brand-gold/20';
      } else {
        dot.className = 'w-3 h-3 rounded-full border-2 transition-all duration-300 bg-white border-gray-300';
      }
    });

    // Enable clicking on visited step dots
    stepDots.forEach((btn, i) => {
      btn.disabled = i > highestVisited;
    });

    prevBtn.classList.toggle('hidden', currentStep === 0);
    nextBtn.classList.toggle('hidden', currentStep === TOTAL_STEPS - 1);
    submitBtn.classList.toggle('hidden', currentStep !== TOTAL_STEPS - 1);
    document.getElementById('upload-note').classList.toggle('hidden', currentStep !== TOTAL_STEPS - 1);

    window.scrollTo({ top: document.querySelector('.sticky').offsetTop, behavior: 'smooth' });
  }

  // Click on step dots to navigate
  stepDots.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      if (i <= highestVisited) {
        currentStep = i;
        updateUI();
      }
    });
  });

  // ── Validation ──

  function addError(container, message) {
    if (!container.querySelector('.error-message')) {
      const msg = document.createElement('p');
      msg.className = 'error-message';
      msg.textContent = message;
      container.appendChild(msg);
    }
  }

  function validateCurrentStep() {
    if (TEST_MODE) return true;

    const step = steps[currentStep];
    let valid = true;

    // Clear previous errors
    step.querySelectorAll('.field-error').forEach(el => el.classList.remove('field-error'));
    step.querySelectorAll('.error-message').forEach(el => el.remove());
    step.querySelectorAll('.file-upload-area').forEach(el => { el.style.borderColor = ''; });

    // Validate [data-required] inputs
    const reqInputs = step.querySelectorAll('[data-required]');
    const processed = new Set();

    reqInputs.forEach(input => {
      if (input.type === 'radio') {
        if (processed.has(input.name)) return;
        processed.add(input.name);
        const group = step.querySelectorAll(`input[name="${input.name}"]`);
        if (!Array.from(group).some(r => r.checked)) {
          valid = false;
          addError(input.closest('fieldset') || input.closest('div'), 'This field is required.');
        }
      } else if (input.type === 'file') {
        if (!input.files || input.files.length === 0) {
          valid = false;
          const area = input.closest('.file-upload-area');
          area.style.borderColor = '#F04438';
          addError(area.parentElement, 'Please upload the required file.');
        }
      } else {
        if (!input.value.trim()) {
          valid = false;
          input.classList.add('field-error');
          addError(input.parentElement, 'This field is required.');
        }
      }
    });

    // Email format check
    if (currentStep === 0) {
      const emailInput = step.querySelector('#email');
      if (emailInput && emailInput.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value)) {
        valid = false;
        emailInput.classList.add('field-error');
        addError(emailInput.parentElement, 'Please enter a valid email address.');
      }
    }

    // Checkbox group minimums (require at least one checked)
    const checkboxGroups = {
      0: ['communication_method', 'languages'],
      1: ['positions', 'shifts'],
      2: ['experience_areas', 'tools'],
    };

    const groups = checkboxGroups[currentStep] || [];
    groups.forEach(name => {
      const checked = step.querySelectorAll(`input[name="${name}"]:checked`);
      if (checked.length === 0) {
        valid = false;
        const fieldset = step.querySelector(`input[name="${name}"]`).closest('fieldset');
        addError(fieldset, 'Please select at least one option.');
      }
    });

    if (!valid) {
      const firstError = step.querySelector('.field-error, .error-message');
      if (firstError) firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    return valid;
  }

  function nextStep() {
    if (!validateCurrentStep()) return;
    if (currentStep < TOTAL_STEPS - 1) {
      currentStep++;
      updateUI();
    }
  }

  function prevStep() {
    if (currentStep > 0) {
      currentStep--;
      updateUI();
    }
  }

  // ── File uploads ──

  document.querySelectorAll('.file-input').forEach(input => {
    input.addEventListener('change', function() {
      const area = this.closest('.file-upload-area');
      const filenameEl = area.parentElement.querySelector('[id$="-filename"]');
      if (this.files.length > 0) {
        const file = this.files[0];
        const sizeMB = (file.size / 1024 / 1024).toFixed(1);
        area.style.borderColor = '#17B26A';
        area.style.backgroundColor = '#F6FEF9';
        if (filenameEl) {
          filenameEl.textContent = `✓ ${file.name} (${sizeMB} MB)`;
          filenameEl.classList.remove('hidden');
        }
      }
    });
  });

  document.querySelectorAll('.file-upload-area').forEach(area => {
    area.addEventListener('dragover', (e) => { e.preventDefault(); area.classList.add('dragover'); });
    area.addEventListener('dragleave', () => area.classList.remove('dragover'));
    area.addEventListener('drop', () => area.classList.remove('dragover'));
  });

  // ── Submission ──

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    if (!TEST_MODE && !validateCurrentStep()) return;

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Uploading &amp; submitting&hellip;';
    document.getElementById('upload-note').innerHTML = '<div class="flex gap-3 items-start"><svg class="w-5 h-5 text-brand-gold flex-shrink-0 mt-0.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg><p class="text-xs text-brand-700 leading-relaxed"><strong>Uploading your files&hellip;</strong> This may take a minute depending on file sizes and your internet speed. Please don\'t close or refresh this page.</p></div>';

    try {
      const formData = new FormData(form);

      // Remove empty file fields — Formspree rejects empty file parts
      for (const [key, value] of [...formData.entries()]) {
        if (value instanceof File && value.size === 0) {
          formData.delete(key);
        }
      }

      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
      });

      const data = await response.json().catch(() => ({}));

      if (response.ok) {
        form.classList.add('hidden');
        document.querySelector('.sticky').classList.add('hidden');
        document.getElementById('success-message').classList.remove('hidden');
        window.scrollTo({ top: 0, behavior: 'smooth' });
        if (typeof fbq !== 'undefined') fbq('track', 'Lead');
        if (typeof mixpanel !== 'undefined') mixpanel.track('Job Application Submitted');
      } else {
        console.error('Formspree error:', response.status, data);
        throw new Error(data.error || data.errors?.map(e => e.message).join(', ') || `Server responded with ${response.status}`);
      }
    } catch (err) {
      console.error('Submission error:', err);
      submitBtn.disabled = false;
      submitBtn.innerHTML = 'Submit Application <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>';
      alert('Error: ' + err.message + '\n\nPlease try again or email nicolehall@attorneyassistant.com directly.');
    }
  });

  // ── Keyboard: Enter to advance ──
  form.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA') {
      e.preventDefault();
      if (currentStep < TOTAL_STEPS - 1) nextStep();
    }
  });

  // ── Selected state styling for checkbox/radio cards ──
  form.addEventListener('change', (e) => {
    const input = e.target;
    if ((input.type === 'checkbox' || input.type === 'radio') && input.closest('.rounded-lg.border')) {
      // For radios, clear siblings first
      if (input.type === 'radio') {
        const group = form.querySelectorAll(`input[name="${input.name}"]`);
        group.forEach(r => {
          const card = r.closest('.rounded-lg.border');
          if (card) {
            card.classList.remove('border-brand-400', 'bg-brand-25');
            card.classList.add('border-gray-200');
          }
        });
      }
      const card = input.closest('.rounded-lg.border');
      if (card) {
        if (input.checked) {
          card.classList.remove('border-gray-200');
          card.classList.add('border-brand-400', 'bg-brand-25');
        } else {
          card.classList.remove('border-brand-400', 'bg-brand-25');
          card.classList.add('border-gray-200');
        }
      }
    }
  });

  // ── Inline field validation on blur/change ──

  function clearFieldError(input) {
    input.classList.remove('field-error');
    const errMsg = input.parentElement?.querySelector('.error-message');
    if (errMsg) errMsg.remove();
    // Clear file upload error styling
    const area = input.closest?.('.file-upload-area');
    if (area) area.style.borderColor = '';
  }

  function showFieldError(input, message) {
    input.classList.add('field-error');
    const container = input.parentElement;
    if (container && !container.querySelector('.error-message')) {
      const msg = document.createElement('p');
      msg.className = 'error-message';
      msg.textContent = message;
      container.appendChild(msg);
    }
  }

  // Validate text/email/url/date/tel on blur
  form.addEventListener('focusout', (e) => {
    if (TEST_MODE) return;
    const input = e.target;
    if (!input.matches('input, textarea')) return;
    if (input.type === 'radio' || input.type === 'checkbox' || input.type === 'file') return;

    clearFieldError(input);

    // Required check
    if (input.hasAttribute('data-required') && !input.value.trim()) {
      showFieldError(input, 'This field is required.');
      return;
    }

    if (!input.value.trim()) return;

    // Email format
    if (input.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
      showFieldError(input, 'Please enter a valid email address.');
      return;
    }

    // URL format
    if (input.type === 'url') {
      try { new URL(input.value); } catch {
        showFieldError(input, 'Please enter a valid URL (e.g. https://...)');
        return;
      }
    }

    // Phone format (WhatsApp)
    if (input.id === 'whatsapp_number' && input.value && !/^\+?\d[\d\s-]{7,}$/.test(input.value.trim())) {
      showFieldError(input, 'Please enter a valid phone number with country code (e.g. +16101234567).');
      return;
    }

    // Zip code — basic check
    if (input.id === 'zip_code' && input.value && input.value.trim().length < 3) {
      showFieldError(input, 'Please enter a valid zip/postal code.');
      return;
    }
  });

  // Clear errors on input (while typing)
  form.addEventListener('input', (e) => {
    const input = e.target;
    if (input.classList.contains('field-error')) {
      clearFieldError(input);
    }
  });

  // Clear checkbox group errors on change
  form.addEventListener('change', (e) => {
    const input = e.target;
    if (input.type === 'checkbox' || input.type === 'radio') {
      const fieldset = input.closest('fieldset');
      if (fieldset) {
        const errMsg = fieldset.querySelector('.error-message');
        if (errMsg) errMsg.remove();
      }
    }
  });

  updateUI();
</script>
