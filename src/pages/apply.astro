---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="Apply Now — Attorney Assistant"
  description="Apply for a position with Attorney Assistant. Fill out our interview form to start your career in the legal industry."
>

  <!-- Hero -->
  <section class="relative bg-brand-900 py-12 md:py-16 grain-overlay overflow-hidden">
    <div class="absolute inset-0 bg-gradient-mesh opacity-30"></div>
    <div class="container-narrow relative z-10 text-center">
      <span class="badge badge-gold mb-4">We're Hiring</span>
      <h1 class="text-display-sm md:text-display-md font-heading text-white mb-3">
        Interview Application
      </h1>
      <p class="text-base md:text-lg text-brand-200 max-w-2xl mx-auto leading-relaxed">
        Thank you for your interest in a role with our company. Please fill out this form to continue with the interview process.
      </p>
    </div>
  </section>

  <!-- Progress Bar -->
  <div class="sticky top-0 z-40 bg-white border-b border-gray-200 shadow-xs">
    <div class="container-narrow py-3">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-gray-500" id="step-label">Step 1 of 6</span>
        <span class="text-xs font-medium text-brand-gold" id="step-name">Personal Information</span>
      </div>
      <div class="w-full bg-gray-100 rounded-full h-2 overflow-hidden">
        <div id="progress-bar" class="h-full bg-brand-gold rounded-full transition-all duration-500 ease-out" style="width: 16.67%"></div>
      </div>
      <div class="flex justify-between mt-2">
        {["Personal Info", "Position", "Experience", "Tech Specs", "Video", "Assessment"].map((name, i) => (
          <button
            type="button"
            class="step-dot flex flex-col items-center gap-1 group"
            data-step-nav={i}
            disabled
          >
            <div class={`w-3 h-3 rounded-full border-2 transition-all duration-300 ${i === 0 ? 'bg-brand-gold border-brand-gold' : 'bg-white border-gray-300'}`}></div>
            <span class="text-[10px] text-gray-400 hidden sm:block group-disabled:text-gray-300">{name}</span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Form -->
  <section class="py-10 md:py-14">
    <div class="container-narrow max-w-3xl">
      <form
        id="application-form"
        method="POST"
        action="https://formspree.io/f/mbdpakyp"
        enctype="multipart/form-data"
      >

        <!-- ============ STEP 1: Personal Information ============ -->
        <div class="form-step active" data-step="0">
          <div class="mb-8">
            <div class="featured-icon featured-icon-md featured-icon-brand mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg>
            </div>
            <h2 class="text-display-xs font-heading text-gray-900 mb-1">Personal Information</h2>
            <p class="text-sm text-gray-500">Let's start with your basic information.</p>
          </div>

          <div class="space-y-5">
            <div>
              <label for="full_name" class="label-base">Full Name <span class="text-error-500">*</span></label>
              <input type="text" id="full_name" name="full_name" data-required class="input-base" placeholder="Your full name" />
            </div>

            <div>
              <label for="date_of_birth" class="label-base">Date of Birth <span class="text-error-500">*</span></label>
              <input type="date" id="date_of_birth" name="date_of_birth" data-required class="input-base" />
            </div>

            <div>
              <label for="email" class="label-base">Email Address <span class="text-error-500">*</span></label>
              <input type="email" id="email" name="email" data-required class="input-base" placeholder="you@example.com" />
            </div>

            <div>
              <label for="street_address" class="label-base">Street Address <span class="text-error-500">*</span></label>
              <input type="text" id="street_address" name="street_address" data-required class="input-base" placeholder="123 Main Street" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="city" class="label-base">City <span class="text-error-500">*</span></label>
                <input type="text" id="city" name="city" data-required class="input-base" placeholder="City" />
              </div>
              <div>
                <label for="zip_code" class="label-base">Zip/Postal Code <span class="text-error-500">*</span></label>
                <input type="text" id="zip_code" name="zip_code" data-required class="input-base" placeholder="12345" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="state" class="label-base">State/Province <span class="text-error-500">*</span></label>
                <input type="text" id="state" name="state" data-required class="input-base" placeholder="State" />
              </div>
              <div>
                <label for="country" class="label-base">Country <span class="text-error-500">*</span></label>
                <input type="text" id="country" name="country" data-required class="input-base" placeholder="Country" />
              </div>
            </div>

            <div id="belize-question" class="card p-5 bg-brand-25 border-brand-100 hidden transition-all duration-300">
              <label class="label-base text-brand-700">For candidates from Belize only: Are you interested in working at our San Ignacio, Belize office location at #3 Moriah Street, San Ignacio Town, Cayo District (in front of Codd's Drug Store)?</label>
              <div class="flex gap-6 mt-2">
                <label class="inline-flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="belize_office" value="Yes" class="form-radio text-brand-gold focus:ring-brand-gold" />
                  <span class="text-sm text-gray-700">Yes</span>
                </label>
                <label class="inline-flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="belize_office" value="No" class="form-radio text-brand-gold focus:ring-brand-gold" />
                  <span class="text-sm text-gray-700">No</span>
                </label>
              </div>
            </div>

            <div>
              <label for="referral" class="label-base">Were you referred by an existing Attorney Assistant employee? If yes, please put their name below.</label>
              <input type="text" id="referral" name="referral" class="input-base" placeholder="Employee name (if applicable)" />
            </div>

            <fieldset>
              <legend class="label-base">Preferred Communication Method <span class="text-error-500">*</span></legend>
              <p class="text-xs text-gray-400 mb-2">Please ensure you actively monitor this. Select all that apply.</p>
              <div class="flex gap-6">
                <label class="inline-flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="communication_method" value="Email" class="form-checkbox rounded text-brand-gold focus:ring-brand-gold" />
                  <span class="text-sm text-gray-700">Email</span>
                </label>
                <label class="inline-flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="communication_method" value="WhatsApp" class="form-checkbox rounded text-brand-gold focus:ring-brand-gold" />
                  <span class="text-sm text-gray-700">WhatsApp</span>
                </label>
              </div>
            </fieldset>

            <div id="whatsapp-field" class="hidden transition-all duration-300">
              <label for="whatsapp_number" class="label-base">WhatsApp Number</label>
              <p class="text-xs text-gray-400 mb-1.5">Provide your number with area code (e.g. +16101234567)</p>
              <input type="tel" id="whatsapp_number" name="whatsapp_number" class="input-base" placeholder="+16101234567" />
            </div>

            <fieldset>
              <legend class="label-base">Languages You Are Fluent In <span class="text-error-500">*</span></legend>
              <p class="text-xs text-gray-400 mb-2">Select all that apply.</p>
              <div class="flex flex-wrap gap-4">
                <label class="inline-flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="languages" value="English" class="form-checkbox rounded text-brand-gold focus:ring-brand-gold" />
                  <span class="text-sm text-gray-700">English</span>
                </label>
                <label class="inline-flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="languages" value="Spanish" class="form-checkbox rounded text-brand-gold focus:ring-brand-gold" />
                  <span class="text-sm text-gray-700">Spanish</span>
                </label>
                <label class="inline-flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="languages" value="Other" class="form-checkbox rounded text-brand-gold focus:ring-brand-gold" />
                  <span class="text-sm text-gray-700">Other</span>
                </label>
              </div>
            </fieldset>
          </div>
        </div>

        <!-- ============ STEP 2: Position & Availability ============ -->
        <div class="form-step" data-step="1">
          <div class="mb-8">
            <div class="featured-icon featured-icon-md featured-icon-brand mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>
            </div>
            <h2 class="text-display-xs font-heading text-gray-900 mb-1">Position & Availability</h2>
            <p class="text-sm text-gray-500">Select the role(s) you're interested in and your availability.</p>
          </div>

          <!-- Position descriptions -->
          <div class="card p-5 mb-6 bg-gray-25">
            <h3 class="text-sm font-heading text-gray-900 mb-3">We offer the following positions:</h3>
            <div class="space-y-3 text-xs text-gray-600 leading-relaxed">
              <div><strong class="text-gray-800">1. General Legal Impact Assistant (IA):</strong> Assist attorneys and other legal professionals with administrative support including document management, organizing case materials, handling basic client inquiries via email and phone, data entry, drafting letters, gathering important documentation, basic research, and other clerical tasks.</div>
              <div><strong class="text-gray-800">2. Receptionist:</strong> Answer incoming calls, assist clients with their inquiries, route calls as necessary, and maintain thorough documentation of client interactions. Create a positive first impression for law firm clients by delivering exceptional customer service, empathy, patience, and professionalism.</div>
              <div><strong class="text-gray-800">3. Intake Specialist:</strong> Work in a critical role as the first point of contact for potential clients responsible for handling client inquiries, gathering essential information, and qualifying potential cases for eligibility. Conduct detailed intake interviews to gather relevant client information in the CRM or case management software, schedule appointments, and follow up on leads.</div>
              <div><strong class="text-gray-800">4. Intake Specialist-Closer:</strong> Work as an Intake Specialist (described above), but MOST IMPORTANTLY convert and close leads, sign clients up for services, and onboard them into the law firm system. Sales experience and a genuine interest in sales are paramount in this role.</div>
              <div><strong class="text-gray-800">5. Medical Records Retrieval:</strong> Request and retrieve medical records and bills from healthcare providers, hospitals, and insurance companies; track, monitor, and follow up on pending requests to ensure timely delivery of documents; maintain an organized database of records. Organization, attention to detail, and effective communication are the keys to success in this role.</div>
            </div>
          </div>

          <div class="space-y-5">
            <fieldset>
              <legend class="label-base">Position(s) You're Applying For <span class="text-error-500">*</span></legend>
              <p class="text-xs text-gray-400 mb-2">Check all that apply.</p>
              <div class="space-y-2">
                {["General Legal Impact Assistant (IA)", "Receptionist", "Intake Specialist", "Intake Specialist-Closer", "Medical Records Retrieval"].map((pos) => (
                  <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:border-brand-300 hover:bg-brand-25 transition-colors cursor-pointer">
                    <input type="checkbox" name="positions" value={pos} class="form-checkbox rounded text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{pos}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <fieldset>
              <legend class="label-base">Are you available to work full-time (at least 40 hours per week)? <span class="text-error-500">*</span></legend>
              <div class="flex gap-6 mt-1">
                <label class="inline-flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="full_time" value="Yes" data-required class="form-radio text-brand-gold focus:ring-brand-gold" />
                  <span class="text-sm text-gray-700">Yes</span>
                </label>
                <label class="inline-flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="full_time" value="No" class="form-radio text-brand-gold focus:ring-brand-gold" />
                  <span class="text-sm text-gray-700">No</span>
                </label>
              </div>
            </fieldset>

            <fieldset>
              <legend class="label-base">Which shifts would you be willing and able to work? <span class="text-error-500">*</span></legend>
              <p class="text-xs text-gray-400 mb-2">During standard US time zones. Select all that apply.</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {["Weekday Business Hours", "Weekday Evenings", "Weekday Overnight", "Weekend Day", "Weekend Evening", "Weekend Overnight"].map((shift) => (
                  <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:border-brand-300 hover:bg-brand-25 transition-colors cursor-pointer">
                    <input type="checkbox" name="shifts" value={shift} class="form-checkbox rounded text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{shift}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <fieldset>
              <legend class="label-base">Are you available to work part-time?</legend>
              <div class="flex gap-6 mt-1">
                {["Yes", "No", "Maybe"].map((opt) => (
                  <label class="inline-flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="part_time" value={opt} class="form-radio text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{opt}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <div id="part-time-hours-field" class="hidden transition-all duration-300">
              <label for="part_time_hours" class="label-base">If open to part-time, how many hours per week?</label>
              <input type="text" id="part_time_hours" name="part_time_hours" class="input-base" placeholder="e.g. 20" />
            </div>

            <fieldset>
              <legend class="label-base">Pay rate is $5 USD/hr for bilingual (English & Spanish) and $4/hr for English-only. Does that work for you? <span class="text-error-500">*</span></legend>
              <div class="flex gap-6 mt-1">
                {["Yes", "No", "Maybe"].map((opt) => (
                  <label class="inline-flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="pay_rate_ok" value={opt} data-required class="form-radio text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{opt}</span>
                  </label>
                ))}
              </div>
            </fieldset>
          </div>
        </div>

        <!-- ============ STEP 3: Experience & Skills ============ -->
        <div class="form-step" data-step="2">
          <div class="mb-8">
            <div class="featured-icon featured-icon-md featured-icon-brand mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342" /></svg>
            </div>
            <h2 class="text-display-xs font-heading text-gray-900 mb-1">Experience & Skills</h2>
            <p class="text-sm text-gray-500">Tell us about your work experience and proficiencies.</p>
          </div>

          <div class="space-y-5">
            <div>
              <label for="experience" class="label-base">Customer Service / Call Center / Law Firm Experience <span class="text-error-500">*</span></label>
              <p class="text-xs text-gray-400 mb-1.5">Please include number of years in the industry and companies for whom you've worked.</p>
              <textarea id="experience" name="experience" data-required rows="4" class="input-base resize-y" placeholder="Describe your relevant experience..."></textarea>
            </div>

            <fieldset>
              <legend class="label-base">Tasks, fields of study, or industries in which you have experience <span class="text-error-500">*</span></legend>
              <p class="text-xs text-gray-400 mb-2">Select all that apply.</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {["BPO", "Customer service", "Legal", "Intake", "Sales", "Data analysis", "Quality assurance", "Data management", "Medical/nursing", "Records management", "Document management", "Appointment-setting", "Executive Assistant", "Marketing", "Supervisor", "Accounting"].map((item) => (
                  <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:border-brand-300 hover:bg-brand-25 transition-colors cursor-pointer">
                    <input type="checkbox" name="experience_areas" value={item} class="form-checkbox rounded text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{item}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <fieldset>
              <legend class="label-base">Tools in which you are proficient <span class="text-error-500">*</span></legend>
              <p class="text-xs text-gray-400 mb-2">Select all that apply.</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {["Microsoft Office", "Microsoft Teams", "Google Sheets", "Google Docs", "Advanced Excel", "Advanced Powerpoint"].map((tool) => (
                  <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:border-brand-300 hover:bg-brand-25 transition-colors cursor-pointer">
                    <input type="checkbox" name="tools" value={tool} class="form-checkbox rounded text-brand-gold focus:ring-brand-gold" />
                    <span class="text-sm text-gray-700">{tool}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <div>
              <label for="crm_systems" class="label-base">CRM Systems Experience</label>
              <input type="text" id="crm_systems" name="crm_systems" class="input-base" placeholder="e.g. Salesforce, HubSpot, Clio..." />
            </div>

            <div>
              <label for="legal_software" class="label-base">Legal Software Experience</label>
              <input type="text" id="legal_software" name="legal_software" class="input-base" placeholder="e.g. Clio, MyCase, PracticePanther..." />
            </div>

            <div>
              <label for="resume" class="label-base">Resume/CV <span class="text-error-500">*</span></label>
              <p class="text-xs text-gray-400 mb-1.5">Must be in English. Use the provided <a href="https://www.canva.com" target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:underline">Canva template</a> to update your resume. Max 10 MB.</p>
              <div class="file-upload-area" id="resume-upload-area">
                <input type="file" id="resume" name="resume" data-required accept=".pdf,.doc,.docx" class="file-input" />
                <div class="file-upload-content">
                  <svg class="w-8 h-8 text-gray-400 mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" /></svg>
                  <p class="text-sm text-gray-600 font-medium">Click to upload or drag & drop</p>
                  <p class="text-xs text-gray-400">PDF, DOC, DOCX up to 10 MB</p>
                </div>
              </div>
              <p id="resume-filename" class="text-xs text-success-600 mt-1 hidden"></p>
            </div>

            <div>
              <label for="id_card" class="label-base">Identification Card</label>
              <p class="text-xs text-gray-400 mb-1.5">For identification purposes only. PDF, document, or image. Max 10 MB.</p>
              <div class="file-upload-area" id="id-upload-area">
                <input type="file" id="id_card" name="id_card" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.webp" class="file-input" />
                <div class="file-upload-content">
                  <svg class="w-8 h-8 text-gray-400 mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" /></svg>
                  <p class="text-sm text-gray-600 font-medium">Click to upload or drag & drop</p>
                  <p class="text-xs text-gray-400">PDF, DOC, JPG, PNG up to 10 MB</p>
                </div>
              </div>
              <p id="id-filename" class="text-xs text-success-600 mt-1 hidden"></p>
            </div>
          </div>
        </div>

        <!-- ============ STEP 4: Technology Specifications ============ -->
        <div class="form-step" data-step="3">
          <div class="mb-8">
            <div class="featured-icon featured-icon-md featured-icon-brand mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z" /></svg>
            </div>
            <h2 class="text-display-xs font-heading text-gray-900 mb-1">Technology Specifications</h2>
            <p class="text-sm text-gray-500">Confirm that you meet the minimum technology requirements.</p>
          </div>

          <div class="card p-5 mb-6 bg-warning-25 border-warning-300">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-warning-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" /></svg>
              <div class="text-xs text-warning-700 leading-relaxed">
                <p class="font-semibold mb-1">Minimum Requirements:</p>
                <ul class="list-disc list-inside space-y-0.5">
                  <li>OS: macOS 11+ or Windows 10 (latest version) or equivalent</li>
                  <li>Processor: Intel i3 or above (no Pentium)</li>
                  <li>RAM: At least 8 GB</li>
                  <li>Internet: Download speed min 50 Mbps, upload min 20 Mbps</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="space-y-5">
            <div>
              <label for="computer_specs" class="label-base">Computer Specifications <span class="text-error-500">*</span></label>
