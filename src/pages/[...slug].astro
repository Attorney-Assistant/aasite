---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import wpPages from "../../scripts/output/wp-xml-pages.json";

export function getStaticPaths() {
  // Only build WP XML pages that are still needed as live content.
  // Everything else is either migrated to a dedicated Astro page or
  // handled by an .htaccess redirect.
  const liveLegacySlugs = new Set([
    "attorney-assistant-contract-terms",
    "attorney-assistant-contract-terms-for-100",
    "testimonials-and-case-studies",
    "recruitment-onboarding",
    "cost-comparison",
    "affiliate",
    "events",
    "new-events",
  ]);
  return wpPages
    .filter((page: any) => liveLegacySlugs.has(page.slug))
    .map((page: any) => ({
      params: { slug: page.slug },
      props: { page },
    }));
}

interface Props {
  page: {
    id: string;
    title: string;
    slug: string;
    link: string;
    content: string;
  };
}

const { page } = Astro.props;
---

<BaseLayout title={page.title} description={`${page.title} — Attorney Assistant helps law firms streamline operations, fix intake, and grow faster.`}>
  <Hero title={page.title} />

  <article class="wp-content">
    <div class="container-wide py-12 lg:py-20">
      <div class="prose-brand" set:html={page.content} />
    </div>
  </article>
</BaseLayout>
