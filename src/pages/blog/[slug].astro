---
import BaseLayout from "@layouts/BaseLayout.astro";
import { fetchBlogPostSlugs, fetchBlogPostBySlug, fetchAllBlogPosts } from "@lib/blog";
import BlogCard from "@components/BlogCard.astro";
import ROICalculator from "@components/ROICalculator.astro";

export async function getStaticPaths() {
  let slugs: { slug: string }[] = [];
  try {
    slugs = await fetchBlogPostSlugs();
  } catch {}
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = await fetchBlogPostBySlug(slug!);

if (!post) {
  return Astro.redirect("/blog");
}

const formattedDate = post.publishedDate
  ? new Date(post.publishedDate).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;

// Related posts: prefer same tag, fall back to most recent
const allPosts = await fetchAllBlogPosts();
const currentTagSlugs = new Set((post.tags || []).map((t: any) => t.slug));
const otherPosts = allPosts.filter((p: any) => p.slug !== slug);
const tagMatches = otherPosts.filter((p: any) =>
  (p.tags || []).some((t: any) => currentTagSlugs.has(t.slug))
);
const relatedPosts = tagMatches.length >= 3
  ? tagMatches.slice(0, 3)
  : [...tagMatches, ...otherPosts.filter((p: any) => !tagMatches.includes(p))].slice(0, 3);
---

<BaseLayout
  title={post.seoTitle || post.title}
  description={post.seoDescription || post.excerpt}
  image={post.featuredImage}
  type="article"
  publishedDate={post.publishedDate}
  author={post.authorName}
  schema={{
    "@type": "BlogPosting",
    "headline": post.title,
    "description": post.seoDescription || post.excerpt,
    "image": post.featuredImage || undefined,
    "datePublished": post.publishedDate,
    "author": { "@type": "Person", "name": post.authorName || "Attorney Assistant" },
    "publisher": { "@id": "https://attorneyassistant.com/#organization" },
    "mainEntityOfPage": `https://attorneyassistant.com/blog/${slug}`,
    "keywords": post.tags?.map((t: any) => t.name).join(", ") || undefined,
  }}
>

  <article>
    <!-- Header -->
    <header class="bg-white border-b border-gray-200 py-16 md:py-24">
      <div class="container-narrow reveal" style="transition-delay:0.1s">
        <a href="/blog" class="group inline-flex items-center gap-1.5 text-sm font-medium text-brand-700 hover:text-brand-800 transition-colors mb-8">
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
          Back to Blog
        </a>

        {post.tags && post.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-5">
            {post.tags.slice(0, 5).map((tag: any) => (
              <a
                href={`/blog/category/${tag.slug}`}
                class="badge badge-brand"
              >
                {tag.name}
              </a>
            ))}
          </div>
        )}

        <h1 class="text-display-sm md:text-display-md lg:text-display-lg font-heading text-gray-900 mb-6">
          {post.title}
        </h1>

        {formattedDate && (
          <div class="text-sm text-gray-500">
            <time datetime={post.publishedDate}>{formattedDate}</time>
          </div>
        )}
      </div>
    </header>

    {post.featuredImage && (
      <div class="container-narrow mt-10 reveal" style="transition-delay:0.2s">
        <img
          src={post.featuredImage}
          alt={post.title}
          class="w-full rounded-2xl border border-gray-200 shadow-xs"
        />
      </div>
    )}

    <!-- Body -->
    <div class="container-narrow py-12 md:py-16">
      <div class="prose-brand blog-content" set:html={post.postBody} />
    </div>

    <!-- ROI Calculator (HubSpot posts only) -->
    {post.source === "hubspot" && (
      <div class="container-narrow pb-12">
        <ROICalculator />
      </div>
    )}

    <!-- Back to blog -->
    <div class="container-narrow pb-16">
      <div class="border-t border-gray-200 pt-8">
        <a href="/blog" class="group inline-flex items-center gap-1.5 text-sm font-medium text-brand-700 hover:text-brand-800 transition-colors">
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
          Back to Blog
        </a>
      </div>
    </div>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="section-padding">
        <div class="container-wide">
          <h2 class="text-display-xs font-heading text-center text-gray-900 mb-4">Related Articles</h2>
          <div class="divider-gold-center mb-12"></div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {relatedPosts.map((p: any) => (
              <BlogCard
                title={p.title}
                slug={p.slug}
                excerpt={p.excerpt}
                featuredImage={p.featuredImage}
                publishedDate={p.publishedDate}
                tags={p.tags}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </article>

  <style>
    .blog-content :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 1rem;
    }
    .blog-content :global(iframe) {
      max-width: 100%;
      border-radius: 0.75rem;
    }
    .blog-content :global(table) {
      max-width: 100%;
      overflow-x: auto;
      display: block;
    }
    .blog-content :global(pre) {
      max-width: 100%;
      overflow-x: auto;
      border-radius: 0.75rem;
    }
  </style>

</BaseLayout>
