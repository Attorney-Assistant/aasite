---
/**
 * Redirect legacy /Blog/category/slug (capital B) URLs
 * to the new /blog/category/slug (lowercase) equivalents.
 */
import { fetchBlogTags } from "@lib/hubspot";

export async function getStaticPaths() {
  let tags: any[] = [];
  try {
    tags = await fetchBlogTags();
  } catch {}
  return tags.map((tag) => ({
    params: { slug: tag.slug },
    props: { name: tag.name },
  }));
}

interface Props {
  name: string;
}

const { slug } = Astro.params;
const { name } = Astro.props;
const destination = `/blog/category/${slug}`;
const canonicalUrl = `https://attorneyassistant.com${destination}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{`Redirecting — ${name}`}</title>
  </head>
  <body>
    <p>This page has moved. <a href={destination}>Click here</a> if you are not redirected.</p>
  </body>
</html>
