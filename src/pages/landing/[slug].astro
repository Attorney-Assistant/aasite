---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import FeatureCard from "@components/FeatureCard.astro";
import TestimonialCard from "@components/TestimonialCard.astro";
import CTABanner from "@components/CTABanner.astro";
import { fetchLandingPageSlugs, fetchLandingPageBySlug } from "@lib/hubspot";

export async function getStaticPaths() {
  let slugs: { slug: string }[] = [];
  try {
    slugs = await fetchLandingPageSlugs();
  } catch {}
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const page = await fetchLandingPageBySlug(slug!);

if (!page) {
  return Astro.redirect("/");
}

// Map old variant names to new ones
function mapVariant(style: string): "brand" | "light" | "dark" {
  if (style === "gold" || style === "blue") return "brand";
  if (style === "dark") return "dark";
  if (style === "light") return "light";
  return "brand";
}
---

<BaseLayout
  title={page.seo_title || page.hero_title || page.title}
  description={page.seo_description}
  image={page.hero_image}
>

  <Hero
    title={page.hero_title}
    subtitle={page.hero_subtitle}
    buttonText={page.cta_text}
    buttonLink={page.cta_link}
  />

  {page.sections?.map((section: any) => {
    if (section.type === "hero") {
      return (
        <Hero
          title={section.heading}
          subtitle={section.subheading}
          buttonText={section.cta_text}
          buttonLink={section.cta_link}
        />
      );
    }

    if (section.type === "cta") {
      return (
        <CTABanner
          heading={section.heading}
          body={section.body}
          buttonText={section.button_text}
          buttonLink={section.button_link}
          variant={mapVariant(section.style || "brand")}
        />
      );
    }

    if (section.type === "feature_grid") {
      return (
        <section class="section-padding bg-gray-50 border-y border-gray-100 relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-20%,rgba(180,160,120,0.08),transparent_70%)] pointer-events-none"></div>
          <div class="container-wide relative">
            {section.heading && (
              <div class="text-center mb-12 reveal">
                <h2 class="text-display-sm md:text-display-md font-heading text-gray-900">{section.heading}</h2>
                <div class="divider-gold-center mt-5"></div>
              </div>
            )}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {section.features?.map((f: any, i: number) => (
                <div class="reveal" style={`transition-delay: ${i * 100}ms`}>
                  <FeatureCard title={f.title} description={f.description} icon={f.icon} />
                </div>
              ))}
            </div>
          </div>
        </section>
      );
    }

    if (section.type === "text_with_image") {
      return (
        <section class="section-padding">
          <div class="container-wide">
            <div class:list={["grid md:grid-cols-2 gap-12 lg:gap-16 items-center", section.image_position === "left" && "md:flex-row-reverse"]}>
              <div class:list={[section.image_position === "left" && "md:order-2", "reveal"]}>
                {section.heading && <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mb-6">{section.heading}</h2>}
                {section.body && <div class="prose-brand" set:html={section.body} />}
              </div>
              {section.image && (
                <div class:list={[section.image_position === "left" && "md:order-1", "reveal"]} style="transition-delay: 100ms">
                  <img src={section.image} alt={section.image_alt || ""} class="rounded-2xl shadow-lg w-full" loading="lazy" />
                </div>
              )}
            </div>
          </div>
        </section>
      );
    }

    if (section.type === "testimonials") {
      return (
        <section class="section-padding bg-gray-50 border-y border-gray-100 relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-20%,rgba(180,160,120,0.08),transparent_70%)] pointer-events-none"></div>
          <div class="container-wide relative">
            {section.heading && (
              <div class="text-center mb-12 reveal">
                <h2 class="text-display-sm md:text-display-md font-heading text-gray-900">{section.heading}</h2>
                <div class="divider-gold-center mt-5"></div>
              </div>
            )}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {section.testimonials?.map((t: any, i: number) => (
                <div class="reveal" style={`transition-delay: ${i * 100}ms`}>
                  <TestimonialCard {...t} />
                </div>
              ))}
            </div>
          </div>
        </section>
      );
    }

    if (section.type === "faq") {
      return (
        <section class="section-padding">
          <div class="container-narrow">
            {section.heading && (
              <div class="text-center mb-12 reveal">
                <h2 class="text-display-sm md:text-display-md font-heading text-gray-900">{section.heading}</h2>
                <div class="divider-gold-center mt-5"></div>
              </div>
            )}
            <div class="divide-y divide-gray-200">
              {section.faqs?.map((faq: any, i: number) => (
                <details class="group py-5 reveal" style={`transition-delay: ${i * 80}ms`}>
                  <summary class="flex items-center justify-between cursor-pointer text-base font-semibold text-gray-900">
                    {faq.question}
                    <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform shrink-0 ml-4" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                    </svg>
                  </summary>
                  <p class="mt-3 text-gray-500 leading-relaxed">{faq.answer}</p>
                </details>
              ))}
            </div>
          </div>
        </section>
      );
    }

    return null;
  })}

  {page.cta_text && page.cta_link && (
    <CTABanner
      heading="Ready to Get Started?"
      buttonText={page.cta_text}
      buttonLink={page.cta_link}
      variant="brand"
    />
  )}

</BaseLayout>
