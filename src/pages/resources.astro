---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import CTABanner from "@components/CTABanner.astro";

const resources = [
  {
    title: "Scripts",
    description: "Ready-to-use intake and follow-up scripts tailored for law firms. Download and customize for your practice areas.",
    href: "/all-scripts-2025",
    icon: "document",
  },
  {
    title: "Guides",
    description: "In-depth guides on legal operations, intake optimization, and building a more efficient law firm.",
    href: "/guides",
    icon: "book",
  },
  {
    title: "Podcasts",
    description: "Listen to expert conversations on legal industry trends, firm growth strategies, and operational best practices.",
    href: "/podcast",
    icon: "headphones",
  },
  {
    title: "Webinars",
    description: "On-demand webinars covering everything from intake best practices to scaling your firm with virtual support.",
    href: "/webinars",
    icon: "video",
  },
  {
    title: "Blog",
    description: "Insights, tips, and best practices from the Attorney Assistant team to help your firm thrive.",
    href: "/blog",
    icon: "pencil",
  },
];
---

<BaseLayout title="Free Resources for Law Firms" description="Free resources to help law firms operate smarter — intake scripts, downloadable guides, podcast episodes, recorded webinars, and more.">

  <Hero
    badge="Resource Hub"
    title="Resources"
    subtitle="Free resources to help empower law firms to operate smarter."
  />

  <section class="section-padding reveal" style="transition-delay: 0.1s;">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {resources.map((resource) => (
          <a href={resource.href} class="card card-hover p-8 flex flex-col group">
            <div class="featured-icon featured-icon-md featured-icon-brand mb-5">
              {resource.icon === "document" && (
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
              )}
              {resource.icon === "book" && (
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
              )}
              {resource.icon === "headphones" && (
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" /></svg>
              )}
              {resource.icon === "video" && (
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25z" /></svg>
              )}
              {resource.icon === "pencil" && (
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /></svg>
              )}
            </div>
            <h3 class="text-lg font-heading text-gray-900 mb-2 group-hover:text-brand-600 transition-colors">{resource.title}</h3>
            <p class="text-base text-gray-500 leading-relaxed flex-1">{resource.description}</p>
            <span class="inline-flex items-center mt-5 text-sm font-semibold text-brand-700 group-hover:text-brand-800 transition-colors">
              Explore {resource.title}
              <svg class="w-4 h-4 ml-1.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="newsletter" class="section-padding bg-gray-50 relative overflow-hidden reveal" style="transition-delay: 0.2s;">
    <div class="absolute inset-0 bg-gradient-mesh opacity-40"></div>
    <div class="container-narrow text-center relative">
      <div class="featured-icon featured-icon-md featured-icon-brand mx-auto mb-5">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
      </div>
      <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mb-4">Subscribe For The Latest Resources</h2>
      <div class="divider-gold-center mt-5"></div>
      <p class="text-lg text-gray-500 mb-8 max-w-2xl mx-auto">Stay up to date with the latest scripts, guides, and insights for running a more efficient law firm.</p>
      <a href="/contact" class="btn-primary btn-lg">Get in Touch</a>
    </div>
  </section>

  <CTABanner
    heading="Ready to Transform Your Practice?"
    body="Get in touch to learn how Attorney Assistant can streamline your legal operations."
    buttonText="Get Started"
    buttonLink="/contact"
    variant="brand"
  />

</BaseLayout>
