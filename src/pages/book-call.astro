---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="Book a Call | Attorney Assistant"
  description="Schedule a free consultation with Attorney Assistant. Let's discuss how we can help your law firm streamline operations and capture more leads."
>

  <section class="relative overflow-hidden bg-gradient-to-b from-brand-navy via-brand-800 to-brand-navy grain-overlay">
    <div class="absolute inset-0">
      <div class="absolute top-20 left-1/4 w-96 h-96 bg-brand-gold/15 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-1/3 w-80 h-80 bg-brand-blue/15 rounded-full blur-3xl"></div>
    </div>
    <div class="container-wide relative py-16 md:py-20">
      <div class="text-center max-w-2xl mx-auto reveal">
        <span class="badge bg-white/10 text-white/80 border-white/10 mb-4">Free Consultation</span>
        <h1 class="text-display-sm md:text-display-md font-heading text-white mb-4">
          Schedule Your Diagnostic Call
        </h1>
        <div class="divider-gold-center mt-4 mb-5"></div>
        <p class="text-lg text-white/60">
          Tell us what's not working and we'll show you how to fix it — no pitch, just a straightforward conversation about your firm's operations.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-5 gap-12 items-start">
        <!-- Calendly Embed -->
        <div class="lg:col-span-3 reveal" style="transition-delay: 0.1s;">
          <div style="max-width: 720px; margin: 0 auto;">
            <div
              class="calendly-inline-widget"
              data-url="https://calendly.com/aa-sales-team/attorney-assistant-diagnostic-call-with-team?hide_event_type_details=1&hide_gdpr_banner=1"
              style="min-width:320px;height:660px;"
            ></div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 reveal" style="transition-delay: 0.2s;">
          <div class="space-y-6">
            <!-- What to expect -->
            <div class="card p-6">
              <h3 class="font-heading text-lg text-gray-900 mb-4">What to Expect</h3>
              <ul class="space-y-3">
                <li class="flex gap-3">
                  <div class="featured-icon featured-icon-md featured-icon-gold flex-shrink-0 mt-0.5">
                    <img src="/icons/buiness & finance_analityc.svg" alt="" aria-hidden="true" class="w-5 h-5" />
                  </div>
                  <div>
                    <p class="text-sm font-medium text-gray-900">Intake Audit</p>
                    <p class="text-xs text-gray-500">We'll review how leads flow through your firm</p>
                  </div>
                </li>
                <li class="flex gap-3">
                  <div class="featured-icon featured-icon-md featured-icon-gold flex-shrink-0 mt-0.5">
                    <img src="/icons/buiness & finance_target.svg" alt="" aria-hidden="true" class="w-5 h-5" />
                  </div>
                  <div>
                    <p class="text-sm font-medium text-gray-900">Gap Analysis</p>
                    <p class="text-xs text-gray-500">Identify where leads are falling through the cracks</p>
                  </div>
                </li>
                <li class="flex gap-3">
                  <div class="featured-icon featured-icon-md featured-icon-gold flex-shrink-0 mt-0.5">
                    <img src="/icons/buiness & finance_chart.svg" alt="" aria-hidden="true" class="w-5 h-5" />
                  </div>
                  <div>
                    <p class="text-sm font-medium text-gray-900">Custom Recommendations</p>
                    <p class="text-xs text-gray-500">Actionable steps tailored to your practice</p>
                  </div>
                </li>
              </ul>
            </div>

            <!-- Contact info -->
            <div class="card p-6 bg-gray-50">
              <h3 class="font-heading text-sm text-gray-900 mb-3">Prefer to reach out directly?</h3>
              <div class="space-y-3">
                <a href="tel:+12153372677" class="flex items-center gap-3 text-sm text-gray-600 hover:text-brand-700 transition-colors">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                  +1 (215) 337-2677
                </a>
                <a href="mailto:info@attorneyassistant.com" class="flex items-center gap-3 text-sm text-gray-600 hover:text-brand-700 transition-colors">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                  info@attorneyassistant.com
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calendly script -->
  <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>

</BaseLayout>
