  .quiz-yn-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .quiz-option--yn {
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.25rem 1rem;
    gap: 0.5rem;
  }
  .quiz-option--yn input { display: none; }
  .quiz-option--yn svg { flex-shrink: 0; }
  .quiz-option--yes:hover {
    border-color: #22c55e;
    background: rgba(34,197,94,0.04);
  }
  .quiz-option--yes:has(input:checked) {
    border-color: #22c55e;
    background: rgba(34,197,94,0.08);
    color: #16a34a;
    box-shadow: 0 0 0 3px rgba(34,197,94,0.1);
  }
  .quiz-option--no:hover {
    border-color: #ef4444;
    background: rgba(239,68,68,0.04);
  }
  .quiz-option--no:has(input:checked) {
    border-color: #ef4444;
    background: rgba(239,68,68,0.08);
    color: #dc2626;
    box-shadow: 0 0 0 3px rgba(239,68,68,0.1);
  }

  /* Results */
  .result-score-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
  .result-score-badge.severe {
    background: rgba(239,68,68,0.1);
    color: #dc2626;
    border: 1px solid rgba(239,68,68,0.2);
  }
  .result-score-badge.critical {
    background: rgba(249,115,22,0.1);
    color: #ea580c;
    border: 1px solid rgba(249,115,22,0.2);
  }
  .result-score-badge.gaps {
    background: rgba(249,166,48,0.1);
    color: #b45309;
    border: 1px solid rgba(249,166,48,0.2);
  }
  /* Hide ALL quiz/hidden fields rendered by HubSpot — only show contact fields */
  #hs-form-target .hs_marketing_spend,
  #hs-form-target .hs_net_fee_per_case,
  #hs-form-target .hs_afterhours_close,
  #hs-form-target .hs_n15minute_speed_to_lead,
  #hs-form-target .hs_saturday_persistence,
  #hs-form-target .hs_operational_count,
  #hs-form-target .hs-fieldtype-radio,
  #hs-form-target .hs-fieldtype-select[class*="marketing_spend"],
  #hs-form-target .hs-fieldtype-select[class*="net_fee"],
  #hs-form-target .hs-fieldtype-select[class*="afterhours"],
  #hs-form-target .hs-fieldtype-select[class*="speed_to_lead"],
  #hs-form-target .hs-fieldtype-select[class*="saturday"],
  #hs-form-target .hs-fieldtype-select[class*="operational"] {
    display: none !important;
    height: 0 !important;
    overflow: hidden !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .result-score-badge.aligned {
    background: rgba(34,197,94,0.1);
    color: #16a34a;
    border: 1px solid rgba(34,197,94,0.2);
  }
</style>

<script is:inline>
(function() {
  var questions = document.querySelectorAll('.quiz-q');
  var currentStep = 0;
  var totalQuestions = questions.length;
  var answers = {};

  function updateProgress(step, total) {
    var pct = Math.round(((step + 1) / total) * 100);
    var bar = document.getElementById('quiz-progress');
    var label = document.getElementById('quiz-step-label');
    var pctLabel = document.getElementById('quiz-pct');
    if (bar) bar.style.width = pct + '%';
    if (label) label.textContent = 'Question ' + (step + 1) + ' of ' + total;
    if (pctLabel) pctLabel.textContent = pct + '%';
  }

  function showQuestion(idx) {
    questions.forEach(function(q, i) {
      q.classList.toggle('hidden', i !== idx);
    });
    updateProgress(idx, totalQuestions);
  }

  // Auto-advance on radio selection
  document.getElementById('quiz-container').addEventListener('change', function(e) {
    if (e.target.type !== 'radio') return;
    answers[e.target.name] = e.target.value;

    setTimeout(function() {
      if (currentStep < totalQuestions - 1) {
        currentStep++;
        showQuestion(currentStep);
      } else {
        showFormStep();
      }
    }, 300);
  });

  function showFormStep() {
    document.getElementById('quiz-container').classList.add('hidden');
    document.getElementById('quiz-step-label').textContent = 'Almost done!';
    document.getElementById('quiz-pct').textContent = '100%';
    document.getElementById('quiz-progress').style.width = '100%';
    document.getElementById('form-step').classList.remove('hidden');
    loadHubSpotForm();
  }

  function getOperationalCount() {
    var count = 0;
    if ((answers.afterhours_close || '').toLowerCase() === 'no') count++;
    if ((answers.n15minute_speed_to_lead || '').toLowerCase() === 'no') count++;
    if ((answers.saturday_persistence || '').toLowerCase() === 'no') count++;
    return count;
  }

  function showResults() {
    var count = getOperationalCount();
    var resultsDiv = document.getElementById('results-content');
    var badge, title, desc;

    if (count === 3) {
      badge = '<div class="result-score-badge severe"><span class="w-2 h-2 rounded-full bg-red-500"></span>Severe Exposure</div>';
      title = 'You are wasting marketing dollars.';
      desc = 'Your firm has critical operational gaps across after-hours coverage, speed to lead, and weekend persistence. Every marketing dollar you spend is partially wasted until these are addressed.';
    } else if (count === 2) {
      badge = '<div class="result-score-badge critical"><span class="w-2 h-2 rounded-full bg-orange-500"></span>Critical Weaknesses</div>';
      title = 'You are wasting marketing dollars.';
      desc = 'For firms with your marketing spend and case volume, missed timing windows often result in signed agreements being lost before follow-up occurs.';
    } else if (count === 1) {
      badge = '<div class="result-score-badge gaps"><span class="w-2 h-2 rounded-full bg-amber-500"></span>Noticeable Gaps</div>';
      title = 'You are wasting marketing dollars.';
      desc = 'Your responses indicate at least one gap in how new client leads are handled. For firms spending at your level, even a single breakdown in coverage or speed can impact signed clients annually.';
    } else {
      badge = '<div class="result-score-badge aligned"><span class="w-2 h-2 rounded-full bg-green-500"></span>Operationally Aligned</div>';
      title = 'Your firm appears operationally aligned.';
      desc = 'Based on your responses, your firm appears capable of signing new clients efficiently. Your primary leverage may be optimizing marketing allocation.';
    }

    resultsDiv.innerHTML = badge +
      '<h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mb-4">' + title + '</h2>' +
      '<p class="text-base text-gray-500 leading-relaxed">' + desc + '</p>';

    document.getElementById('form-step').classList.add('hidden');
    document.querySelector('#quiz-card .mb-6').classList.add('hidden'); // hide progress
    document.getElementById('results-step').classList.remove('hidden');

    // Scroll to results
    document.getElementById('quiz-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function loadHubSpotForm() {
    function createForm() {
      window.hbspt.forms.create({
        portalId: '49161090',
        formId: '0df04980-60a2-47a6-830a-58d1a3a8b9d0',
        region: 'na1',
        target: '#hs-form-target',
        onFormReady: function(form) {
          // Force-hide all quiz fieldsets via JS (belt + suspenders with CSS)
          var hideFields = ['marketing_spend', 'net_fee_per_case', 'afterhours_close', 'n15minute_speed_to_lead', 'saturday_persistence', 'operational_count'];
          hideFields.forEach(function(name) {
            var wrapper = form.querySelector('.hs_' + name);
            if (wrapper) wrapper.style.display = 'none';
          });
          // Also hide any fieldsets that contain radio buttons
          form.querySelectorAll('fieldset').forEach(function(fs) {
            if (fs.querySelector('input[type="radio"]')) fs.style.display = 'none';
          });

          // Fill hidden fields
          var fields = {
            marketing_spend: answers.marketing_spend || '',
            net_fee_per_case: answers.net_fee_per_case || '',
            afterhours_close: answers.afterhours_close || '',
            n15minute_speed_to_lead: answers.n15minute_speed_to_lead || '',
            saturday_persistence: answers.saturday_persistence || '',
            operational_count: String(getOperationalCount())
          };

          Object.keys(fields).forEach(function(name) {
            var input = form.querySelector('input[name="' + name + '"]');
            if (input) {
              input.value = fields[name];
              input.dispatchEvent(new Event('input', { bubbles: true }));
              input.dispatchEvent(new Event('change', { bubbles: true }));
            }
            // Also try select elements
            var select = form.querySelector('select[name="' + name + '"]');
            if (select) {
              select.value = fields[name];
              select.dispatchEvent(new Event('change', { bubbles: true }));
            }
          });
        },
        onFormSubmit: function() {
          if (typeof fbq !== 'undefined') fbq('track', 'Lead');
          if (typeof mixpanel !== 'undefined') mixpanel.track('Marketing Waste Quiz Submitted', { operational_count: getOperationalCount() });
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'quiz_submitted', conversion_type: 'lead', operational_count: getOperationalCount() });
        },
        onFormSubmitted: function() {
          showResults();
        }
      });
    }

    if (window.hbspt) {
      createForm();
    } else {
      var script = document.createElement('script');
      script.src = '//js.hsforms.net/forms/embed/v2.js';
      script.charset = 'utf-8';
      script.onload = createForm;
      document.head.appendChild(script);
    }
  }

  showQuestion(0);
})();
</script>
