---
import BaseLayout from "@layouts/BaseLayout.astro";
import CTABanner from "@components/CTABanner.astro";
---

<BaseLayout
  title="Your Marketing Budget Is Leaking Revenue | Attorney Assistant"
  description="Law firms pour money into marketing but lose leads to broken follow-up, dead social accounts, and zero tracking. We fix the operational gaps so your spend actually converts."
>

  <!-- Hero with Form -->
  <section class="relative overflow-hidden bg-brand-950">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-navy via-brand-900 to-brand-950"></div>
    <div class="lp-orb lp-orb--1" aria-hidden="true"></div>
    <div class="lp-orb lp-orb--2" aria-hidden="true"></div>
    <div class="grain-overlay"></div>

    <div class="container-wide relative z-10 py-20 lg:py-28">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal">
          <div class="mb-6">
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium bg-error-50/10 text-red-400 border border-red-500/20 backdrop-blur-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse"></span>
              Marketing ROI Crisis
            </span>
          </div>
          <h1 class="text-display-md md:text-display-lg lg:text-display-xl font-heading text-white leading-tight mb-6">
            Your Marketing Budget Is <span class="text-gradient-gold">Leaking Revenue</span>
          </h1>
          <p class="text-lg md:text-xl text-gray-300 mb-8 leading-relaxed max-w-lg">
            You're spending thousands on ads, SEO, and agencies — but leads go cold, social media goes quiet, and nobody tracks what's working. The problem isn't your marketing. It's the operations behind it.
          </p>
          <div class="flex flex-wrap items-center gap-4 text-sm text-gray-400">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Free audit
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              No commitment
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Results in 30 days
            </div>
          </div>
        </div>
        <!-- Quiz + Form Card -->
        <div class="bg-white rounded-2xl p-6 md:p-8 shadow-2xl ring-1 ring-white/10 reveal" style="transition-delay: 150ms" id="quiz-card">
          <!-- Progress bar -->
          <div class="mb-6">
            <div class="flex justify-between text-xs text-gray-400 mb-2">
              <span id="quiz-step-label">Question 1 of 5</span>
              <span id="quiz-pct">20%</span>
            </div>
            <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
              <div class="h-full bg-brand-gold rounded-full transition-all duration-500" id="quiz-progress" style="width:20%"></div>
            </div>
          </div>

          <!-- Quiz questions (one at a time) -->
          <div id="quiz-container">
            <div class="quiz-q" data-field="marketing_spend">
              <div class="quiz-q-icon">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
              </div>
              <h2 class="text-lg font-heading text-gray-900 mb-5">Approximately how much does your firm spend on marketing per month?</h2>
              <div class="space-y-2.5">
                <label class="quiz-option"><input type="radio" name="marketing_spend" value="Under $5,000"><span>Under $5,000</span></label>
                <label class="quiz-option"><input type="radio" name="marketing_spend" value="$5,000-$15,000"><span>$5,000 – $15,000</span></label>
                <label class="quiz-option"><input type="radio" name="marketing_spend" value="$15,000-$30,000"><span>$15,000 – $30,000</span></label>
                <label class="quiz-option"><input type="radio" name="marketing_spend" value="$30,000+"><span>$30,000+</span></label>
              </div>
            </div>

            <div class="quiz-q hidden" data-field="net_fee_per_case">
              <div class="quiz-q-icon">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <h2 class="text-lg font-heading text-gray-900 mb-5">On average, how much revenue does your firm generate per signed client?</h2>
              <div class="space-y-2.5">
                <label class="quiz-option"><input type="radio" name="net_fee_per_case" value="Under $5,000"><span>Under $5,000</span></label>
                <label class="quiz-option"><input type="radio" name="net_fee_per_case" value="$5,000-$10,000"><span>$5,000 – $10,000</span></label>
                <label class="quiz-option"><input type="radio" name="net_fee_per_case" value="$10,000-$25,000"><span>$10,000 – $25,000</span></label>
                <label class="quiz-option"><input type="radio" name="net_fee_per_case" value="$25,000+"><span>$25,000+</span></label>
              </div>
            </div>

            <div class="quiz-q hidden" data-field="afterhours_close">
              <div class="quiz-q-icon quiz-q-icon--alert">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <h2 class="text-lg font-heading text-gray-900 mb-4">If a qualified lead contacts your firm after hours, does your team immediately exit that same interaction with either:</h2>
              <div class="text-sm text-gray-500 mb-5 space-y-1">
                <p>(1) A signed engagement agreement secured on the spot, OR</p>
                <p>(2) A firmly booked appointment with a decision-maker authorized to convert them into a signed and paid client</p>
              </div>
              <div class="quiz-yn-grid">
                <label class="quiz-option quiz-option--yn quiz-option--yes"><input type="radio" name="afterhours_close" value="Yes"><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg><span>Yes</span></label>
                <label class="quiz-option quiz-option--yn quiz-option--no"><input type="radio" name="afterhours_close" value="No"><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg><span>No</span></label>
              </div>
            </div>

            <div class="quiz-q hidden" data-field="n15minute_speed_to_lead">
              <div class="quiz-q-icon quiz-q-icon--alert">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
              </div>
              <h2 class="text-lg font-heading text-gray-900 mb-5">If a new lead submitted a form through your website right now, would someone from your firm reach out and follow-up within 15 minutes?</h2>
              <div class="quiz-yn-grid">
                <label class="quiz-option quiz-option--yn quiz-option--yes"><input type="radio" name="n15minute_speed_to_lead" value="Yes"><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg><span>Yes</span></label>
                <label class="quiz-option quiz-option--yn quiz-option--no"><input type="radio" name="n15minute_speed_to_lead" value="No"><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg><span>No</span></label>
              </div>
            </div>

            <div class="quiz-q hidden" data-field="saturday_persistence">
              <div class="quiz-q-icon quiz-q-icon--alert">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
              </div>
              <h2 class="text-lg font-heading text-gray-900 mb-5">If a new lead doesn't answer your first call, does your team continue outbound follow-up on nights and weekends or wait until normal business hours to try again?</h2>
              <div class="quiz-yn-grid">
                <label class="quiz-option quiz-option--yn quiz-option--yes"><input type="radio" name="saturday_persistence" value="Yes"><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg><span>Yes</span></label>
                <label class="quiz-option quiz-option--yn quiz-option--no"><input type="radio" name="saturday_persistence" value="No"><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg><span>No</span></label>
              </div>
            </div>
          </div>

          <!-- HubSpot form (hidden until quiz complete) -->
          <div id="form-step" class="hidden">
            <div class="mb-5">
              <h2 class="text-lg font-heading text-gray-900 mb-1">See Your Results</h2>
              <p class="text-sm text-gray-500">Enter your info to get your personalized marketing waste score.</p>
            </div>
            <div id="hs-form-target"></div>
          </div>

          <!-- Results (hidden until form submitted) -->
          <div id="results-step" class="hidden">
            <div id="results-content"></div>
            <a href="/book-call" class="btn-primary btn-lg group w-full justify-center mt-6">
              Book Your 30-Minute Solutions Review
              <svg class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Leak -->
  <section class="lp-leak">
    <div class="container-wide">
      <div class="text-center mb-12">
        <span class="badge bg-error-50 text-error-700 border border-error-300 mb-3 reveal">The Leak</span>
        <h2 class="text-display-sm md:text-display-md font-heading text-gray-900 mb-4 reveal" style="transition-delay: 80ms">
          Where Your Marketing Dollars Actually Go
        </h2>
        <div class="divider-gold-center mt-5 reveal" style="transition-delay: 120ms"></div>
        <p class="text-lg text-gray-500 max-w-3xl mx-auto mt-5 reveal" style="transition-delay: 160ms">
          Most law firms blame their agency or their ads. But the real waste happens after the click — in the operational gaps nobody's watching.
        </p>
      </div>

      <!-- Waste flow diagram -->
      <div class="lp-flow reveal" style="transition-delay: 200ms">
        <div class="lp-flow-step lp-flow-step--green">
          <div class="lp-flow-icon">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
          </div>
          <span class="lp-flow-label">You spend $5K–$15K/mo on marketing</span>
        </div>
        <div class="lp-flow-arrow" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </div>
        <div class="lp-flow-step lp-flow-step--amber">
          <div class="lp-flow-icon">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
          </div>
          <span class="lp-flow-label">Leads come in</span>
        </div>
        <div class="lp-flow-arrow" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </div>
        <div class="lp-flow-step lp-flow-step--red">
          <div class="lp-flow-icon">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
          </div>
          <span class="lp-flow-label">Nobody follows up, tracks, or converts</span>
        </div>
      </div>

      <!-- Stat cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
        <div class="lp-stat-card reveal" style="transition-delay: 300ms">
          <div class="lp-stat-num text-error-600">78%</div>
          <p class="text-sm text-gray-700 font-medium">of leads go to the first firm that responds — not the best firm</p>
        </div>
        <div class="lp-stat-card reveal" style="transition-delay: 400ms">
          <div class="lp-stat-num text-error-600">$150K+</div>
          <p class="text-sm text-gray-700 font-medium">in annual revenue lost by firms with no after-hours follow-up system</p>
        </div>
        <div class="lp-stat-card reveal" style="transition-delay: 500ms">
          <div class="lp-stat-num text-error-600">67%</div>
          <p class="text-sm text-gray-700 font-medium">of law firm marketing spend generates zero attributable cases</p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Real Problem -->
  <section class="section-padding bg-gray-50 border-y border-gray-100 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_-20%,rgba(26,58,92,0.06),transparent_70%)] pointer-events-none"></div>
    <div class="container-narrow relative">
      <div class="text-center mb-12 reveal">
        <span class="badge badge-brand mb-3">The Real Problem</span>
        <h2 class="text-display-sm md:text-display-md font-heading text-gray-900 mb-4">
          It's Not a Marketing Problem.<br />It's an Operations Problem.
        </h2>
        <div class="divider-gold-center mt-5"></div>
      </div>

      <div class="lp-problems-list">
        {[
          {
            icon: "M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0",
            title: "Leads come in — nobody follows up fast enough",
            desc: "A lead that waits more than 5 minutes is already calling your competitor. If you don't have a system that responds instantly, your ad spend is subsidizing someone else's caseload."
          },
          {
            icon: "M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5",
            title: "Social media goes quiet for weeks",
            desc: "You paid for a website rebrand and a content strategy, but nobody's posting. Your firm looks inactive. Potential clients check your profiles and see radio silence — that's a trust killer."
          },
          {
            icon: "M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z",
            title: "No tracking — you can't tell what works",
            desc: "You're spending money across 4 channels but nobody's tracking which ones generate actual cases. Without attribution, you're guessing. And guessing is expensive."
          },
          {
            icon: "M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z",
            title: "Your team doesn't have time to execute",
            desc: "Partners shouldn't be scheduling posts. Paralegals shouldn't be chasing intake forms. The marketing execution falls through the cracks because it's nobody's dedicated job."
          },
        ].map((item, i) => (
          <div class="lp-problem-row reveal" style={`transition-delay: ${i * 100}ms`}>
            <div class="lp-problem-icon">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <div>
              <h3 class="text-base font-heading text-gray-900 mb-1">{item.title}</h3>
              <p class="text-sm text-gray-500 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The Fix -->
  <section class="section-padding">
    <div class="container-wide">
      <div class="text-center mb-12 reveal">
        <span class="badge badge-success mb-3">The Fix</span>
        <h2 class="text-display-sm md:text-display-md font-heading text-gray-900 mb-4">
          We Fix the Operations So Your Marketing Actually Converts
        </h2>
        <div class="divider-gold-center mt-5"></div>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto mt-5">
          We don't run your ads. We make sure the money you're already spending actually turns into clients.
        </p>
      </div>

      <div class="lp-fix-grid">
        {[
          { num: "01", title: "Instant Lead Response", desc: "Every inquiry gets acknowledged within minutes — nights, weekends, holidays. No lead goes cold.", color: "brand-gold" },
          { num: "02", title: "Consistent Content Execution", desc: "Your social media, email campaigns, and blog stay active with on-brand content posted on schedule.", color: "brand-blue" },
          { num: "03", title: "Pipeline Tracking & Attribution", desc: "We track every lead from first touch to signed retainer so you know exactly which spend generates cases.", color: "brand-gold" },
          { num: "04", title: "Follow-Up Sequences", desc: "Automated and human-driven follow-up that nurtures leads who aren't ready to sign today.", color: "brand-blue" },
          { num: "05", title: "Review & Reputation Management", desc: "Consistent review requests and monitoring that builds your online presence without you thinking about it.", color: "brand-gold" },
          { num: "06", title: "Monthly ROI Reporting", desc: "Clear reports that show what's working, what isn't, and where to shift budget — in plain English.", color: "brand-blue" },
        ].map((item, i) => (
          <div class="lp-fix-card reveal" style={`transition-delay: ${i * 80}ms`}>
            <span class={`lp-fix-num text-${item.color}`}>{item.num}</span>
            <h3 class="text-base font-heading text-gray-900 mb-1">{item.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Before / After Comparison -->
