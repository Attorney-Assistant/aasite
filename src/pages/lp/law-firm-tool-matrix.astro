---
import BaseLayout from "@layouts/BaseLayout.astro";
import HubSpotForm from "@components/HubSpotForm.astro";
---

<BaseLayout
  title="PI Law Firm Tool Matrix — Map Every Tool to Every Task | Attorney Assistant"
  description="Map every tool in your PI law firm to every task. 30+ tools, 38 tasks, 71 AI agent ideas. See where AI agents can take over your firm's operations."
  noindex={true}
  schema={{
    "@type": "WebPage",
    "name": "PI Law Firm Tool Matrix",
    "description": "Map every tool to every task. 30+ tools, 38 tasks, 71 AI agent ideas for PI law firms.",
    "publisher": {
      "@type": "Organization",
      "name": "Attorney Assistant"
    }
  }}
>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-gray-900">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-navy via-gray-900 to-brand-800"></div>
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    <div class="grain-overlay"></div>

    <div class="container-wide relative z-10 py-20 lg:py-28">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal">
          <span class="badge bg-white/10 text-white/80 border-white/10 mb-4">Free Interactive Tool</span>
          <h1 class="text-display-lg md:text-display-xl font-heading text-white leading-tight mb-6">
            Every Tool.<br />Every Task.
            <span class="text-gradient-gold">Every AI Opportunity.</span>
          </h1>
          <p class="text-lg md:text-xl text-gray-300 mb-8 leading-relaxed">
            The PI Law Firm Tool Matrix maps every tool in your tech stack to every task in your firm &mdash; then shows you exactly where AI agents can take over. Stop guessing which tools matter. Start seeing the gaps.
          </p>
          <div class="flex flex-wrap gap-4 mb-8">
            <a href="#access-the-matrix" class="btn-primary btn-lg group">
              Access the Tool Matrix
              <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" /></svg>
            </a>
          </div>
          <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-gray-400">
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              30+ tools mapped
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              38 tasks covered
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              71 AI agent ideas
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Export to Google Sheets
            </span>
          </div>
        </div>

        <!-- Form Card -->
        <div class="bg-white rounded-2xl p-6 md:p-8 shadow-2xl reveal" style="transition-delay: 150ms" id="access-the-matrix">
          <div class="flex items-center gap-3 mb-2">
            <div class="featured-icon featured-icon-md featured-icon-gold">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>
            </div>
            <div>
              <h2 class="text-xl font-heading text-gray-900">Access the Tool Matrix</h2>
              <p class="text-sm text-gray-500">Free &mdash; instant access</p>
            </div>
          </div>
          <p class="text-sm text-gray-500 mb-5">Enter your info below and you'll get immediate access to the interactive PI Law Firm Tool Matrix.</p>
          <HubSpotForm portalId="49161090" formId="27242cd1-e1ce-44d3-9119-be881499146a" />
        </div>
      </div>
    </div>
  </section>

  <!-- What's Inside -->
  <section class="section-padding bg-white">
    <div class="container-wide">
      <div class="text-center mb-12">
        <span class="badge badge-brand mb-3 reveal">What's Inside</span>
        <h2 class="text-display-sm md:text-display-md font-heading text-gray-900 mb-4 reveal" style="transition-delay: 80ms">
          Your Firm's Entire Tech Stack. Mapped.
        </h2>
        <div class="divider-gold-center mb-6"></div>
        <p class="text-gray-500 max-w-2xl mx-auto reveal" style="transition-delay: 120ms">
          The Tool Matrix answers the question every PI firm asks but can never answer cleanly: <strong>Which tools do we actually need, which tasks do they cover, and where are the gaps?</strong>
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 reveal" style="transition-delay: 160ms">
        <div class="card card-hover p-6">
          <div class="featured-icon featured-icon-md featured-icon-brand mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Tool-to-Task Grid</h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            30+ tools across your entire PI tech stack — CMS, phone systems, CRMs, e-sign, medical records, lien tools, and more — mapped against 38 operational tasks. See exactly which tools cover which tasks.
          </p>
        </div>

        <div class="card card-hover p-6">
          <div class="featured-icon featured-icon-md featured-icon-navy mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" /></svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">71 AI Agent Ideas</h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            Every task where an AI agent could replace or augment manual work — with descriptions, use cases, and the tools each agent would plug into. Your AI automation roadmap, pre-built.
          </p>
        </div>

        <div class="card card-hover p-6">
          <div class="featured-icon featured-icon-md featured-icon-gold mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" /></svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Customizable Mappings</h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            Toggle which tools your firm actually uses. Add custom tools. Edit AI agent descriptions to match your workflows. The matrix adapts to your firm, not the other way around.
          </p>
        </div>

        <div class="card card-hover p-6">
          <div class="featured-icon featured-icon-md featured-icon-success mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Gap Visibility</h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            Instantly see which tasks have no tool coverage, which tools overlap, and where you're paying for capabilities you're not using. Stop wasting budget on redundant software.
          </p>
        </div>

        <div class="card card-hover p-6">
          <div class="featured-icon featured-icon-md featured-icon-brand mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 14.25v2.25m3-4.5v4.5m3-6.75v6.75m3-9v9M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z" /></svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Task Group Breakdown</h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            Tasks organized by operational group — Intake, Case Management, Medical/Liens, Financial, Marketing, and Admin. See your firm's operations the way they actually run.
          </p>
        </div>

        <div class="card card-hover p-6">
          <div class="featured-icon featured-icon-md featured-icon-gray mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
          </div>
          <h3 class="text-lg font-heading text-gray-900 mb-2">Export to Google Sheets</h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            Export the full matrix and AI agent list as CSV or open directly in Google Sheets. Share with your team, use for vendor evaluations, or plan your automation rollout.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow">
      <div class="text-center mb-12">
        <span class="badge badge-gray mb-3 reveal">Who It's For</span>
        <h2 class="text-display-sm font-heading text-gray-900 mb-4 reveal" style="transition-delay: 80ms">
          Built for PI Firms Making Tech Decisions
        </h2>
        <div class="divider-gold-center mb-6"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-6 reveal" style="transition-delay: 120ms">
        <div class="flex gap-4 p-5 bg-white rounded-xl border border-gray-200">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-brand-gold/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" /></svg>
          </div>
          <div>
            <h3 class="font-heading text-gray-900 mb-1">Firm Owners Evaluating Tools</h3>
            <p class="text-sm text-gray-500">Stop buying software based on demos. See which tools actually cover your firm's tasks — and which ones don't.</p>
          </div>
        </div>

        <div class="flex gap-4 p-5 bg-white rounded-xl border border-gray-200">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-brand-blue/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
          </div>
          <div>
            <h3 class="font-heading text-gray-900 mb-1">Firms Exploring AI Automation</h3>
            <p class="text-sm text-gray-500">71 pre-built AI agent concepts mapped to your existing tools. See exactly where to start automating — and with what.</p>
          </div>
        </div>

        <div class="flex gap-4 p-5 bg-white rounded-xl border border-gray-200">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-brand-navy/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-navy" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" /></svg>
          </div>
          <div>
            <h3 class="font-heading text-gray-900 mb-1">COOs Auditing Tech Spend</h3>
            <p class="text-sm text-gray-500">Find overlapping tools, identify gaps, and build a business case for consolidation or new investments — backed by data, not gut feel.</p>
          </div>
        </div>

        <div class="flex gap-4 p-5 bg-white rounded-xl border border-gray-200">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-green-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>
          </div>
          <div>
            <h3 class="font-heading text-gray-900 mb-1">Legal Ops Consultants</h3>
            <p class="text-sm text-gray-500">Use the matrix as a diagnostic framework for client engagements. Customize per firm, export recommendations, and track implementation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA with Form -->
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-navy via-brand-800 to-brand-navy grain-overlay" id="get-started">
    <div class="absolute inset-0">
      <div class="absolute top-20 left-1/4 w-96 h-96 bg-brand-gold/15 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-1/3 w-80 h-80 bg-brand-blue/15 rounded-full blur-3xl"></div>
    </div>
    <div class="container-wide relative py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="text-center lg:text-left reveal">
          <h2 class="text-display-sm md:text-display-md font-heading text-white mb-4">
            See Your Firm's Tech Stack Clearly
          </h2>
          <div class="divider-gold-center lg:divider-gold mb-6"></div>
          <p class="text-lg text-white/60 max-w-xl mb-8">
            Stop paying for tools you don't use and missing capabilities you need. Access the PI Law Firm Tool Matrix and map your entire tech stack in minutes.
          </p>
          <div class="flex flex-wrap gap-x-6 gap-y-3 text-sm text-white/40 justify-center lg:justify-start">
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              No credit card
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Instant access
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Google Sheets export
            </span>
          </div>
        </div>

        <div class="bg-white/10 backdrop-blur-sm border border-white/15 rounded-2xl p-8 md:p-10 text-center reveal" style="transition-delay: 150ms">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-brand-gold/15 text-brand-gold mb-5">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>
          </div>
          <h3 class="text-xl font-heading text-white mb-2">Ready to Map Your Tech Stack?</h3>
          <p class="text-sm text-white/50 mb-6">Takes 30 seconds. Instant access.</p>
          <a href="#access-the-matrix" class="btn-primary btn-lg group w-full justify-center">
