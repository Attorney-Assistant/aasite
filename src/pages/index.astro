<script>
(function () {
  const section = document.getElementById("why-us");
  if (!section) return;

  const cards = section.querySelectorAll<HTMLElement>(".wu-card");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.wu || "0", 10) * 350;
          setTimeout(() => el.classList.add("wu-visible"), delay);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.3 }
  );

  cards.forEach((card) => observer.observe(card));
})();
</script>

<style>
  /* Hero rotating headline */
  .hero-rotate {
    display: block;
    position: relative;
  }

  /* Invisible sizer — takes up space for the longest phrase so the container never jumps */
  .hero-rotate__sizer {
    display: block;
    visibility: hidden;
    height: auto;
    pointer-events: none;
  }

  .hero-rotate__item {
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    transform: translateY(0.35em);
    transition: opacity 0.5s ease, transform 0.5s ease;
    pointer-events: none;
  }

  .hero-rotate__item.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .hero-rotate__item.is-exiting {
    opacity: 0;
    transform: translateY(-0.35em);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-rotate__item {
      transition: none;
    }
  }
</style>

<script>
(function () {
  const container = document.querySelector('.hero-rotate');
  if (!container) return;

  const items = container.querySelectorAll('.hero-rotate__item');
  if (items.length < 2) return;

  let current = 0;
  const DISPLAY_MS = 2200;
  const TRANSITION_MS = 500;
  const LAST = items.length - 1;

  // Activate first item
  items[0].classList.add('is-active');

  function rotate() {
    const prev = current;
    current++;

    // Exit current
    items[prev].classList.remove('is-active');
    items[prev].classList.add('is-exiting');

    // Enter next
    items[current].classList.add('is-active');

    // Update aria
    items[prev].setAttribute('aria-hidden', 'true');
    items[current].removeAttribute('aria-hidden');

    // Clean up exit class after transition
    setTimeout(function () {
      items[prev].classList.remove('is-exiting');
    }, TRANSITION_MS);

    // Stop when we reach the last item
    if (current >= LAST) clearInterval(timer);
  }

  var timer = setInterval(rotate, DISPLAY_MS + TRANSITION_MS);
})();
</script>
