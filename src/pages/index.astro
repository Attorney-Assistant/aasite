---
import BaseLayout from "@layouts/BaseLayout.astro";
import HubSpotForm from "@components/HubSpotForm.astro";
import LogoScroller from "@components/LogoScroller.astro";
import ComparisonTable from "@components/ComparisonTable.astro";
import ProcessSteps from "@components/ProcessSteps.astro";
import ServiceCard from "@components/ServiceCard.astro";
import YouTubeEmbed from "@components/YouTubeEmbed.astro";
import TestimonialCard from "@components/TestimonialCard.astro";
import CTABanner from "@components/CTABanner.astro";
import DayTimeline from "@components/DayTimeline.astro";
import { fetchFeaturedTestimonials } from "@lib/hubspot";

let testimonials: any[] = [];

try {
  testimonials = (await fetchFeaturedTestimonials()) || [];
} catch {
  // Build continues with empty data if HubSpot is unreachable
}
---

<BaseLayout title="Attorney Assistant — Delegate to Achieve More" description="Attorney Assistant solves the operational problems that prevent law firms from growing — intake failure, follow-up gaps, and admin chaos. Trusted by 200+ law firms.">

  <!-- Hero -->
  <section class="relative overflow-hidden bg-brand-950 grain-overlay">
    <!-- Background elements -->
    <div class="absolute inset-0 bg-gradient-to-br from-brand-navy via-brand-900 to-brand-950"></div>
    <!-- Floating orbs sit above the gradient -->
    <div class="home-hero-orb home-hero-orb--1" aria-hidden="true"></div>
    <div class="home-hero-orb home-hero-orb--2" aria-hidden="true"></div>
    <div class="home-hero-orb home-hero-orb--3" aria-hidden="true"></div>

    <div class="container-wide relative z-10 py-14 lg:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-start">
        <!-- Left: Copy + Stats -->
        <div class="pt-0 lg:pt-4">
          <div class="mb-6 reveal">
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium bg-white/5 text-brand-200 border border-white/10 backdrop-blur-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-gold animate-pulse"></span>
              Trusted by 200+ law firms
            </span>
          </div>
          <h1 class="text-display-md md:text-display-lg lg:text-display-xl text-white leading-tight mb-6 reveal" style="transition-delay: 100ms">
            You don't have a lead problem.<br />
            <span class="hero-rotate" aria-live="polite">
              <!-- Sizer: invisible, holds the longest phrase to reserve height -->
              <span class="hero-rotate__sizer text-gradient-gold" aria-hidden="true">You have an operations problem.</span>
              <span class="hero-rotate__item text-gradient-gold is-active">You have an intake problem.</span>
              <span class="hero-rotate__item text-gradient-gold" aria-hidden="true">You have a follow-up problem.</span>
              <span class="hero-rotate__item text-gradient-gold" aria-hidden="true">You have an operations problem.</span>
            </span>
          </h1>
          <p class="text-lg md:text-xl text-gray-400 mb-6 leading-relaxed max-w-lg reveal" style="transition-delay: 200ms">
            Attorney Assistant handles the intake, follow-up, and admin that law firms consistently fail to execute — so more of your existing leads actually close.
          </p>
          <div class="flex flex-wrap gap-3 mb-8 reveal" style="transition-delay: 300ms">
            <a href="/book-call" class="btn-primary btn-lg group">
              Start Growing Your Firm
              <svg class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
              </svg>
            </a>
            <a href="/services" class="btn-ghost-light btn-lg">
              Explore Services
            </a>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-3 gap-6 pt-8 border-t border-white/10 reveal" style="transition-delay: 400ms">
            <div>
              <p class="text-display-xs md:text-display-sm text-white font-heading">60%+</p>
              <p class="text-xs text-gray-500 mt-1 uppercase tracking-widest">Cost Savings</p>
            </div>
            <div>
              <p class="text-display-xs md:text-display-sm text-white font-heading">200+</p>
              <p class="text-xs text-gray-500 mt-1 uppercase tracking-widest">Law Firms</p>
            </div>
            <div>
              <p class="text-display-xs md:text-display-sm text-white font-heading">1000s</p>
              <p class="text-xs text-gray-500 mt-1 uppercase tracking-widest">Hours Saved</p>
            </div>
          </div>
        </div>

        <!-- Right: HubSpot Form Card -->
        <div class="bg-white rounded-2xl p-6 md:p-8 shadow-2xl ring-1 ring-white/10 reveal-scale" style="transition-delay: 200ms">
          <div class="mb-5">
            <h2 class="text-xl font-heading text-gray-900 mb-1">Get Started</h2>
            <p class="text-sm text-gray-500"><a href="/book-call" class="text-brand-blue underline hover:text-brand-navy transition-colors">Book a call</a> or submit the form and we'll reach out.</p>
          </div>
          <HubSpotForm portalId="49161090" formId="8459e8a1-ab4f-4e5f-80ce-9767181c4791" region="na1" />
          <p class="text-xs text-gray-400 mt-4 leading-relaxed">
            By providing your information, you agree to receive telephone calls and SMS or MMS text messages for marketing purposes at the phone number provided.
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom gradient line -->
    <div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-gold/30 to-transparent"></div>
  </section>

  <!-- Logo Scroller -->
  <LogoScroller />

  <!-- Services Grid -->
  <section class="section-padding bg-white">
    <div class="container-wide">
      <div class="text-center mb-14 reveal">
        <span class="badge badge-brand mb-4">Services</span>
        <h2 class="text-display-sm md:text-display-md text-gray-900 mb-4">The Work Your Firm Needs But Hates to Manage</h2>
        <div class="divider-gold-center mt-4 mb-5"></div>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto">We handle the operational work that prevents law firms from growing — built as a custom combination matched to your firm's specific bottlenecks.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="reveal" style="transition-delay: 0ms">
          <ServiceCard title="Lead Follow-up" description="Never lose a lead again. Our team follows up with every prospect promptly and professionally.">
            <svg slot="icon" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
          </ServiceCard>
        </div>
        <div class="reveal" style="transition-delay: 75ms">
          <ServiceCard title="Intake" description="Comprehensive client intake that captures every detail and qualifies leads for your firm.">
            <svg slot="icon" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
          </ServiceCard>
        </div>
        <div class="reveal" style="transition-delay: 150ms">
          <ServiceCard title="Appointment Booking" description="Seamless scheduling that keeps your calendar full and your clients on track.">
            <svg slot="icon" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
          </ServiceCard>
        </div>
        <div class="reveal" style="transition-delay: 225ms">
          <ServiceCard title="Case Calling" description="Proactive case status updates and follow-up calls to keep clients informed and engaged.">
            <svg slot="icon" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" /></svg>
          </ServiceCard>
        </div>
        <div class="reveal" style="transition-delay: 300ms">
          <ServiceCard title="File Organization" description="Meticulous document management and file organization to keep your cases running smoothly.">
            <svg slot="icon" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" /></svg>
          </ServiceCard>
        </div>
        <div class="reveal" style="transition-delay: 375ms">
          <ServiceCard title="Medical Record Acquisition" description="Timely retrieval of medical records and documentation critical to your cases.">
            <svg slot="icon" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
          </ServiceCard>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Testimonials -->
  <section class="section-padding bg-white">
    <div class="container-wide">
      <div class="text-center mb-14 reveal">
        <span class="badge badge-brand mb-4">From Our Clients</span>
        <h2 class="text-display-sm md:text-display-md text-gray-900 mb-4">Video Testimonials</h2>
        <div class="divider-gold-center mt-4 mb-5"></div>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto">Hear directly from law firms about their experience working with Attorney Assistant.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="reveal" style="transition-delay: 0ms">
          <YouTubeEmbed videoId="o3Fac0xRxCE" title="Client testimonial 1" />
        </div>
        <div class="reveal" style="transition-delay: 100ms">
          <YouTubeEmbed videoId="EZbEo5HYDqg" title="Client testimonial 2" />
        </div>
        <div class="reveal" style="transition-delay: 200ms">
          <YouTubeEmbed videoId="xQCIwMPlLMc" title="Client testimonial 3" />
        </div>
      </div>
    </div>
  </section>

  <!-- Day Timeline -->
  <section class="section-padding bg-gray-25 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-mesh opacity-40"></div>
    <div class="container-wide relative">
      <div class="text-center mb-12 md:mb-16 reveal">
        <span class="badge badge-brand">A Day in the Life</span>
        <h2 class="text-display-xs md:text-display-sm font-heading text-gray-900 mt-4 mb-5">
          See What Changes When We're In Your Corner
        </h2>
        <div class="divider-gold-center mt-5"></div>
        <p class="text-lg text-gray-500 leading-relaxed max-w-2xl mx-auto">
          Walk through a real day at a law firm — with and without our support — and see the difference it makes.
        </p>
      </div>
      <DayTimeline />
    </div>
  </section>

  <!-- The Three Problems -->
  <section class="section-padding bg-white">
    <div class="container-wide">
      <div class="text-center mb-6 reveal">
        <span class="badge badge-brand mb-4">The Problem</span>
        <h2 class="text-display-sm md:text-display-md text-gray-900">It's Not a Marketing Problem.<br class="hidden md:block" /> It's an Operations Problem.</h2>
        <div class="divider-gold-center mt-5"></div>
      </div>
      <p class="text-center text-gray-500 leading-relaxed max-w-2xl mx-auto mb-14 reveal" style="transition-delay: 50ms">
        Three operational failures cost law firms more revenue than they realize. Attorney Assistant solves all three — not by giving you more people, but by fixing how the work gets done.
      </p>

      <!-- 3 problem cards — each visually distinct -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 md:gap-0 max-w-5xl mx-auto three-problems">
        <!-- Problem 1: Intake Failure -->
        <div class="tp-card tp-card--red reveal" style="transition-delay: 100ms">
          <div class="tp-number">01</div>
          <div class="tp-icon-wrap tp-icon-wrap--red">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
          </div>
          <h3 class="tp-title">Intake Failure</h3>
          <p class="tp-stat"><span class="tp-stat-num">20%</span> of leads lost</p>
          <p class="tp-desc">Before anyone even picks up the phone. Missed calls, slow callbacks, broken handoffs — revenue walks out the door every day.</p>
        </div>

        <!-- Problem 2: Admin Chaos -->
        <div class="tp-card tp-card--amber reveal" style="transition-delay: 200ms">
          <div class="tp-number">02</div>
          <div class="tp-icon-wrap tp-icon-wrap--amber">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="tp-title">Admin Chaos</h3>
          <p class="tp-stat"><span class="tp-stat-num">15+</span> hrs/week wasted</p>
          <p class="tp-desc">Your attorneys lose over 15 hours per week to non-billable work — filing, scheduling, chasing records — instead of practicing law.</p>
        </div>

        <!-- Problem 3: Growth Stagnation -->
        <div class="tp-card tp-card--navy reveal" style="transition-delay: 300ms">
          <div class="tp-number">03</div>
          <div class="tp-icon-wrap tp-icon-wrap--navy">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" /></svg>
          </div>
          <h3 class="tp-title">Growth Stagnation</h3>
          <p class="tp-stat"><span class="tp-stat-num">$1M–$2M</span> plateau</p>
          <p class="tp-desc">Without systems, firms hit a ceiling and can't break through. Adding people without fixing operations just adds more chaos.</p>
        </div>
      </div>

      <div class="text-center mt-10 reveal" style="transition-delay: 400ms">
        <a href="/services" class="btn-primary btn-lg group">
          See How We Fix All Three
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Firms Choose Us -->
  <section class="section-padding bg-brand-950 grain-overlay relative overflow-hidden" id="why-us">
    <div class="absolute inset-0">
      <div class="home-hero-orb home-hero-orb--2" style="top: -20%; bottom: auto;"></div>
    </div>
    <div class="container-wide relative z-10">
      <div class="text-center mb-14 reveal">
        <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium bg-white/5 text-brand-200 border border-white/10 backdrop-blur-sm mb-4">Why Us</span>
        <h2 class="text-display-sm md:text-display-md text-white">Why Firms Choose Attorney Assistant</h2>
        <div class="divider-gold-center mt-5"></div>
      </div>

      <div class="wu-grid">
        <!-- Item 1 -->
        <div class="wu-card reveal" data-wu="0" style="transition-delay: 100ms">
          <div class="wu-card-inner">
            <div class="wu-num-ring">
              <span class="wu-num">01</span>
              <svg class="wu-ring" viewBox="0 0 80 80" aria-hidden="true" focusable="false" tabindex="-1">
                <circle cx="40" cy="40" r="36" fill="none" stroke="rgba(249,166,48,0.1)" stroke-width="1.5"/>
                <circle cx="40" cy="40" r="36" fill="none" stroke="#F9A630" stroke-width="1.5"
                  stroke-dasharray="226.19" stroke-dashoffset="226.19" stroke-linecap="round"
                  class="wu-ring-fill"/>
              </svg>
            </div>
            <h3 class="wu-title">We Fix What's Broken</h3>
            <p class="wu-desc">We don't sell services — we solve the intake failures, follow-up gaps, and admin chaos that are costing your firm revenue.</p>
            <div class="wu-accent wu-accent--gold" aria-hidden="true"></div>
          </div>
          <div class="wu-glow wu-glow--gold" aria-hidden="true"></div>
        </div>

        <!-- Item 2 -->
        <div class="wu-card reveal" data-wu="1" style="transition-delay: 250ms">
          <div class="wu-card-inner">
            <div class="wu-num-ring">
              <span class="wu-num">02</span>
              <svg class="wu-ring" viewBox="0 0 80 80" aria-hidden="true" focusable="false" tabindex="-1">
                <circle cx="40" cy="40" r="36" fill="none" stroke="rgba(80,167,221,0.1)" stroke-width="1.5"/>
                <circle cx="40" cy="40" r="36" fill="none" stroke="#50a7dd" stroke-width="1.5"
                  stroke-dasharray="226.19" stroke-dashoffset="226.19" stroke-linecap="round"
                  class="wu-ring-fill"/>
              </svg>
            </div>
            <h3 class="wu-title">Co-Managed, Not Outsourced</h3>
            <p class="wu-desc">We embed in your daily workflow. This isn't "set it and forget it" — we co-manage operations alongside your team so nothing falls through.</p>
            <div class="wu-accent wu-accent--blue" aria-hidden="true"></div>
          </div>
          <div class="wu-glow wu-glow--blue" aria-hidden="true"></div>
        </div>

        <!-- Item 3 -->
        <div class="wu-card reveal" data-wu="2" style="transition-delay: 400ms">
          <div class="wu-card-inner">
            <div class="wu-num-ring">
              <span class="wu-num">03</span>
              <svg class="wu-ring" viewBox="0 0 80 80" aria-hidden="true" focusable="false" tabindex="-1">
                <circle cx="40" cy="40" r="36" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1.5"/>
                <circle cx="40" cy="40" r="36" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"
                  stroke-dasharray="226.19" stroke-dashoffset="226.19" stroke-linecap="round"
                  class="wu-ring-fill"/>
              </svg>
            </div>
            <h3 class="wu-title">Your Success Is Our Success</h3>
            <p class="wu-desc">We're not a vendor — we're an extension of your team. The deeper we integrate, the more efficient your firm becomes. When you grow, we grow.</p>
            <div class="wu-accent wu-accent--white" aria-hidden="true"></div>
          </div>
          <div class="wu-glow wu-glow--white" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Steps -->
  <ProcessSteps />

  <!-- Comparison Table -->
  <ComparisonTable />

  <!-- Testimonials -->
  {testimonials.length > 0 && (
    <section class="section-padding bg-gray-50 border-y border-gray-100 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-mesh opacity-30"></div>
      <div class="container-wide relative">
        <div class="text-center mb-14 reveal">
          <span class="badge badge-brand mb-4">Testimonials</span>
          <h2 class="text-display-sm md:text-display-md text-gray-900">What Our Clients Say</h2>
          <div class="divider-gold-center mt-5"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {testimonials.slice(0, 3).map((t: any, i: number) => (
            <div class="reveal" style={`transition-delay: ${i * 100}ms`}>
              <TestimonialCard {...t} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <CTABanner
    heading="Stop Leaking Revenue. Start Scaling."
    body="Most firms don't need more leads — they need to stop losing the ones they have. We'll diagnose your operational gaps and fix them."
    buttonText="Explore Our Services"
    buttonLink="/services"
    secondaryButtonText="Book a Call"
    secondaryButtonLink="/contact"
    variant="brand"
  />

</BaseLayout>

<style>
  /* ── Homepage hero floating orbs ── */
  .home-hero-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
  }
  .home-hero-orb--1 {
    width: 700px; height: 700px;
