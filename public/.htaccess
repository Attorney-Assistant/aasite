# Redirect rules for Attorney Assistant
# Auto-generated - do not edit manually

ErrorDocument 404 /404.html

RewriteEngine On

# ── Capital-B /Blog/ → lowercase /blog/ redirects ──
RewriteRule ^Blog/?$ /blog [R=301,L]
RewriteRule ^Blog/category/(.*)$ /blog/category/$1 [R=301,L]
RewriteRule ^Blog/page/(.*)$ /blog [R=301,L]
RewriteRule ^Blog/(.+)$ /blog/$1 [R=301,L]

# ── Legacy page redirects ──
RewriteRule ^attorney-assistant-home/?$ / [R=301,L]
RewriteRule ^home-old/?$ / [R=301,L]
RewriteRule ^virtual-legal-assistants/?$ /services/virtual-legal-assistants [R=301,L]
RewriteRule ^admin-support/?$ /services/admin-support [R=301,L]
RewriteRule ^legal-receptionist/?$ /services/legal-receptionist [R=301,L]
RewriteRule ^executive-assistant/?$ /services/executive-assistant [R=301,L]
RewriteRule ^marketing-support/?$ /services/marketing-support [R=301,L]
RewriteRule ^intake-reception/?$ /services/intake-360 [R=301,L]
RewriteRule ^intake360/?$ /services/intake-360 [R=301,L]
RewriteRule ^new-book-a-call/?$ /book-call [R=301,L]
RewriteRule ^book-a-call/?$ /book-call [R=301,L]
RewriteRule ^calendly-booking-page/?$ /book-call [R=301,L]
RewriteRule ^calendly-booking-page-linkedin/?$ /book-call [R=301,L]
RewriteRule ^calendly-booking-page-smb/?$ /book-call [R=301,L]

# (wp-content redirects removed — files served directly from /wp-content/uploads/)

